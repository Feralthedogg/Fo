                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"error"}))
            }
        }
    }
    return None[FuncInfo]()
}

func ReceiverStdlibMethodNames(receiverType string) []string {
    names := StdlibGeneratedMethodNames(receiverType)
    pointerType := PointerReceiverFallbackType(receiverType)
    if !(pointerType == "") {
        return ConcatStrings(names, StdlibGeneratedMethodNames(pointerType), 0)
    }
    return names
}

func ReceiverAllMethodNames(receiverType string, methods []MethodInfo) []string {
    names := ConcatUniqueStrings(ReceiverMethodNames(receiverType, methods), LiveAnyMethodNames(receiverType), 0)
    return ConcatUniqueStrings(names, ReceiverStdlibMethodNames(receiverType), 0)
}

func ResolvePackageFuncSig(path string, name string, argCount int) Option[FuncInfo] {
    live := LiveAnyPackageFuncSig(path, name, argCount)
    if !isNone[FuncInfo](live) {
        return live
    }
    ctor := ResolvePackageTypeCtorSig(path, name, argCount)
    if !isNone[FuncInfo](ctor) {
        return ctor
    }
    if IsStdlibImportPath(path) {
        generated := StdlibGeneratedPackageFuncSig(path, name, argCount)
        if !isNone[FuncInfo](generated) {
            return generated
        }
        prototype := StdlibGeneratedPackageFuncPrototype(path, name)
        if !isNone[FuncInfo](prototype) {
            return prototype
        }
    }
    if IsStdlibImportPath(path) {
        if StringIn(StdlibPackageFunctionNames(path), name) {
            return Some[FuncInfo](VariadicFuncInfo(name, []string{}, []string{}, "any", argCount, []string{"any"}))
        }
        return None[FuncInfo]()
    }
    return None[FuncInfo]()
}

func ResolvePackageTypeCtorSig(path string, name string, argCount int) Option[FuncInfo] {
    typeName := ResolvePackageValueType(path, name)
    if typeName == "" {
        return None[FuncInfo]()
    }
    underlying := StdlibNamedUnderlyingType(typeName)
    if underlying == "" {
        return None[FuncInfo]()
    }
    info := MakeSimpleFuncInfo(name, []string{"value"}, []string{underlying}, []string{typeName})
    if argCount == 1 {
        return Some[FuncInfo](info)
    }
    return Some[FuncInfo](info)
}

func ResolvePackageValueType(path string, name string) string {
    liveType := LiveAnyPackageMemberType(path, name)
    if !(liveType == "") {
        return liveType
    }
    if IsStdlibImportPath(path) {
        generatedType := StdlibGeneratedMemberType(path, name)
        if !(generatedType == "") {
            return generatedType
        }
        if StringIn(StdlibPackageMemberNames(path), name) {
            return "any"
        }
        if StringIn(StdlibPackageFunctionNames(path), name) {
            return "any"
        }
        return ""
    }
    return ""
}

func StdlibPackageNames(path string) []string {
    return ConcatStrings(StdlibPackageFunctionNames(path), StdlibPackageMemberNames(path), 0)
}

func AnyPackageFunctionNames(path string) []string {
    live := LiveAnyPackageFunctionNames(path)
    if len(live) > 0 {
        return live
    }
    return StdlibPackageFunctionNames(path)
}

func AnyPackageMemberNames(path string) []string {
    live := LiveAnyPackageMemberNames(path)
    if len(live) > 0 {
        return live
    }
    return StdlibPackageMemberNames(path)
}

func AnyPackageCallableNames(path string) []string {
    return ConcatStrings(AnyPackageFunctionNames(path), AnyPackageTypeNames(path), 0)
}

func AnyPackageNames(path string) []string {
    return ConcatStrings(AnyPackageFunctionNames(path), AnyPackageMemberNames(path), 0)
}

func AnyPackageTypeNames(path string) []string {
    return PackageTypeNamesFrom(path, AnyPackageMemberNames(path), 0, []string{})
}

func PackageTypeNamesFrom(path string, names []string, idx int, acc []string) []string {
    if idx >= len(names) {
        return acc
    }
    typeName := ResolvePackageValueType(path, names[idx])
    if !(typeName == "") {
        if QualifiedTypeBaseName(typeName) == names[idx] {
            return PackageTypeNamesFrom(path, names, idx + 1, append(acc, names[idx]))
        }
    }
    return PackageTypeNamesFrom(path, names, idx + 1, acc)
}

func IsStdlibImportPath(path string) bool {
    if path == "" {
        return false
    }
    head := StdlibFirstSegment(path, 0, "")
    if head == "" {
        return false
    }
    return !strings.Contains(head, ".")
}

func StdlibFirstSegment(path string, idx int, acc string) string {
    if idx >= len(path) {
        return acc
    }
    if path[idx] == "/"[0] {
        return acc
    }
    return StdlibFirstSegment(path, idx + 1, acc + string(path[idx]))
}

