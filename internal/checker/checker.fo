package checker

import "github.com/Feralthedogg/Fo/internal/ast"
import "github.com/Feralthedogg/Fo/internal/diagnostic"
import "github.com/Feralthedogg/Fo/internal/token"
import "strings"

type NameEntry struct {
    Name string
    Kind string
    Pos token.Pos
}

func EmptyNameEntry() NameEntry {
    return NameEntry{
        Name: "",
        Kind: "",
        Pos: ast.ZeroPos(),
    }
}

type BindingState struct {
    Diag diagnostic.Diagnostics
    Local []NameEntry
    Visible []NameEntry
}

type TypeEntry struct {
    Name string
    TypeName string
}

type EnumInfo struct {
    Name string
    Variants []string
}

func EmptyEnumInfo() EnumInfo {
    return EnumInfo{
        Name: "",
        Variants: []string{},
    }
}

type StructInfo struct {
    Name string
    Fields []FieldTypeInfo
}

func EmptyStructInfo() StructInfo {
    return StructInfo{
        Name: "",
        Fields: []FieldTypeInfo{},
    }
}

type FieldTypeInfo struct {
    Name string
    TypeName string
}

type InterfaceInfo struct {
    Name string
    Methods []FuncInfo
}

func EmptyInterfaceInfo() InterfaceInfo {
    return InterfaceInfo{
        Name: "",
        Methods: []FuncInfo{},
    }
}

type MethodInfo struct {
    ReceiverType string
    Name string
    ParamNames []string
    ParamTypes []string
    ResultTypes []string
}

func EmptyMethodInfo() MethodInfo {
    return MethodInfo{
        ReceiverType: "",
        Name: "",
        ParamNames: []string{},
        ParamTypes: []string{},
        ResultTypes: []string{},
    }
}

type FuncInfo struct {
    Name string
    TypeParams []string
    ParamNames []string
    ParamTypes []string
    ResultTypes []string
}

func EmptyFuncInfo() FuncInfo {
    return FuncInfo{
        Name: "",
        TypeParams: []string{},
        ParamNames: []string{},
        ParamTypes: []string{},
        ResultTypes: []string{},
    }
}

type TypeBinding struct {
    Name string
    TypeName string
}

type SubsequenceMemoEntry struct {
    LeftIdx int
    RightIdx int
    Value int
}

type SubsequenceMemoResult struct {
    Value int
    Memo []SubsequenceMemoEntry
}

func Check(file ast.File) diagnostic.Diagnostics {
    return CheckWithBase(file, diagnostic.New())
}

func CheckWithBase(file ast.File, base diagnostic.Diagnostics) diagnostic.Diagnostics {
    PreloadImportedPackages(file.Imports, 0)
    imports := CollectImportEntries(file.Imports, 0, []NameEntry{})
    importTypes := CollectImportTypeEntries(file.Imports, 0, []TypeEntry{})
    externs := EffectiveExternNames(file)
    enums := CollectEnums(file.Decls, 0, []EnumInfo{})
    structs := ConcatStructInfos(CollectStructs(file.Decls, 0, []StructInfo{}), StdlibStructInfos(), 0)
    interfaces := CollectInterfaces(file.Decls, 0, []InterfaceInfo{})
    funcs := ConcatFuncInfos(CollectFuncs(file.Decls, 0, []FuncInfo{}), CollectConstructors(file.Decls, 0, []FuncInfo{}))
    methods := CollectMethods(file.Decls, 0, []MethodInfo{})
    return CheckDecls(file.Decls, []NameEntry{}, imports, importTypes, base, externs, enums, structs, interfaces, funcs, methods)
}

func PreloadImportedPackages(imports []ast.ImportDecl, idx int) {
    if idx >= len(imports) {
        return
    }
    path := TrimImportQuotes(ast.ImportPath(imports[idx]))
    if !(path == "") {
        if !IsStdlibImportPath(path) {
            LiveAnyPreload(path)
        }
    }
    PreloadImportedPackages(imports, idx + 1)
}

func StdlibStructInfos() []StructInfo {
    return []StructInfo{
        StructInfo{
            Name: "exec.Cmd",
            Fields: []FieldTypeInfo{
                FieldTypeInfo{Name: "Path", TypeName: "string"},
                FieldTypeInfo{Name: "Args", TypeName: "[]string"},
                FieldTypeInfo{Name: "Dir", TypeName: "string"},
                FieldTypeInfo{Name: "Env", TypeName: "[]string"},
                FieldTypeInfo{Name: "Stdout", TypeName: "any"},
                FieldTypeInfo{Name: "Stderr", TypeName: "any"},
                FieldTypeInfo{Name: "Stdin", TypeName: "any"},
                FieldTypeInfo{Name: "ProcessState", TypeName: "any"},
            },
        },
    }
}

func ConcatStructInfos(left []StructInfo, right []StructInfo, idx int) []StructInfo {
    if idx >= len(right) {
        return left
    }
    return ConcatStructInfos(append(left, right[idx]), right, idx + 1)
}

func CollectImportEntries(imports []ast.ImportDecl, idx int, acc []NameEntry) []NameEntry {
    if idx >= len(imports) {
        return acc
    }
    name := ImportVisibleName(imports[idx])
    if name == "" {
        return CollectImportEntries(imports, idx + 1, acc)
    }
    return CollectImportEntries(imports, idx + 1, append(acc, NameEntry{
        Name: name,
        Kind: "import",
        Pos: imports[idx].Pos,
    }))
}

func CollectImportTypeEntries(imports []ast.ImportDecl, idx int, acc []TypeEntry) []TypeEntry {
    if idx >= len(imports) {
        return acc
    }
    name := ImportVisibleName(imports[idx])
    if name == "" {
        return CollectImportTypeEntries(imports, idx + 1, acc)
    }
    return CollectImportTypeEntries(imports, idx + 1, append(acc, TypeEntry{
        Name: name,
        TypeName: "pkg:" + TrimImportQuotes(ast.ImportPath(imports[idx])),
    }))
}

func ImportVisibleName(imp ast.ImportDecl) string {
    alias := ast.ImportAlias(imp)
    if alias == "_" || alias == "." {
        return ""
    }
    if !(alias == "") {
        return alias
    }
    return ImportBaseName(ast.ImportPath(imp))
}

func TrimImportQuotes(path string) string {
    return strings.TrimPrefix(strings.TrimSuffix(path, "\""), "\"")
}

func ImportBaseName(path string) string {
    trimmed := strings.TrimPrefix(strings.TrimSuffix(path, "\""), "\"")
    if trimmed == "github.com/Feralthedogg/Fo/stdlib/fo" {
        return "base"
    }
    last := ImportBaseNameFrom(trimmed, len(trimmed) - 1, "")
    if IsMajorVersionImportSegment(last) {
        prefix := ImportTrimLastSegment(trimmed)
        prev := ImportBaseNameFrom(prefix, len(prefix) - 1, "")
        if !(prev == "") {
            return prev
        }
    }
    return last
}

func ImportTrimLastSegment(path string) string {
    return ImportTrimLastSegmentFrom(path, len(path) - 1, "")
}

func ImportTrimLastSegmentFrom(path string, idx int, acc string) string {
    if idx < 0 {
        return ""
    }
    if path[idx] == "/"[0] {
        return acc
    }
    return ImportTrimLastSegmentFrom(path, idx - 1, string(path[idx]) + acc)
}

func IsMajorVersionImportSegment(value string) bool {
    if len(value) < 2 {
        return false
    }
    if !(value[0] == "v"[0]) {
        return false
    }
    return ImportDigitsOnly(value, 1)
}

func ImportDigitsOnly(value string, idx int) bool {
    if idx >= len(value) {
        return true
    }
    if value[idx] < "0"[0] || value[idx] > "9"[0] {
        return false
    }
    return ImportDigitsOnly(value, idx + 1)
}

func ImportBaseNameFrom(path string, idx int, acc string) string {
    if idx < 0 {
        return acc
    }
    if path[idx] == "/"[0] {
        return acc
    }
    return ImportBaseNameFrom(path, idx - 1, string(path[idx]) + acc)
}

func EffectiveExternNames(file ast.File) []string {
    if ast.FilePackageName(file) == "main" {
        return []string{}
    }
    return CollectExternNames(file.Decls, 0, []string{})
}

func CollectExternNames(decls []ast.Decl, idx int, acc []string) []string {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    if ast.DeclIsFuncDecl(decl) {
        if ast.DeclIsExtern(decl) {
            return CollectExternNames(decls, idx + 1, append(acc, ast.DeclName(decl)))
        }
    }
    return CollectExternNames(decls, idx + 1, acc)
}

func CollectEnums(decls []ast.Decl, idx int, acc []EnumInfo) []EnumInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    variants := ast.DeclEnumVariants(decl)
    if len(variants) > 0 {
        return CollectEnums(
            decls,
            idx + 1,
            append(acc, EnumInfo{
                Name: ast.DeclName(decl),
                Variants: VariantNames(variants, 0),
            }),
        )
    }
    return CollectEnums(decls, idx + 1, acc)
}

func CollectStructs(decls []ast.Decl, idx int, acc []StructInfo) []StructInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    fields := ast.DeclStructFields(decl)
    if len(fields) > 0 {
        return CollectStructs(
            decls,
            idx + 1,
            append(acc, StructInfo{
                Name: ast.DeclName(decl),
                Fields: StructFieldInfos(fields, 0, []FieldTypeInfo{}),
            }),
        )
    }
    return CollectStructs(decls, idx + 1, acc)
}

func StructFieldInfos(fields []ast.FieldDef, idx int, acc []FieldTypeInfo) []FieldTypeInfo {
    if idx >= len(fields) {
        return acc
    }
    return StructFieldInfos(fields, idx + 1, append(acc, FieldTypeInfo{
        Name: ast.FieldName(fields[idx]),
        TypeName: TypeExprName(ast.FieldType(fields[idx])),
    }))
}

func CollectInterfaces(decls []ast.Decl, idx int, acc []InterfaceInfo) []InterfaceInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    methods := ast.DeclInterfaceMethods(decl)
    if len(methods) > 0 {
        return CollectInterfaces(
            decls,
            idx + 1,
            append(acc, InterfaceInfo{
                Name: ast.DeclName(decl),
                Methods: InterfaceMethodInfos(methods, 0, []FuncInfo{}),
            }),
        )
    }
    return CollectInterfaces(decls, idx + 1, acc)
}

func InterfaceMethodInfos(methods []ast.MethodSig, idx int, acc []FuncInfo) []FuncInfo {
    if idx >= len(methods) {
        return acc
    }
    return InterfaceMethodInfos(methods, idx + 1, append(acc, FuncInfo{
        Name: ast.MethodSigName(methods[idx]),
        TypeParams: []string{},
        ParamNames: FieldNames(ast.MethodSigParams(methods[idx]), 0, []string{}),
        ParamTypes: FieldTypes(ast.MethodSigParams(methods[idx]), 0, []string{}),
        ResultTypes: TypeNames(ast.MethodSigResults(methods[idx]), 0, []string{}),
    }))
}

func CollectFuncs(decls []ast.Decl, idx int, acc []FuncInfo) []FuncInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    if ast.DeclIsFuncDecl(decl) {
        if !ast.DeclHasReceiver(decl) {
            return CollectFuncs(
                decls,
                idx + 1,
                append(acc, FuncInfo{
                    Name: ast.DeclName(decl),
                    TypeParams: TypeParamNames(ast.DeclTypeParams(decl), 0, []string{}),
                    ParamNames: FieldNames(ast.DeclParams(decl), 0, []string{}),
                    ParamTypes: FieldTypes(ast.DeclParams(decl), 0, []string{}),
                    ResultTypes: TypeNames(ast.DeclResults(decl), 0, []string{}),
                }),
            )
        }
    }
    return CollectFuncs(decls, idx + 1, acc)
}

func CollectMethods(decls []ast.Decl, idx int, acc []MethodInfo) []MethodInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    if ast.DeclIsFuncDecl(decl) {
        if ast.DeclHasReceiver(decl) {
            return CollectMethods(
                decls,
                idx + 1,
                append(acc, MethodInfo{
                    ReceiverType: TypeExprName(ast.FieldType(ast.DeclReceiverField(decl))),
                    Name: ast.DeclName(decl),
                    ParamNames: FieldNames(ast.DeclParams(decl), 0, []string{}),
                    ParamTypes: FieldTypes(ast.DeclParams(decl), 0, []string{}),
                    ResultTypes: TypeNames(ast.DeclResults(decl), 0, []string{}),
                }),
            )
        }
    }
    return CollectMethods(decls, idx + 1, acc)
}

func CollectConstructors(decls []ast.Decl, idx int, acc []FuncInfo) []FuncInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    variants := ast.DeclEnumVariants(decl)
    if len(variants) > 0 {
        typeParams := TypeParamNames(ast.DeclTypeParams(decl), 0, []string{})
        enumType := GenericNamedTypeFromParams(ast.DeclName(decl), typeParams)
        return CollectConstructors(
            decls,
            idx + 1,
            ConcatFuncInfos(acc, ConstructorInfos(enumType, typeParams, variants, 0, []FuncInfo{})),
        )
    }
    return CollectConstructors(decls, idx + 1, acc)
}

func TypeParamNames(items []ast.TypeParam, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return TypeParamNames(items, idx + 1, append(acc, ast.TypeParamName(items[idx])))
}

func GenericNamedTypeFromParams(name string, params []string) string {
    if len(params) == 0 {
        return name
    }
    return name + "[" + JoinStrings(params, 0) + "]"
}

func ConstructorInfos(enumType string, typeParams []string, variants []ast.Variant, idx int, acc []FuncInfo) []FuncInfo {
    if idx >= len(variants) {
        return acc
    }
    info := FuncInfo{
        Name: ast.VariantName(variants[idx]),
        TypeParams: typeParams,
        ParamNames: []string{},
        ParamTypes: TypeNames(ast.VariantFields(variants[idx]), 0, []string{}),
        ResultTypes: []string{enumType},
    }
    return ConstructorInfos(enumType, typeParams, variants, idx + 1, append(acc, info))
}

func ConcatFuncInfos(left []FuncInfo, right []FuncInfo) []FuncInfo {
    return ConcatFuncInfosLoop(left, right, 0)
}

func ConcatFuncInfosLoop(left []FuncInfo, right []FuncInfo, idx int) []FuncInfo {
    if idx >= len(right) {
        return left
    }
    return ConcatFuncInfosLoop(append(left, right[idx]), right, idx + 1)
}

func FieldTypes(fields []ast.FieldDef, idx int, acc []string) []string {
    if idx >= len(fields) {
        return acc
    }
    return FieldTypes(fields, idx + 1, append(acc, TypeExprName(ast.FieldType(fields[idx]))))
}

func FieldNames(fields []ast.FieldDef, idx int, acc []string) []string {
    if idx >= len(fields) {
        return acc
    }
    return FieldNames(fields, idx + 1, append(acc, ast.FieldName(fields[idx])))
}

func TypeNames(items []ast.TypeExpr, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return TypeNames(items, idx + 1, append(acc, TypeExprName(items[idx])))
}

func VariantNames(items []ast.Variant, idx int) []string {
    if idx >= len(items) {
        return []string{}
    }
    return VariantNamesAcc(items, idx, []string{})
}

func VariantNamesAcc(items []ast.Variant, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return VariantNamesAcc(items, idx + 1, append(acc, ast.VariantName(items[idx])))
}

func CheckDecls(decls []ast.Decl, seen []NameEntry, imports []NameEntry, importTypes []TypeEntry, diag diagnostic.Diagnostics, externs []string, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if len(decls) == 0 {
        return diag
    }

    current := decls[0]
    nextDiag := CheckDecl(current, seen, imports, importTypes, diag, externs, enums, structs, interfaces, funcs, methods)
    nextSeen := ExtendSeen(current, seen)
    return CheckDecls(decls[1:], nextSeen, imports, importTypes, nextDiag, externs, enums, structs, interfaces, funcs, methods)
}

func CheckDecl(decl ast.Decl, seen []NameEntry, imports []NameEntry, importTypes []TypeEntry, diag diagnostic.Diagnostics, externs []string, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if ast.DeclIsFuncDecl(decl) {
        return CheckFuncDecl(decl, seen, imports, importTypes, diag, externs, enums, structs, interfaces, funcs, methods)
    }
    if ast.DeclIsTypeDecl(decl) {
        return CheckTypeDecl(decl, seen, diag)
    }
    return diag
}

func CheckFuncDecl(decl ast.Decl, seen []NameEntry, imports []NameEntry, importTypes []TypeEntry, diag diagnostic.Diagnostics, externs []string, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    headerDiag := CheckFuncDeclHeader(decl, seen, diag)
    paramState := CheckFieldDefs(ast.DeclParams(decl), []NameEntry{}, "parameter", headerDiag)
    return CheckFuncDeclBody(decl, paramState, imports, importTypes, externs, enums, structs, interfaces, funcs, methods)
}

func CheckFuncDeclHeader(decl ast.Decl, seen []NameEntry, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    if ast.DeclIsTopLevelFunc(decl) {
        name := ast.DeclName(decl)
        pos := ast.DeclPos(decl)
        initDiag := CheckInitName(name, pos, diag)
        namedDiag := CheckDuplicateName(name, "func", pos, seen, initDiag)
        return CheckVariadicParams(ast.DeclParams(decl), 0, namedDiag)
    }
    return CheckVariadicParams(ast.DeclParams(decl), 0, diag)
}

func CheckFuncDeclBody(decl ast.Decl, paramState DuplicateState, imports []NameEntry, importTypes []TypeEntry, externs []string, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    typeEnv := ParamTypeEnv(ast.DeclParams(decl), 0, []TypeEntry{})
    if ast.DeclHasReceiver(decl) {
        receiver := ast.DeclReceiverField(decl)
        recvState := RegisterName(
            ast.FieldName(receiver),
            "receiver",
            receiver.Pos,
            paramState.Seen,
            paramState.Seen,
            paramState.Diag,
        )
        recvEnv := append(typeEnv, TypeEntry{
            Name: ast.FieldName(receiver),
            TypeName: TypeExprName(ast.FieldType(receiver)),
        })
        fullEnv := ConcatTypeEntries(recvEnv, importTypes, 0)
        if ast.DeclIsExtern(decl) {
            return recvState.Diag
        }
        importVisible := ConcatNameEntries(imports, recvState.Visible, 0)
        bodyDiag := CheckBlock(ast.DeclBodyBlock(decl), recvState.Visible, importVisible, recvState.Diag, externs)
        return CheckSemanticBlock(ast.DeclBodyBlock(decl), ast.DeclResults(decl), bodyDiag, fullEnv, enums, structs, interfaces, funcs, methods)
    }
    if ast.DeclIsExtern(decl) {
        return paramState.Diag
    }
    fullEnv := ConcatTypeEntries(typeEnv, importTypes, 0)
    importVisible := ConcatNameEntries(imports, paramState.Seen, 0)
    bodyDiag := CheckBlock(ast.DeclBodyBlock(decl), paramState.Seen, importVisible, paramState.Diag, externs)
    return CheckSemanticBlock(ast.DeclBodyBlock(decl), ast.DeclResults(decl), bodyDiag, fullEnv, enums, structs, interfaces, funcs, methods)
}

func ConcatNameEntries(left []NameEntry, right []NameEntry, idx int) []NameEntry {
    if idx >= len(right) {
        return left
    }
    return ConcatNameEntries(append(left, right[idx]), right, idx + 1)
}

func ConcatTypeEntries(left []TypeEntry, right []TypeEntry, idx int) []TypeEntry {
    if idx >= len(right) {
        return left
    }
    return ConcatTypeEntries(append(left, right[idx]), right, idx + 1)
}

func ParamTypeEnv(fields []ast.FieldDef, idx int, acc []TypeEntry) []TypeEntry {
    if idx >= len(fields) {
        return acc
    }
    return ParamTypeEnv(fields, idx + 1, append(acc, TypeEntry{
        Name: ast.FieldName(fields[idx]),
        TypeName: TypeExprName(ast.FieldType(fields[idx])),
    }))
}

func CheckTypeDecl(decl ast.Decl, seen []NameEntry, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    name := ast.DeclName(decl)
    pos := ast.DeclPos(decl)
    next := CheckDuplicateName(name, "type", pos, seen, diag)

    fields := ast.DeclStructFields(decl)
    if len(fields) > 0 {
        return CheckFieldDefs(fields, []NameEntry{}, "field", next).Diag
    }

    variants := ast.DeclEnumVariants(decl)
    if len(variants) > 0 {
        return CheckVariants(variants, []NameEntry{}, next).Diag
    }

    methods := ast.DeclInterfaceMethods(decl)
    if len(methods) > 0 {
        return CheckMethods(methods, []NameEntry{}, next).Diag
    }

    return next
}

func CheckFieldDefs(fields []ast.FieldDef, seen []NameEntry, kind string, diag diagnostic.Diagnostics) DuplicateState {
    if len(fields) == 0 {
        return DuplicateState{
            Diag: diag,
            Seen: seen,
        }
    }

    field := fields[0]
    state := CheckDuplicateLocalName(ast.FieldName(field), kind, field.Pos, seen, diag)
    return CheckFieldDefs(fields[1:], state.Seen, kind, state.Diag)
}

type DuplicateState struct {
    Diag diagnostic.Diagnostics
    Seen []NameEntry
}

func CheckVariants(items []ast.Variant, seen []NameEntry, diag diagnostic.Diagnostics) DuplicateState {
    if len(items) == 0 {
        return DuplicateState{
            Diag: diag,
            Seen: seen,
        }
    }
    item := items[0]
    state := CheckDuplicateLocalName(ast.VariantName(item), "variant", item.Pos, seen, diag)
    return CheckVariants(items[1:], state.Seen, state.Diag)
}

func CheckMethods(items []ast.MethodSig, seen []NameEntry, diag diagnostic.Diagnostics) DuplicateState {
    if len(items) == 0 {
        return DuplicateState{
            Diag: diag,
            Seen: seen,
        }
    }
    item := items[0]
    state := CheckDuplicateLocalName(ast.MethodSigName(item), "method", item.Pos, seen, CheckVariadicParams(ast.MethodSigParams(item), 0, diag))
    return CheckMethods(items[1:], state.Seen, state.Diag)
}

func CheckVariadicParams(fields []ast.FieldDef, idx int, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    if ast.FieldIsVariadic(fields[idx]) {
        if idx + 1 < len(fields) {
            return CheckVariadicParams(
                fields,
                idx + 1,
                diag.Error(
                    diagnostic.SyntaxCategory(),
                    fields[idx].Pos,
                    "variadic parameter must be the final parameter",
                ),
            )
        }
    }
    return CheckVariadicParams(fields, idx + 1, diag)
}

func CheckDuplicateLocalName(name string, kind string, pos token.Pos, seen []NameEntry, diag diagnostic.Diagnostics) DuplicateState {
    prev := FindNameEntry(seen, name)
    if !isNone[NameEntry](prev) {
        item := unwrapOr[NameEntry](prev, EmptyNameEntry())
        return DuplicateState{
            Diag: diag.ErrorRelated(
                diagnostic.TypeErrorCategory(),
                pos,
                "FTYPE001",
                "duplicate "+kind+" declaration: "+name,
                "This declaration conflicts with an earlier " + EntryLabel(item) + ".",
                "Rename one of the declarations so each local name is introduced only once in the same scope.",
                item.Pos,
                "previous " + EntryLabel(item) + " declared here",
            ),
            Seen: seen,
        }
    }
    return DuplicateState{
        Diag: diag,
        Seen: append(seen, NameEntry{
            Name: name,
            Kind: kind,
            Pos: pos,
        }),
    }
}

func CheckInitName(name string, pos token.Pos, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    if name == "init" {
        return diag.ErrorWithHint(
            diagnostic.SyntaxCategory(),
            pos,
            "`init()` is not allowed in Fo",
            "Use explicit entrypoints and bridge layers instead of package initialization side effects.",
        )
    }
    return diag
}

func CheckDuplicateName(name string, kind string, pos token.Pos, seen []NameEntry, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    prev := FindNameEntry(seen, name)
    if !isNone[NameEntry](prev) {
        item := unwrapOr[NameEntry](prev, EmptyNameEntry())
        return diag.ErrorRelated(
            diagnostic.TypeErrorCategory(),
            pos,
            "FTYPE002",
            "duplicate "+kind+" declaration: "+name,
            "Top-level declarations share one namespace per package.",
            "Rename the declaration or remove the earlier one.",
            item.Pos,
            "previous " + EntryLabel(item) + " declared here",
        )
    }
    return diag
}

func CheckBlock(block ast.BlockStmt, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    return CheckStatements(ast.BlockStatements(block), local, visible, diag, externs)
}

func CheckStatements(stmts []ast.Stmt, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if len(stmts) == 0 {
        return diag
    }

    stmt := stmts[0]
    if ast.StmtIsBind(stmt) {
        nextDiag := CheckExpr(ast.StmtBindValue(stmt), visible, diag, externs)
        state := RegisterNames(ast.StmtBindNames(stmt), "binding", stmt.TokenPos(), local, visible, nextDiag)
        return CheckStatements(stmts[1:], state.Local, state.Visible, state.Diag, externs)
    }

    nextDiag := CheckStmt(stmt, visible, diag, externs)
    return CheckStatements(stmts[1:], local, visible, nextDiag, externs)
}

func CheckStmt(stmt ast.Stmt, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if ast.StmtIsReturn(stmt) {
        return CheckExprs(ast.StmtReturnResults(stmt), 0, visible, diag, externs)
    }
    if ast.StmtIsIf(stmt) {
        next := CheckExpr(ast.StmtIfCond(stmt), visible, diag, externs)
        return CheckBlock(ast.StmtIfBody(stmt), []NameEntry{}, visible, next, externs)
    }
    if ast.StmtIsSwitch(stmt) {
        tagDiag := CheckSwitchTag(stmt, visible, diag, externs)
        return CheckSwitchCases(ast.StmtSwitchCases(stmt), 0, visible, tagDiag, externs)
    }
    if ast.StmtIsMatch(stmt) {
        next := CheckExpr(ast.StmtMatchTag(stmt), visible, diag, externs)
        return CheckMatchCases(ast.StmtMatchCases(stmt), 0, visible, next, externs)
    }
    if ast.StmtIsDiscard(stmt) {
        return CheckExpr(ast.StmtDiscardValue(stmt), visible, diag, externs)
    }
    if ast.StmtIsExpr(stmt) {
        return CheckExpr(ast.StmtExprValue(stmt), visible, diag, externs)
    }
    return diag
}

func CheckSwitchTag(stmt ast.Stmt, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if ast.ExprOptionIsNone(ast.StmtSwitchTag(stmt)) {
        return diag
    }
    return CheckExpr(ast.ExprOptionValue(ast.StmtSwitchTag(stmt)), visible, diag, externs)
}

func CheckSwitchCases(cases []ast.CaseClause, idx int, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if idx >= len(cases) {
        return diag
    }
    exprDiag := CheckExprs(ast.SwitchCaseExprs(cases[idx]), 0, visible, diag, externs)
    bodyDiag := CheckStatements(ast.SwitchCaseBody(cases[idx]), []NameEntry{}, visible, exprDiag, externs)
    return CheckSwitchCases(cases, idx + 1, visible, bodyDiag, externs)
}

func CheckMatchCases(cases []ast.MatchCase, idx int, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if idx >= len(cases) {
        return diag
    }
    state := RegisterPattern(ast.MatchCasePattern(cases[idx]), []NameEntry{}, visible, diag)
    next := CheckStatements(ast.MatchCaseBody(cases[idx]), state.Local, state.Visible, state.Diag, externs)
    return CheckMatchCases(cases, idx + 1, visible, next, externs)
}

func RegisterPattern(pattern ast.Pattern, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if ast.PatternIsWildcard(pattern) {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    if ast.PatternIsIdent(pattern) {
        return RegisterNames([]string{ast.PatternIdentName(pattern)}, "pattern", pattern.TokenPos(), local, visible, diag)
    }
    if ast.PatternIsEnum(pattern) {
        return RegisterPatterns(ast.PatternEnumSubPats(pattern), 0, local, visible, diag)
    }
    if ast.PatternIsStruct(pattern) {
        return RegisterFieldPatterns(ast.PatternStructFields(pattern), 0, local, visible, diag)
    }
    return BindingState{
        Diag: diag,
        Local: local,
        Visible: visible,
    }
}

func RegisterPatterns(patterns []ast.Pattern, idx int, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if idx >= len(patterns) {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    state := RegisterPattern(patterns[idx], local, visible, diag)
    return RegisterPatterns(patterns, idx + 1, state.Local, state.Visible, state.Diag)
}

func RegisterFieldPatterns(fields []ast.FieldPattern, idx int, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if idx >= len(fields) {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    state := RegisterPattern(ast.FieldPatternPatternValue(fields[idx]), local, visible, diag)
    return RegisterFieldPatterns(fields, idx + 1, state.Local, state.Visible, state.Diag)
}

func RegisterNames(names []string, kind string, pos token.Pos, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if len(names) == 0 {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    state := RegisterName(names[0], kind, pos, local, visible, diag)
    return RegisterNames(names[1:], kind, pos, state.Local, state.Visible, state.Diag)
}

func RegisterName(name string, kind string, pos token.Pos, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if IsBlankIdentifier(name) {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    prev := FindNameEntry(local, name)
    if !isNone[NameEntry](prev) {
        item := unwrapOr[NameEntry](prev, EmptyNameEntry())
        return BindingState{
            Diag: diag.ErrorRelated(
                diagnostic.ImmutabilityCategory(),
                pos,
                "FIMM001",
                "reassignment is not allowed in Fo: "+name,
                "Bindings in Fo are immutable once introduced in the same block scope.",
                "Introduce a new name instead of reusing '" + name + "'.",
                item.Pos,
                "original " + EntryLabel(item) + " declared here",
            ),
            Local: local,
            Visible: visible,
        }
    }
    return RegisterNameWithShadow(name, kind, pos, local, visible, diag)
}

func RegisterNameWithShadow(name string, kind string, pos token.Pos, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    entry := NameEntry{
        Name: name,
        Kind: kind,
        Pos: pos,
    }
    return BindingState{
        Diag: ShadowDiag(name, pos, visible, diag),
        Local: append(local, entry),
        Visible: append(visible, entry),
    }
}

func ShadowDiag(name string, pos token.Pos, visible []NameEntry, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    prev := FindNameEntry(visible, name)
    if !isNone[NameEntry](prev) {
        item := unwrapOr[NameEntry](prev, EmptyNameEntry())
        return diag.WarningRelated(
            diagnostic.TypeErrorCategory(),
            pos,
            "FTYPE010",
            "shadowing "+item.Kind+" declaration: "+name,
            "The new binding hides an earlier visible declaration with the same name.",
            "Shadowing is legal here, but it usually reduces readability.",
            item.Pos,
            "shadowed " + EntryLabel(item) + " declared here",
        )
    }
    return diag
}

func CheckExprs(exprs []ast.Expr, idx int, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if idx >= len(exprs) {
        return diag
    }
    next := CheckExpr(exprs[idx], visible, diag, externs)
    return CheckExprs(exprs, idx + 1, visible, next, externs)
}

func CheckExpr(expr ast.Expr, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if ast.ExprIsIdent(expr) {
        name := ast.ExprIdentName(expr)
        if IsBuiltinName(name) {
            return diag
        }
        if LooksLikeEnumSymbol(name) {
            return diag
        }
        if !isNone[NameEntry](FindLastNameEntry(visible, name)) {
            return diag
        }
        candidates := VisibleNames(visible, 0, []string{})
        suggestion := SuggestName(name, candidates, 0, "", 0)
        if !IsTypoLikeSuggestion(name, suggestion) {
            return diag
        }
        return diag.ErrorRelatedSuggested(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE011",
            "unknown name "+name,
            "This identifier is not bound in the current scope.",
            MaybeSuggestionText(suggestion),
            UnknownNameHint(visible),
            SuggestedRelatedPos(visible, suggestion),
            SuggestedRelatedMessage(visible, suggestion),
        )
    }
    if ast.ExprIsCall(expr) {
        next := CheckCallExpr(expr, visible, diag, externs)
        return CheckExprs(ast.ExprCallArgs(expr), 0, visible, next, externs)
    }
    if ast.ExprIsMake(expr) {
        return CheckExprs(ast.ExprMakeArgs(expr), 0, visible, diag, externs)
    }
    if ast.ExprIsBinary(expr) {
        next := CheckExpr(ast.ExprBinaryLeft(expr), visible, diag, externs)
        return CheckExpr(ast.ExprBinaryRight(expr), visible, next, externs)
    }
    if ast.ExprIsUnary(expr) {
        return CheckExpr(ast.ExprUnaryOperand(expr), visible, diag, externs)
    }
    if ast.ExprIsPipeline(expr) {
        next := CheckExpr(ast.ExprPipelineLeft(expr), visible, diag, externs)
        return CheckExpr(ast.ExprPipelineRight(expr), visible, next, externs)
    }
    if ast.ExprIsSelector(expr) {
        return CheckExpr(ast.ExprSelectorTarget(expr), visible, diag, externs)
    }
    if ast.ExprIsIndex(expr) {
        next := CheckExpr(ast.ExprIndexTarget(expr), visible, diag, externs)
        return CheckExpr(ast.ExprIndexValue(expr), visible, next, externs)
    }
    if ast.ExprIsSlice(expr) {
        targetDiag := CheckExpr(ast.ExprSliceTarget(expr), visible, diag, externs)
        lowDiag := CheckOptionalExpr(ast.ExprSliceLow(expr), visible, targetDiag, externs)
        return CheckOptionalExpr(ast.ExprSliceHigh(expr), visible, lowDiag, externs)
    }
    if ast.ExprIsStructLit(expr) {
        return CheckFieldInitExprs(ast.ExprStructLitFields(expr), 0, visible, diag, externs)
    }
    if ast.ExprIsCopyUpdate(expr) {
        next := CheckExpr(ast.ExprCopyUpdateSource(expr), visible, diag, externs)
        return CheckFieldUpdateExprs(ast.ExprCopyUpdateUpdates(expr), 0, visible, next, externs)
    }
    if ast.ExprIsSliceLit(expr) {
        return CheckExprs(ast.ExprSliceLitElems(expr), 0, visible, diag, externs)
    }
    if ast.ExprIsFuncLit(expr) {
        return CheckFuncLitExpr(expr, visible, diag, externs)
    }
    return diag
}

func CheckFuncLitExpr(expr ast.Expr, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    params := ast.ExprFuncLitParams(expr)
    paramDiag := CheckFieldDefs(params, []NameEntry{}, "parameter", diag).Diag
    bindings := RegisterFuncLitParams(params, 0, []NameEntry{}, visible, paramDiag)
    return CheckBlock(ast.ExprFuncLitBody(expr), bindings.Local, bindings.Visible, bindings.Diag, externs)
}

func RegisterFuncLitParams(fields []ast.FieldDef, idx int, local []NameEntry, visible []NameEntry, diag diagnostic.Diagnostics) BindingState {
    if idx >= len(fields) {
        return BindingState{
            Diag: diag,
            Local: local,
            Visible: visible,
        }
    }
    state := RegisterName(ast.FieldName(fields[idx]), "parameter", fields[idx].Pos, local, visible, diag)
    return RegisterFuncLitParams(fields, idx + 1, state.Local, state.Visible, state.Diag)
}

func CheckSemanticBlock(block ast.BlockStmt, results []ast.TypeExpr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    return CheckSemanticStatements(ast.BlockStatements(block), 0, results, diag, env, enums, structs, interfaces, funcs, methods)
}

func CheckSemanticStatements(stmts []ast.Stmt, idx int, results []ast.TypeExpr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(stmts) {
        return diag
    }
    stmt := stmts[idx]
    next := CheckSemanticStmt(stmt, results, diag, env, enums, structs, interfaces, funcs, methods)
    nextEnv := SemanticEnvAfterStmt(stmt, env, enums, structs, funcs, methods)
    return CheckSemanticStatements(stmts, idx + 1, results, next, nextEnv, enums, structs, interfaces, funcs, methods)
}

func CheckSemanticStmt(stmt ast.Stmt, results []ast.TypeExpr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if ast.StmtIsReturn(stmt) {
        callDiag := CheckSemanticExprs(ast.StmtReturnResults(stmt), 0, diag, env, enums, structs, interfaces, funcs, methods)
        return CheckReturnShape(ast.StmtReturnResults(stmt), results, stmt.TokenPos(), callDiag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsIf(stmt) {
        exprDiag := CheckSemanticExpr(ast.StmtIfCond(stmt), diag, env, enums, structs, interfaces, funcs, methods)
        condDiag := CheckConditionShape(ast.StmtIfCond(stmt), stmt.TokenPos(), exprDiag)
        return CheckSemanticBlock(ast.StmtIfBody(stmt), results, condDiag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsSwitch(stmt) {
        return CheckSemanticSwitchCases(ast.StmtSwitchCases(stmt), 0, results, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsMatch(stmt) {
        matchType := InferMatchTagType(ast.StmtMatchTag(stmt), env, enums)
        patternDiag := CheckMatchPatternTypes(ast.StmtMatchCases(stmt), 0, matchType, diag, enums, structs, funcs)
        matchDiag := CheckMatchExhaustiveness(stmt, env, enums, patternDiag)
        return CheckSemanticMatchCases(ast.StmtMatchCases(stmt), 0, results, matchDiag, env, matchType, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsBind(stmt) {
        return CheckSemanticExpr(ast.StmtBindValue(stmt), diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsDiscard(stmt) {
        return CheckSemanticExpr(ast.StmtDiscardValue(stmt), diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.StmtIsExpr(stmt) {
        return CheckSemanticExpr(ast.StmtExprValue(stmt), diag, env, enums, structs, interfaces, funcs, methods)
    }
    return diag
}

func CheckMatchPatternTypes(cases []ast.MatchCase, idx int, matchType string, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    if idx >= len(cases) {
        return diag
    }
    next := CheckPatternType(ast.MatchCasePattern(cases[idx]), matchType, cases[idx].Pos, diag, enums, structs, funcs)
    return CheckMatchPatternTypes(cases, idx + 1, matchType, next, enums, structs, funcs)
}

func CheckPatternType(pattern ast.Pattern, expectedType string, pos token.Pos, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    if expectedType == "" {
        return diag
    }
    if ast.PatternIsWildcard(pattern) || ast.PatternIsIdent(pattern) {
        return diag
    }
    if ast.PatternIsLit(pattern) {
        return CheckLitPatternType(pattern, expectedType, pos, diag)
    }
    if ast.PatternIsTuple(pattern) {
        return CheckTuplePatternType(pattern, expectedType, pos, diag, enums, structs, funcs)
    }
    if ast.PatternIsEnum(pattern) {
        if !IsKnownEnumType(expectedType, enums) {
            return diag
        }
        return CheckEnumPatternType(pattern, expectedType, pos, diag, enums, structs, funcs)
    }
    if ast.PatternIsStruct(pattern) {
        if !IsKnownStructType(expectedType, structs) {
            return diag
        }
        return CheckStructPatternType(pattern, expectedType, pos, diag, enums, structs, funcs)
    }
    return diag
}

func CheckLitPatternType(pattern ast.Pattern, expectedType string, pos token.Pos, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    got := BasicLitTypeName(ast.PatternLitKind(pattern), ast.PatternLitValue(pattern))
    if got == "" {
        return diag
    }
    if got == expectedType {
        return diag
    }
    return diag.Error(
        diagnostic.TypeErrorCategory(),
        pos,
        "pattern type mismatch: expected "+expectedType+", got "+got,
    )
}

func CheckTuplePatternType(pattern ast.Pattern, expectedType string, pos token.Pos, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    expected := ParseTupleTypeNames(expectedType)
    if len(expected) == 0 {
        return diag
    }
    elems := ast.PatternTupleElems(pattern)
    if len(elems) == len(expected) {
        return CheckPatternTypes(elems, expected, 0, diag, enums, structs, funcs)
    }
    return diag.Error(
        diagnostic.TypeErrorCategory(),
        pos,
        "tuple pattern arity mismatch: expected "+IntString(len(expected))+", got "+IntString(len(elems)),
    )
}

func IsKnownEnumType(name string, enums []EnumInfo) bool {
    info := FindEnumInfo(enums, name)
    if !isNone[EnumInfo](info) {
        return true
    }
    return false
}

func IsKnownStructType(name string, structs []StructInfo) bool {
    normalized := NormalizeStructLikeType(name)
    info := FindStructInfo(structs, normalized)
    if !isNone[StructInfo](info) {
        return true
    }
    if LiveAnyHasStructType(normalized) {
        return true
    }
    if len(StdlibStructFieldNames(normalized)) > 0 {
        return true
    }
    return false
}

func CheckEnumPatternType(pattern ast.Pattern, expectedType string, pos token.Pos, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    name := ast.PatternEnumName(pattern)
    info := FindEnumConstructor(funcs, expectedType, name)
    if !isNone[FuncInfo](info) {
        item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
        subPats := ast.PatternEnumSubPats(pattern)
        if len(subPats) == len(item.ParamTypes) {
            return CheckPatternTypes(subPats, item.ParamTypes, 0, diag, enums, structs, funcs)
        }
        return diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            pos,
            "FTYPE020",
            "pattern arity mismatch for "+name+": expected "+IntString(len(item.ParamTypes))+", got "+IntString(len(subPats)),
            "Constructor signature is " + CallSignatureDetail(item) + ".",
            "Adjust the number of nested subpatterns to match the constructor payload arity.",
        )
    }
    return diag.ErrorDetailedSuggested(
        diagnostic.TypeErrorCategory(),
        pos,
        "FTYPE021",
        "pattern variant "+name+" does not belong to "+expectedType,
        "The matched value has enum type " + expectedType + ", but the pattern names a constructor from a different enum or an unknown constructor.",
        MaybeSuggestionText(SuggestName(name, unwrapOr[EnumInfo](FindEnumInfo(enums, expectedType), EmptyEnumInfo()).Variants, 0, "", 0)),
        EnumVariantHint(expectedType, enums),
    )
}

func CheckPatternTypes(patterns []ast.Pattern, expected []string, idx int, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    if idx >= len(patterns) {
        return diag
    }
    next := CheckPatternType(patterns[idx], expected[idx], patterns[idx].TokenPos(), diag, enums, structs, funcs)
    return CheckPatternTypes(patterns, expected, idx + 1, next, enums, structs, funcs)
}

func CheckStructPatternType(pattern ast.Pattern, expectedType string, pos token.Pos, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    if ast.PatternStructType(pattern) == expectedType {
        return CheckStructPatternFields(ast.PatternStructFields(pattern), expectedType, 0, diag, enums, structs, funcs)
    }
    return diag.Error(
        diagnostic.TypeErrorCategory(),
        pos,
        "pattern type mismatch: expected "+expectedType+", got "+ast.PatternStructType(pattern),
    )
}

func CheckStructPatternFields(fields []ast.FieldPattern, structType string, idx int, diag diagnostic.Diagnostics, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    name := ast.FieldPatternNameValue(fields[idx])
    fieldType := FieldTypeForStruct(structType, name, structs)
    if fieldType == "" {
        return CheckStructPatternFields(
            fields,
            structType,
            idx + 1,
            diag.ErrorDetailedSuggested(
                diagnostic.TypeErrorCategory(),
                ast.FieldPatternPatternValue(fields[idx]).TokenPos(),
                "FTYPE030",
                "unknown field "+name+" on "+structType,
                "The struct pattern mentions a field that does not exist on the matched struct type.",
                MaybeSuggestionText(SuggestName(name, StructFieldNames(structType, structs), 0, "", 0)),
                StructFieldHint(structType, structs),
            ),
            enums,
            structs,
            funcs,
        )
    }
    next := CheckPatternType(ast.FieldPatternPatternValue(fields[idx]), fieldType, ast.FieldPatternPatternValue(fields[idx]).TokenPos(), diag, enums, structs, funcs)
    return CheckStructPatternFields(fields, structType, idx + 1, next, enums, structs, funcs)
}

func ExtendTypeEnvWithPattern(pattern ast.Pattern, expectedType string, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) []TypeEntry {
    if expectedType == "" {
        return env
    }
    if ast.PatternIsWildcard(pattern) || ast.PatternIsLit(pattern) {
        return env
    }
    if ast.PatternIsIdent(pattern) {
        return append(env, TypeEntry{
            Name: ast.PatternIdentName(pattern),
            TypeName: expectedType,
        })
    }
    if ast.PatternIsTuple(pattern) {
        return ExtendTypeEnvWithTuplePattern(ast.PatternTupleElems(pattern), ParseTupleTypeNames(expectedType), 0, env, enums, structs, funcs)
    }
    if ast.PatternIsEnum(pattern) {
        info := FindEnumConstructor(funcs, expectedType, ast.PatternEnumName(pattern))
        if isNone[FuncInfo](info) {
            return env
        }
        item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
        return ExtendTypeEnvWithPatterns(ast.PatternEnumSubPats(pattern), item.ParamTypes, 0, env, enums, structs, funcs)
    }
    if ast.PatternIsStruct(pattern) {
        return ExtendTypeEnvWithStructPattern(ast.PatternStructFields(pattern), expectedType, 0, env, enums, structs, funcs)
    }
    return env
}

func ExtendTypeEnvWithPatterns(patterns []ast.Pattern, expected []string, idx int, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) []TypeEntry {
    if idx >= len(patterns) {
        return env
    }
    if idx >= len(expected) {
        return env
    }
    next := ExtendTypeEnvWithPattern(patterns[idx], expected[idx], env, enums, structs, funcs)
    return ExtendTypeEnvWithPatterns(patterns, expected, idx + 1, next, enums, structs, funcs)
}

func ExtendTypeEnvWithTuplePattern(patterns []ast.Pattern, expected []string, idx int, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) []TypeEntry {
    if idx >= len(patterns) {
        return env
    }
    if idx >= len(expected) {
        return env
    }
    next := ExtendTypeEnvWithPattern(patterns[idx], expected[idx], env, enums, structs, funcs)
    return ExtendTypeEnvWithTuplePattern(patterns, expected, idx + 1, next, enums, structs, funcs)
}

func ExtendTypeEnvWithStructPattern(fields []ast.FieldPattern, structType string, idx int, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo) []TypeEntry {
    if idx >= len(fields) {
        return env
    }
    name := ast.FieldPatternNameValue(fields[idx])
    fieldType := FieldTypeForStruct(structType, name, structs)
    if fieldType == "" {
        return ExtendTypeEnvWithStructPattern(fields, structType, idx + 1, env, enums, structs, funcs)
    }
    next := ExtendTypeEnvWithPattern(ast.FieldPatternPatternValue(fields[idx]), fieldType, env, enums, structs, funcs)
    return ExtendTypeEnvWithStructPattern(fields, structType, idx + 1, next, enums, structs, funcs)
}

func CheckSemanticSwitchCases(cases []ast.CaseClause, idx int, results []ast.TypeExpr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(cases) {
        return diag
    }
    exprDiag := CheckSemanticExprs(ast.SwitchCaseExprs(cases[idx]), 0, diag, env, enums, structs, interfaces, funcs, methods)
    next := CheckSemanticStatements(ast.SwitchCaseBody(cases[idx]), 0, results, exprDiag, env, enums, structs, interfaces, funcs, methods)
    return CheckSemanticSwitchCases(cases, idx + 1, results, next, env, enums, structs, interfaces, funcs, methods)
}

func CheckSemanticMatchCases(cases []ast.MatchCase, idx int, results []ast.TypeExpr, diag diagnostic.Diagnostics, env []TypeEntry, matchType string, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(cases) {
        return diag
    }
    caseEnv := ExtendTypeEnvWithPattern(ast.MatchCasePattern(cases[idx]), matchType, env, enums, structs, funcs)
    next := CheckSemanticStatements(ast.MatchCaseBody(cases[idx]), 0, results, diag, caseEnv, enums, structs, interfaces, funcs, methods)
    return CheckSemanticMatchCases(cases, idx + 1, results, next, env, matchType, enums, structs, interfaces, funcs, methods)
}

func CheckConditionShape(expr ast.Expr, pos token.Pos, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    got := InferExprTypeName(expr)
    if got == "" {
        return diag
    }
    if got == "bool" {
        return diag
    }
    return diag.ErrorDetailed(
        diagnostic.TypeErrorCategory(),
        pos,
        "FTYPE040",
        "if condition must be bool, got "+got,
        "Conditional branches are selected from a boolean value only.",
        "Compare the value explicitly or convert the expression to a bool before using it in 'if'.",
    )
}

func CheckReturnShape(exprs []ast.Expr, results []ast.TypeExpr, pos token.Pos, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if len(exprs) == len(results) {
        return CheckReturnTypes(exprs, results, 0, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if len(exprs) == 1 {
        got := InferExprTypeNameFromEnv(exprs[0], env, enums, structs, funcs, methods)
        elems := ParseTupleTypeNames(got)
        if len(elems) == len(results) {
            return CheckReturnTupleTypes(elems, results, 0, exprs[0].TokenPos(), diag, interfaces, methods)
        }
        if !(got == "") {
            return diag.ErrorDetailed(
                diagnostic.TypeErrorCategory(),
                pos,
                "FTYPE041",
                "return value count mismatch: expected "+IntString(len(results))+", got "+IntString(len(exprs)),
                "The function returns " + IntString(len(results)) + " values, but this return statement produces one expression of inferred type " + got + ". " + ReturnExprReason(exprs[0], got, env, enums, structs, funcs, methods),
                "Return the same number of values as the function result list, or change the function signature if a single aggregate value is intended.",
            )
        }
    }
    return diag.ErrorDetailed(
        diagnostic.TypeErrorCategory(),
        pos,
        "FTYPE041",
        "return value count mismatch: expected "+IntString(len(results))+", got "+IntString(len(exprs)),
        "The function signature and the return statement disagree on result arity.",
        "Return the same number of values as the function result list, or wrap multiple values in an explicit tuple only when the signature expects it.",
    )
}

func CheckReturnTypes(exprs []ast.Expr, results []ast.TypeExpr, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(exprs) {
        return diag
    }
    expected := TypeExprName(results[idx])
    got := InferExprTypeNameFromEnv(exprs[idx], env, enums, structs, funcs, methods)
    if expected == "" {
        return CheckReturnTypes(exprs, results, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if got == "" {
        return CheckReturnTypes(exprs, results, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ReturnTypeCompatible(expected, got, interfaces, methods) {
        return CheckReturnTypes(exprs, results, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckReturnTypes(
        exprs,
        results,
        idx + 1,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            exprs[idx].TokenPos(),
            "FTYPE042",
            "return type mismatch: expected "+expected+", got "+got,
            "Result #" + IntString(idx + 1) + " is declared as " + expected + ", but the returned expression is inferred as " + got + ". " + ReturnExprReason(exprs[idx], got, env, enums, structs, funcs, methods),
            "Change the returned expression so it produces " + expected + ", or change the function result type if the current expression is the intended one.",
        ),
        env,
        enums,
        structs,
        interfaces,
        funcs,
        methods,
    )
}

func CheckReturnTupleTypes(got []string, results []ast.TypeExpr, idx int, pos token.Pos, diag diagnostic.Diagnostics, interfaces []InterfaceInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(got) {
        return diag
    }
    expected := TypeExprName(results[idx])
    if ReturnTypeCompatible(expected, got[idx], interfaces, methods) {
        return CheckReturnTupleTypes(got, results, idx + 1, pos, diag, interfaces, methods)
    }
    return CheckReturnTupleTypes(
        got,
        results,
        idx + 1,
        pos,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            pos,
            "FTYPE043",
            "return type mismatch: expected "+expected+", got "+got[idx],
            "Tuple result #" + IntString(idx + 1) + " is declared as " + expected + ", but the returned tuple element is inferred as " + got[idx] + ".",
            "Adjust the tuple element expression or the function result list so they agree.",
        ),
        interfaces,
        methods,
    )
}

func ReturnExprReason(expr ast.Expr, got string, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) string {
    if ast.ExprIsIdent(expr) {
        name := ast.ExprIdentName(expr)
        bound := LookupTypeEnv(env, name)
        if !(bound == "") {
            return "Name '" + name + "' is currently bound as " + bound + "."
        }
        return "Name '" + name + "' is inferred as " + got + "."
    }
    if ast.ExprIsCall(expr) {
        fn := ast.ExprCallFunc(expr)
        if ast.ExprIsIdent(fn) {
            name := ast.ExprIdentName(fn)
            sig := ResolveFuncSig(funcs, name)
            if !isNone[FuncInfo](sig) {
                info := unwrapOr[FuncInfo](sig, EmptyFuncInfo())
                return "Call '" + name + "' resolves to " + CallSignatureDetail(info) + "."
            }
            if !(EnumTypeForVariant(name, enums) == "") {
                return "Constructor call '" + name + "' builds enum value " + got + "."
            }
        }
        if ast.ExprIsSelector(fn) {
            recvType := InferExprTypeNameFromEnv(ast.ExprSelectorTarget(fn), env, enums, structs, funcs, methods)
            if !(recvType == "") {
                return "Method call '" + recvType + "." + ast.ExprSelectorField(fn) + "' is inferred as " + got + "."
            }
        }
        return "This call expression is inferred as " + got + "."
    }
    if ast.ExprIsSelector(expr) {
        recvType := InferExprTypeNameFromEnv(ast.ExprSelectorTarget(expr), env, enums, structs, funcs, methods)
        if !(recvType == "") {
            return "Selector '" + recvType + "." + ast.ExprSelectorField(expr) + "' resolves to " + got + "."
        }
    }
    if ast.ExprIsStructLit(expr) {
        return "Struct literal constructs " + ast.ExprStructLitType(expr) + "."
    }
    if ast.ExprIsCopyUpdate(expr) {
        sourceType := InferExprTypeNameFromEnv(ast.ExprCopyUpdateSource(expr), env, enums, structs, funcs, methods)
        if !(sourceType == "") {
            return "Copy-update preserves the source struct type " + sourceType + "."
        }
    }
    if ast.ExprIsTuple(expr) {
        return "Tuple literal is inferred as " + got + "."
    }
    if ast.ExprIsBasicLit(expr) {
        return "Literal expression is inferred as " + got + "."
    }
    return "This expression is inferred as " + got + "."
}

func TypeExprName(expr ast.TypeExpr) string {
    if ast.TypeExprIsQualified(expr) {
        name := ast.TypeExprQualifiedPackage(expr) + "." + ast.TypeExprQualifiedName(expr)
        args := ast.TypeExprQualifiedArgs(expr)
        if len(args) == 0 {
            return name
        }
        return name + "[" + JoinTypeNames(args, 0) + "]"
    }
    if ast.TypeExprIsTuple(expr) {
        return "(" + JoinTypeNames(ast.TypeExprTupleElems(expr), 0) + ")"
    }
    if ast.TypeExprIsMap(expr) {
        return "map[" + TypeExprName(ast.TypeExprMapKey(expr)) + "]" + TypeExprName(ast.TypeExprMapValue(expr))
    }
    if ast.TypeExprIsPointer(expr) {
        return "*" + TypeExprName(ast.TypeExprPointerElem(expr))
    }
    if ast.TypeExprIsSlice(expr) {
        return "[]" + TypeExprName(ast.TypeExprSliceElem(expr))
    }
    if ast.TypeExprIsChan(expr) {
        if ast.TypeExprChanReceiveOnly(expr) {
            return "<-chan " + TypeExprName(ast.TypeExprChanElem(expr))
        }
        return "chan " + TypeExprName(ast.TypeExprChanElem(expr))
    }
    if ast.TypeExprIsFunc(expr) {
        return FuncTypeName(ast.TypeExprFuncParams(expr), ast.TypeExprFuncResults(expr))
    }
    name := ast.TypeExprNamedName(expr)
    args := ast.TypeExprNamedArgs(expr)
    if len(args) == 0 {
        return name
    }
    return name + "[" + JoinTypeNames(args, 0) + "]"
}

func JoinTypeNames(items []ast.TypeExpr, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := TypeExprName(items[idx])
    if idx + 1 >= len(items) {
        return head
    }
    return head + ", " + JoinTypeNames(items, idx + 1)
}

func FuncTypeName(params []ast.TypeExpr, results []ast.TypeExpr) string {
    if len(params) == 0 {
        if len(results) == 0 {
            return "func"
        }
    }
    head := "func(" + JoinTypeNames(params, 0) + ")"
    if len(results) == 0 {
        return head
    }
    if len(results) == 1 {
        return head + " " + TypeExprName(results[0])
    }
    return head + " (" + JoinTypeNames(results, 0) + ")"
}

func FuncLitTypeName(params []ast.FieldDef, results []ast.TypeExpr) string {
    return FuncTypeName(FuncLitParamTypes(params, 0, []ast.TypeExpr{}), results)
}

func FuncLitParamTypes(params []ast.FieldDef, idx int, acc []ast.TypeExpr) []ast.TypeExpr {
    if idx >= len(params) {
        return acc
    }
    return FuncLitParamTypes(params, idx + 1, append(acc, ast.FieldType(params[idx])))
}

func FuncTypeParamCloseIndex(typeName string, idx int, depth int) int {
    if idx >= len(typeName) {
        return -1
    }
    if typeName[idx] == "("[0] {
        return FuncTypeParamCloseIndex(typeName, idx + 1, depth + 1)
    }
    if typeName[idx] == ")"[0] {
        if depth == 0 {
            return idx
        }
        return FuncTypeParamCloseIndex(typeName, idx + 1, depth - 1)
    }
    return FuncTypeParamCloseIndex(typeName, idx + 1, depth)
}

func SliceString(value string, start int, end int) string {
    if start < 0 {
        return SliceString(value, 0, end)
    }
    if end < start {
        return ""
    }
    if end > len(value) {
        return SliceString(value, start, len(value))
    }
    return value[start:end]
}

func FuncTypeParamTypeNames(typeName string) []string {
    if typeName == "func" {
        return []string{}
    }
    close := FuncTypeParamCloseIndex(typeName, 5, 0)
    if close < 0 {
        return []string{}
    }
    text := strings.TrimSpace(SliceString(typeName, 5, close))
    if text == "" {
        return []string{}
    }
    return SplitTopLevelComma(text)
}

func FuncTypeResultTypeNames(typeName string) []string {
    if typeName == "func" {
        return []string{}
    }
    close := FuncTypeParamCloseIndex(typeName, 5, 0)
    if close < 0 {
        return []string{}
    }
    text := strings.TrimSpace(SliceString(typeName, close + 1, len(typeName)))
    if text == "" {
        return []string{}
    }
    if HasTupleEnvelope(text) {
        return ParseTupleTypeNames(text)
    }
    return []string{text}
}

func JoinNormalizedTypeNames(items []string) string {
    return strings.Join(NormalizeInteropTypeNames(items, 0, []string{}), ", ")
}

func NormalizeInteropTypeNames(items []string, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return NormalizeInteropTypeNames(items, idx + 1, append(acc, NormalizeInteropTypeName(items[idx])))
}

func IsPreludeInteropBaseType(short string) bool {
    return short == "Option" || short == "Result" || short == "Unit" || short == "Ordering" || short == "IOResult" || short == "StringResult" || short == "UnitResult" || short == "StringsResult" || short == "Cmd" || short == "Task" || short == "TaskResult" || short == "Pair"
}

func NormalizeInteropBaseType(typeName string) string {
    if strings.HasPrefix(typeName, "base.") {
        short := QualifiedTypeShortName(typeName)
        if IsPreludeInteropBaseType(short) {
            return short
        }
        return "fo." + short
    }
    if strings.HasPrefix(typeName, "fo.") {
        short := QualifiedTypeShortName(typeName)
        if IsPreludeInteropBaseType(short) {
            return short
        }
    }
    return typeName
}

func NormalizeInteropFuncType(typeName string) string {
    if typeName == "func" {
        return typeName
    }
    params := FuncTypeParamTypeNames(typeName)
    results := FuncTypeResultTypeNames(typeName)
    head := "func(" + JoinNormalizedTypeNames(params) + ")"
    if len(results) == 0 {
        return head
    }
    if len(results) == 1 {
        return head + " " + NormalizeInteropTypeName(results[0])
    }
    return head + " (" + JoinNormalizedTypeNames(results) + ")"
}

func NormalizeInteropTypeName(typeName string) string {
    if typeName == "" {
        return ""
    }
    if strings.HasPrefix(typeName, "...") {
        return "..." + NormalizeInteropTypeName(strings.TrimPrefix(typeName, "..."))
    }
    if strings.HasPrefix(typeName, "*") {
        return "*" + NormalizeInteropTypeName(TrimPointerPrefix(typeName))
    }
    if strings.HasPrefix(typeName, "[]") {
        return "[]" + NormalizeInteropTypeName(strings.TrimPrefix(typeName, "[]"))
    }
    if strings.HasPrefix(typeName, "<-chan ") {
        return "<-chan " + NormalizeInteropTypeName(strings.TrimPrefix(typeName, "<-chan "))
    }
    if strings.HasPrefix(typeName, "chan ") {
        return "chan " + NormalizeInteropTypeName(strings.TrimPrefix(typeName, "chan "))
    }
    if HasMapPrefix(typeName) {
        return "map[" + NormalizeInteropTypeName(MapKeyTypeName(typeName)) + "]" + NormalizeInteropTypeName(MapValueTypeName(typeName))
    }
    if HasTupleEnvelope(typeName) {
        return "(" + JoinNormalizedTypeNames(ParseTupleTypeNames(typeName)) + ")"
    }
    if HasFuncType(typeName) {
        return NormalizeInteropFuncType(typeName)
    }
    base := NormalizeInteropBaseType(BaseTypeName(typeName))
    args := ParseNamedTypeArgs(typeName)
    if len(args) == 0 {
        return base
    }
    return base + "[" + JoinNormalizedTypeNames(args) + "]"
}

func InferExprTypeName(expr ast.Expr) string {
    if ast.ExprIsIdent(expr) {
        if ast.ExprIdentName(expr) == "nil" {
            return "nil"
        }
    }
    if ast.ExprIsBasicLit(expr) {
        return BasicLitTypeName(ast.ExprBasicLitKind(expr), ast.ExprBasicLitValue(expr))
    }
    if ast.ExprIsFuncLit(expr) {
        return FuncLitTypeName(ast.ExprFuncLitParams(expr), ast.ExprFuncLitResults(expr))
    }
    if ast.ExprIsMake(expr) {
        return TypeExprName(ast.ExprMakeType(expr))
    }
    if ast.ExprIsTuple(expr) {
        return TupleExprTypeName(ast.ExprTupleElems(expr), 0, []string{})
    }
    if ast.ExprIsMapLit(expr) {
        if !(ast.ExprMapLitTypeName(expr) == "") {
            return ast.ExprMapLitTypeName(expr)
        }
        return "map[" + TypeExprName(ast.ExprMapLitKeyType(expr)) + "]" + TypeExprName(ast.ExprMapLitValueType(expr))
    }
    if ast.ExprIsSliceLit(expr) {
        if !(ast.ExprSliceLitTypeName(expr) == "") {
            return ast.ExprSliceLitTypeName(expr)
        }
        if !isNone[ast.TypeExpr](ast.ExprSliceLitType(expr)) {
            return "[]" + TypeExprName(unwrapOr[ast.TypeExpr](ast.ExprSliceLitType(expr), ast.MakeNamedType(ast.ZeroPos(), "any")))
        }
    }
    if ast.ExprIsStructLit(expr) {
        return ast.ExprStructLitType(expr)
    }
    if ast.ExprIsCall(expr) {
        fn := ast.ExprCallFunc(expr)
        if ast.ExprIsIdent(fn) {
            builtin := BuiltinCallResultType(ast.ExprIdentName(fn))
            if !(builtin == "") {
                return builtin
            }
        }
    }
    if ast.ExprIsUnary(expr) {
        if ast.ExprUnaryOp(expr) == token.NotType() {
            return "bool"
        }
        if ast.ExprUnaryOp(expr) == token.MinusType() {
            return InferExprTypeName(ast.ExprUnaryOperand(expr))
        }
    }
    if ast.ExprIsBinary(expr) {
        op := ast.ExprBinaryOp(expr)
        if op == token.EqType() || op == token.LandType() || op == token.LorType() || op == token.LtType() || op == token.GtType() || op == token.LteType() || op == token.GteType() {
            return "bool"
        }
        left := InferExprTypeName(ast.ExprBinaryLeft(expr))
        right := InferExprTypeName(ast.ExprBinaryRight(expr))
        if left == right {
            return left
        }
        return ""
    }
    if ast.ExprIsPipeline(expr) {
        return InferExprTypeName(ast.ExprPipelineRight(expr))
    }
    return ""
}

func BasicLitTypeName(kind token.Type, value string) string {
    if kind == token.StringLitType() {
        return "string"
    }
    if kind == token.IntLitType() {
        return "int"
    }
    if kind == token.FloatLitType() {
        return "float64"
    }
    if kind == token.RuneLitType() {
        return "rune"
    }
    if kind == token.TrueType() || kind == token.FalseType() {
        return "bool"
    }
    if value == "true" || value == "false" {
        return "bool"
    }
    return ""
}

func TupleExprTypeName(items []ast.Expr, idx int, acc []string) string {
    if idx >= len(items) {
        return "(" + JoinStrings(acc, 0) + ")"
    }
    got := InferExprTypeName(items[idx])
    if got == "" {
        return ""
    }
    return TupleExprTypeName(items, idx + 1, append(acc, got))
}

func IntString(n int) string {
    if n == 0 {
        return "0"
    }
    if n == 1 {
        return "1"
    }
    if n == 2 {
        return "2"
    }
    if n == 3 {
        return "3"
    }
    if n == 4 {
        return "4"
    }
    if n == 5 {
        return "5"
    }
    if n == 6 {
        return "6"
    }
    if n == 7 {
        return "7"
    }
    if n == 8 {
        return "8"
    }
    if n == 9 {
        return "9"
    }
    return "0"
}

func CheckMatchExhaustiveness(stmt ast.Stmt, env []TypeEntry, enums []EnumInfo, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    matchType := InferMatchTagType(ast.StmtMatchTag(stmt), env, enums)
    if matchType == "" {
        return diag
    }
    info := FindEnumInfo(enums, matchType)
    if isNone[EnumInfo](info) {
        return diag
    }
    item := unwrapOr[EnumInfo](info, EmptyEnumInfo())
    return CheckMatchCasesAgainstEnum(ast.StmtMatchCases(stmt), item, stmt.TokenPos(), diag)
}

func InferMatchTagType(expr ast.Expr, env []TypeEntry, enums []EnumInfo) string {
    if ast.ExprIsIdent(expr) {
        return LookupTypeEnv(env, ast.ExprIdentName(expr))
    }
    if ast.ExprIsCall(expr) {
        fn := ast.ExprCallFunc(expr)
        if ast.ExprIsIdent(fn) {
            return EnumTypeForVariant(ast.ExprIdentName(fn), enums)
        }
    }
    return ""
}

func LookupTypeEnv(env []TypeEntry, name string) string {
    if len(env) == 0 {
        return ""
    }
    if env[0].Name == name {
        return env[0].TypeName
    }
    return LookupTypeEnv(env[1:], name)
}

func FindStructInfo(items []StructInfo, name string) Option[StructInfo] {
    if len(items) == 0 {
        return None[StructInfo]()
    }
    if BaseTypeName(items[0].Name) == BaseTypeName(name) {
        return Some[StructInfo](items[0])
    }
    return FindStructInfo(items[1:], name)
}

func FieldTypeForStruct(typeName string, fieldName string, structs []StructInfo) string {
    normalized := NormalizeStructLikeType(typeName)
    info := FindStructInfo(structs, normalized)
    if isNone[StructInfo](info) {
        liveFieldType := LiveAnyStructFieldType(normalized, fieldName)
        if !(liveFieldType == "") {
            return liveFieldType
        }
        return StdlibStructFieldType(normalized, fieldName)
    }
    item := unwrapOr[StructInfo](info, EmptyStructInfo())
    return FieldTypeForInfo(item.Fields, fieldName)
}

func ResolveFieldPathType(structType string, path []string, structs []StructInfo) string {
    if len(path) == 0 {
        return structType
    }
    fieldType := FieldTypeForStruct(structType, path[0], structs)
    if fieldType == "" {
        return ""
    }
    if len(path) == 1 {
        return fieldType
    }
    if !IsKnownStructType(fieldType, structs) {
        return ""
    }
    return ResolveFieldPathType(fieldType, path[1:], structs)
}

func FieldTypeForInfo(fields []FieldTypeInfo, fieldName string) string {
    if len(fields) == 0 {
        return ""
    }
    if fields[0].Name == fieldName {
        return fields[0].TypeName
    }
    return FieldTypeForInfo(fields[1:], fieldName)
}

func SliceElemTypeName(typeName string) string {
    if HasSlicePrefix(typeName) {
        return TrimSlicePrefix(typeName)
    }
    return ""
}

func HasSlicePrefix(typeName string) bool {
    if len(typeName) < 2 {
        return false
    }
    if typeName[0] == "["[0] {
        if typeName[1] == "]"[0] {
            return true
        }
    }
    return false
}

func TrimSlicePrefix(typeName string) string {
    if len(typeName) <= 2 {
        return ""
    }
    return typeName[2:len(typeName)]
}

func ParseTupleTypeNames(typeName string) []string {
    if !HasTupleEnvelope(typeName) {
        return []string{}
    }
    inner := TrimTupleEnvelope(typeName)
    if strings.TrimSpace(inner) == "" {
        return []string{}
    }
    return ParseTupleTypeNamesLoop(strings.Split(inner, ","), 0, []string{})
}

func HasTupleEnvelope(typeName string) bool {
    if len(typeName) < 2 {
        return false
    }
    if typeName[0] == "("[0] {
        if typeName[len(typeName)-1] == ")"[0] {
            return true
        }
    }
    return false
}

func TrimTupleEnvelope(typeName string) string {
    if len(typeName) <= 2 {
        return ""
    }
    return typeName[1 : len(typeName)-1]
}

func ParseTupleTypeNamesLoop(items []string, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return ParseTupleTypeNamesLoop(items, idx + 1, append(acc, strings.TrimSpace(items[idx])))
}

func FindEnumInfo(enums []EnumInfo, name string) Option[EnumInfo] {
    if len(enums) == 0 {
        return None[EnumInfo]()
    }
    if BaseTypeName(enums[0].Name) == BaseTypeName(name) {
        return Some[EnumInfo](enums[0])
    }
    return FindEnumInfo(enums[1:], name)
}

func EnumTypeForVariant(variant string, enums []EnumInfo) string {
    return EnumTypeForVariantLoop(variant, enums, 0, "")
}

func EnumTypeForVariantLoop(variant string, enums []EnumInfo, idx int, found string) string {
    if idx >= len(enums) {
        return found
    }
    if EnumHasVariant(enums[idx], variant) {
        if found == "" {
            return EnumTypeForVariantLoop(variant, enums, idx + 1, enums[idx].Name)
        }
        return ""
    }
    return EnumTypeForVariantLoop(variant, enums, idx + 1, found)
}

func EnumHasVariant(info EnumInfo, variant string) bool {
    return StringIn(info.Variants, variant)
}

func ReturnTypeCompatible(expected string, got string, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    expectedNorm := NormalizeInteropTypeName(expected)
    gotNorm := NormalizeInteropTypeName(got)
    if IsTypeVariableName(expectedNorm) {
        return true
    }
    if expectedNorm == "any" {
        return true
    }
    if expectedNorm == "interface" {
        return true
    }
    if NilCompatible(expectedNorm, gotNorm) {
        return true
    }
    if IntegerCompatible(expectedNorm, gotNorm) {
        return true
    }
    if expectedNorm == "func" {
        return HasFuncType(gotNorm)
    }
    if gotNorm == "func" {
        return HasFuncType(expectedNorm)
    }
    if HasFuncType(expectedNorm) {
        if HasFuncType(gotNorm) {
            return FuncTypeCompatible(expectedNorm, gotNorm, interfaces, methods)
        }
    }
    if StructuralTypeCompatible(expectedNorm, gotNorm, interfaces, methods) {
        return true
    }
    if PointerCompatible(expectedNorm, gotNorm) {
        return true
    }
    if StdlibUnderlyingCompatible(expectedNorm, gotNorm) {
        return true
    }
    if expectedNorm == gotNorm {
        return true
    }
    return TypeImplementsInterface(gotNorm, expectedNorm, interfaces, methods)
}

func ArgumentTypeCompatible(expected string, got string, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    expectedNorm := NormalizeInteropTypeName(expected)
    gotNorm := NormalizeInteropTypeName(got)
    if IsTypeVariableName(expectedNorm) {
        return true
    }
    return ReturnTypeCompatible(expectedNorm, gotNorm, interfaces, methods)
}

func StructuralTypeCompatible(expected string, got string, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    if HasSlicePrefix(expected) {
        if HasSlicePrefix(got) {
            return ReturnTypeCompatible(TrimSlicePrefix(expected), TrimSlicePrefix(got), interfaces, methods)
        }
    }
    if HasMapPrefix(expected) {
        if HasMapPrefix(got) {
            if !ReturnTypeCompatible(MapKeyTypeName(expected), MapKeyTypeName(got), interfaces, methods) {
                return false
            }
            return ReturnTypeCompatible(MapValueTypeName(expected), MapValueTypeName(got), interfaces, methods)
        }
    }
    if HasTupleEnvelope(expected) {
        if HasTupleEnvelope(got) {
            return StructuralTypeListCompatible(ParseTupleTypeNames(expected), ParseTupleTypeNames(got), 0, interfaces, methods)
        }
    }
    expectedBase := BaseTypeName(expected)
    gotBase := BaseTypeName(got)
    expectedArgs := ParseNamedTypeArgs(expected)
    gotArgs := ParseNamedTypeArgs(got)
    if expectedBase == gotBase {
        if len(expectedArgs) == len(gotArgs) {
            if len(expectedArgs) > 0 {
                return StructuralTypeListCompatible(expectedArgs, gotArgs, 0, interfaces, methods)
            }
        }
    }
    return false
}

func StructuralTypeListCompatible(expected []string, got []string, idx int, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    if !(len(expected) == len(got)) {
        return false
    }
    if idx >= len(expected) {
        return true
    }
    if !ReturnTypeCompatible(expected[idx], got[idx], interfaces, methods) {
        return false
    }
    return StructuralTypeListCompatible(expected, got, idx + 1, interfaces, methods)
}

func FuncTypeCompatible(expected string, got string, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    expectedParams := FuncTypeParamTypeNames(expected)
    gotParams := FuncTypeParamTypeNames(got)
    if !(len(expectedParams) == len(gotParams)) {
        return false
    }
    expectedResults := FuncTypeResultTypeNames(expected)
    gotResults := FuncTypeResultTypeNames(got)
    if !(len(expectedResults) == len(gotResults)) {
        return false
    }
    if !FuncTypeListCompatible(expectedParams, gotParams, 0, interfaces, methods) {
        return false
    }
    return FuncTypeListCompatible(expectedResults, gotResults, 0, interfaces, methods)
}

func FuncTypeListCompatible(expected []string, got []string, idx int, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    if idx >= len(expected) {
        return true
    }
    if !ReturnTypeCompatible(expected[idx], got[idx], interfaces, methods) {
        return false
    }
    return FuncTypeListCompatible(expected, got, idx + 1, interfaces, methods)
}

func IntegerCompatible(expected string, got string) bool {
    if !IsIntegerLikeType(expected) {
        return false
    }
    return IsIntegerLikeType(got)
}

func IsIntegerLikeType(typeName string) bool {
    if typeName == "int" || typeName == "int32" || typeName == "int64" {
        return true
    }
    if typeName == "uint" || typeName == "uint32" || typeName == "uint64" {
        return true
    }
    if typeName == "byte" || typeName == "rune" {
        return true
    }
    return false
}

func PointerCompatible(expected string, got string) bool {
    if strings.HasPrefix(expected, "*") {
        return TrimPointerPrefix(expected) == got
    }
    return false
}

func TrimPointerPrefix(typeName string) string {
    return strings.TrimPrefix(typeName, "*")
}

func StdlibUnderlyingCompatible(expected string, got string) bool {
    expectedUnderlying := StdlibNamedUnderlyingType(expected)
    gotUnderlying := StdlibNamedUnderlyingType(got)
    if !(expectedUnderlying == "") {
        if expectedUnderlying == got {
            return true
        }
        if IntegerCompatible(expectedUnderlying, got) {
            return true
        }
    }
    if !(gotUnderlying == "") {
        if gotUnderlying == expected {
            return true
        }
        if IntegerCompatible(expected, gotUnderlying) {
            return true
        }
    }
    if !(expectedUnderlying == "") {
        if !(gotUnderlying == "") {
            if IntegerCompatible(expectedUnderlying, gotUnderlying) {
                return true
            }
            return expectedUnderlying == gotUnderlying
        }
    }
    return false
}

func HasFuncType(typeName string) bool {
    return typeName == "func" || strings.HasPrefix(typeName, "func(")
}

func NilCompatible(expected string, got string) bool {
    if !(got == "nil") {
        return false
    }
    if expected == "interface" {
        return true
    }
    if expected == "error" {
        return true
    }
    if strings.HasPrefix(expected, "*") {
        return true
    }
    if strings.HasPrefix(expected, "[]") {
        return true
    }
    if strings.HasPrefix(expected, "map[") {
        return true
    }
    if strings.HasPrefix(expected, "chan ") || strings.HasPrefix(expected, "<-chan ") {
        return true
    }
    if HasFuncType(expected) {
        return true
    }
    underlying := StdlibNamedUnderlyingType(expected)
    if underlying == "" {
        return false
    }
    return NilCompatible(underlying, got)
}

func TypeImplementsInterface(typeName string, interfaceName string, interfaces []InterfaceInfo, methods []MethodInfo) bool {
    info := FindInterfaceInfo(interfaces, interfaceName)
    if !isNone[InterfaceInfo](info) {
        item := unwrapOr[InterfaceInfo](info, EmptyInterfaceInfo())
        return HasMethodInfos(typeName, item.Methods, methods, 0)
    }
    builtin := BuiltinInterfaceMethods(interfaceName)
    if len(builtin) > 0 {
        return HasMethodInfos(typeName, builtin, methods, 0)
    }
    live := LiveAnyInterfaceMethods(interfaceName)
    if len(live) > 0 {
        return HasMethodInfos(typeName, live, methods, 0)
    }
    stdlib := StdlibInterfaceMethods(interfaceName)
    if len(stdlib) == 0 {
        return false
    }
    return HasMethodInfos(typeName, stdlib, methods, 0)
}

func BuiltinInterfaceMethods(interfaceName string) []FuncInfo {
    if interfaceName == "error" {
        return []FuncInfo{
            MakeSimpleFuncInfo("Error", []string{}, []string{}, []string{"string"}),
        }
    }
    return []FuncInfo{}
}

func FindInterfaceInfo(items []InterfaceInfo, name string) Option[InterfaceInfo] {
    if len(items) == 0 {
        return None[InterfaceInfo]()
    }
    if BaseTypeName(items[0].Name) == BaseTypeName(name) {
        return Some[InterfaceInfo](items[0])
    }
    return FindInterfaceInfo(items[1:], name)
}

func HasMethodInfos(typeName string, infos []FuncInfo, methods []MethodInfo, idx int) bool {
    if idx >= len(infos) {
        return true
    }
    if MethodImplements(typeName, infos[idx], methods) {
        return HasMethodInfos(typeName, infos, methods, idx + 1)
    }
    return false
}

func MethodImplements(typeName string, need FuncInfo, methods []MethodInfo) bool {
    info := FindMethodInfo(methods, typeName, need.Name)
    if !isNone[MethodInfo](info) {
        item := unwrapOr[MethodInfo](info, EmptyMethodInfo())
        if SignatureMatches(need.ParamTypes, item.ParamTypes, 0) {
            return SignatureMatches(need.ResultTypes, item.ResultTypes, 0)
        }
        return false
    }
    resolved := ResolveAnyMethodSig(methods, typeName, need.Name, len(need.ParamTypes))
    if !isNone[FuncInfo](resolved) {
        item := unwrapOr[FuncInfo](resolved, EmptyFuncInfo())
        if SignatureMatches(need.ParamTypes, item.ParamTypes, 0) {
            return SignatureMatches(need.ResultTypes, item.ResultTypes, 0)
        }
    }
    return false
}

func SignatureMatches(left []string, right []string, idx int) bool {
    if len(left) == len(right) {
        if idx >= len(left) {
            return true
        }
        if NormalizeInteropTypeName(left[idx]) == NormalizeInteropTypeName(right[idx]) {
            return SignatureMatches(left, right, idx + 1)
        }
    }
    return false
}

func StringIn(items []string, want string) bool {
    if len(items) == 0 {
        return false
    }
    if items[0] == want {
        return true
    }
    return StringIn(items[1:], want)
}

type CoverageState struct {
    Diag diagnostic.Diagnostics
    Seen []CoverageEntry
    HasWildcard bool
    CatchAllPos token.Pos
}

type CoverageEntry struct {
    Name string
    Pos token.Pos
}

func CheckMatchCasesAgainstEnum(cases []ast.MatchCase, info EnumInfo, pos token.Pos, diag diagnostic.Diagnostics) diagnostic.Diagnostics {
    state := AnalyzeMatchCoverage(cases, 0, []CoverageEntry{}, false, ast.ZeroPos(), diag)
    if state.HasWildcard {
        return state.Diag
    }
    seenNames := CoverageEntryNames(state.Seen, 0, []string{})
    missing := MissingVariants(info.Variants, seenNames, 0, []string{})
    if len(missing) == 0 {
        return state.Diag
    }
    suggestion := MissingVariantSuggestion(cases, info, missing)
    return state.Diag.ErrorDetailedSuggested(
        diagnostic.ExhaustivenessCategory(),
        pos,
        "FEXH001",
        "match does not cover every case of '"+info.Name+"'. Missing: "+JoinStrings(missing, 0),
        ExhaustivenessDetail(info.Name, missing),
        MaybeSuggestionText(suggestion),
        ExhaustivenessHint(missing, suggestion),
    )
}

func AnalyzeMatchCoverage(cases []ast.MatchCase, idx int, seen []CoverageEntry, hasWildcard bool, catchAllPos token.Pos, diag diagnostic.Diagnostics) CoverageState {
    if idx >= len(cases) {
        return CoverageState{
            Diag: diag,
            Seen: seen,
            HasWildcard: hasWildcard,
            CatchAllPos: catchAllPos,
        }
    }
    pattern := ast.MatchCasePattern(cases[idx])
    if hasWildcard {
        return AnalyzeMatchCoverage(
            cases,
            idx + 1,
            seen,
            hasWildcard,
            catchAllPos,
            diag.WarningRelated(
                diagnostic.ExhaustivenessCategory(),
                cases[idx].Pos,
                "FEXH002",
                "unreachable match case",
                "A previous catch-all pattern already handles every remaining value.",
                "Remove this case or move it before the catch-all case if it is meant to match first.",
                catchAllPos,
                "previous catch-all case is here",
            ),
        )
    }
    if ast.PatternIsWildcard(pattern) {
        return AnalyzeMatchCoverage(cases, idx + 1, seen, true, cases[idx].Pos, diag)
    }
    if ast.PatternIsIdent(pattern) {
        return AnalyzeMatchCoverage(cases, idx + 1, seen, true, cases[idx].Pos, diag)
    }
    if ast.PatternIsEnum(pattern) {
        name := ast.PatternEnumName(pattern)
        prev := FindCoverageEntry(seen, name)
        if !isNone[CoverageEntry](prev) {
            item := unwrapOr[CoverageEntry](prev, CoverageEntry{Name: "", Pos: ast.ZeroPos()})
            return AnalyzeMatchCoverage(
                cases,
                idx + 1,
                seen,
                false,
                catchAllPos,
                diag.WarningRelated(
                    diagnostic.ExhaustivenessCategory(),
                    cases[idx].Pos,
                    "FEXH003",
                    "redundant match case",
                    "This variant was already handled by an earlier case.",
                    "Remove the duplicate case or merge its logic into the earlier matching branch.",
                    item.Pos,
                    "previous case for '"+name+"' is here",
                ),
            )
        }
        return AnalyzeMatchCoverage(cases, idx + 1, append(seen, CoverageEntry{Name: name, Pos: cases[idx].Pos}), false, catchAllPos, diag)
    }
    return AnalyzeMatchCoverage(cases, idx + 1, seen, false, catchAllPos, diag)
}

func CoverageEntryNames(items []CoverageEntry, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return CoverageEntryNames(items, idx + 1, append(acc, items[idx].Name))
}

func FindCoverageEntry(items []CoverageEntry, name string) Option[CoverageEntry] {
    if len(items) == 0 {
        return None[CoverageEntry]()
    }
    if items[0].Name == name {
        return Some[CoverageEntry](items[0])
    }
    return FindCoverageEntry(items[1:], name)
}

func ExhaustivenessDetail(typeName string, missing []string) string {
    return "The matched value has enum type " + typeName + ", but the case list still leaves uncovered constructors."
}

func ExhaustivenessHint(missing []string, suggestion string) string {
    if !(suggestion == "") {
        return "Add a case for " + suggestion + " or add a final catch-all only if every remaining case is intentionally handled the same way."
    }
    return "Add explicit cases for the missing variants, or add a final catch-all only if every remaining case is intentionally handled the same way."
}

func MissingVariantSuggestion(cases []ast.MatchCase, info EnumInfo, missing []string) string {
    if len(missing) == 1 {
        return missing[0]
    }
    return SuggestMissingVariantFromCases(cases, info, missing, 0, "", 0)
}

func SuggestMissingVariantFromCases(cases []ast.MatchCase, info EnumInfo, missing []string, idx int, best string, bestScore int) string {
    if idx >= len(cases) {
        if bestScore <= 0 {
            return ""
        }
        return best
    }
    pattern := ast.MatchCasePattern(cases[idx])
    if ast.PatternIsEnum(pattern) {
        name := ast.PatternEnumName(pattern)
        if !StringIn(info.Variants, name) {
            missingSuggestion := SuggestName(name, missing, 0, "", 0)
            if IsTypoLikeSuggestion(name, missingSuggestion) {
                score := SuggestionScore(name, missingSuggestion)
                if score > bestScore {
                    return SuggestMissingVariantFromCases(cases, info, missing, idx + 1, missingSuggestion, score)
                }
            }
        }
    }
    return SuggestMissingVariantFromCases(cases, info, missing, idx + 1, best, bestScore)
}

func MissingVariants(all []string, seen []string, idx int, acc []string) []string {
    if idx >= len(all) {
        return acc
    }
    if StringIn(seen, all[idx]) {
        return MissingVariants(all, seen, idx + 1, acc)
    }
    return MissingVariants(all, seen, idx + 1, append(acc, all[idx]))
}

func SemanticEnvAfterStmt(stmt ast.Stmt, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) []TypeEntry {
    if ast.StmtIsBind(stmt) {
        names := ast.StmtBindNames(stmt)
        if len(names) == 0 {
            return env
        }
        inferred := InferExprTypeNameFromEnv(ast.StmtBindValue(stmt), env, enums, structs, funcs, methods)
        if inferred == "" {
            return env
        }
        return ExtendTypeEnvForNames(names, inferred, env, 0)
    }
    return env
}

func ExtendTypeEnvForNames(names []string, inferred string, env []TypeEntry, idx int) []TypeEntry {
    if len(names) == 0 {
        return env
    }
    if len(names) == 1 {
        if IsBlankIdentifier(names[0]) {
            return env
        }
        return append(env, TypeEntry{
            Name: names[0],
            TypeName: inferred,
        })
    }
    elems := ParseTupleTypeNames(inferred)
    if len(elems) == len(names) {
        return ExtendTypeEnvForTupleNames(names, elems, env, 0)
    }
    return env
}

func ExtendTypeEnvForTupleNames(names []string, elems []string, env []TypeEntry, idx int) []TypeEntry {
    if idx >= len(names) {
        return env
    }
    if IsBlankIdentifier(names[idx]) {
        return ExtendTypeEnvForTupleNames(names, elems, env, idx + 1)
    }
    next := append(env, TypeEntry{
        Name: names[idx],
        TypeName: elems[idx],
    })
    return ExtendTypeEnvForTupleNames(names, elems, next, idx + 1)
}

func IsBlankIdentifier(name string) bool {
    return name == "_"
}

func InferExprTypeNameFromEnv(expr ast.Expr, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) string {
    if ast.ExprIsIdent(expr) {
        if ast.ExprIdentName(expr) == "nil" {
            return "nil"
        }
        return LookupTypeEnv(env, ast.ExprIdentName(expr))
    }
    if ast.ExprIsFuncLit(expr) {
        return FuncLitTypeName(ast.ExprFuncLitParams(expr), ast.ExprFuncLitResults(expr))
    }
    if ast.ExprIsMake(expr) {
        return TypeExprName(ast.ExprMakeType(expr))
    }
    if ast.ExprIsTuple(expr) {
        return TupleExprTypeNameFromEnv(ast.ExprTupleElems(expr), 0, []string{}, env, enums, structs, funcs, methods)
    }
    if ast.ExprIsMapLit(expr) {
        if !(ast.ExprMapLitTypeName(expr) == "") {
            return ast.ExprMapLitTypeName(expr)
        }
        return "map[" + TypeExprName(ast.ExprMapLitKeyType(expr)) + "]" + TypeExprName(ast.ExprMapLitValueType(expr))
    }
    if ast.ExprIsSliceLit(expr) {
        if !(ast.ExprSliceLitTypeName(expr) == "") {
            return ast.ExprSliceLitTypeName(expr)
        }
        if !isNone[ast.TypeExpr](ast.ExprSliceLitType(expr)) {
            return "[]" + TypeExprName(unwrapOr[ast.TypeExpr](ast.ExprSliceLitType(expr), ast.MakeNamedType(ast.ZeroPos(), "any")))
        }
    }
    if ast.ExprIsStructLit(expr) {
        return ast.ExprStructLitType(expr)
    }
    if ast.ExprIsCopyUpdate(expr) {
        return InferExprTypeNameFromEnv(ast.ExprCopyUpdateSource(expr), env, enums, structs, funcs, methods)
    }
    if ast.ExprIsSelector(expr) {
        recvType := CanonicalTypeNameWithEnv(InferExprTypeNameFromEnv(ast.ExprSelectorTarget(expr), env, enums, structs, funcs, methods), env)
        if recvType == "" {
            return ""
        }
        if IsPackageRefType(recvType) {
            return ResolvePackageValueType(PackageRefPath(recvType), ast.ExprSelectorField(expr))
        }
        return FieldTypeForStruct(recvType, ast.ExprSelectorField(expr), structs)
    }
    if ast.ExprIsIndex(expr) {
        base := InferExprTypeNameFromEnv(ast.ExprIndexTarget(expr), env, enums, structs, funcs, methods)
        return SliceElemTypeName(base)
    }
    if ast.ExprIsSlice(expr) {
        return InferExprTypeNameFromEnv(ast.ExprSliceTarget(expr), env, enums, structs, funcs, methods)
    }
    if ast.ExprIsCall(expr) {
        fn := ast.ExprCallFunc(expr)
        if ast.ExprIsIdent(fn) {
            builtin := BuiltinCallResultType(ast.ExprIdentName(fn))
            if !(builtin == "") {
                return builtin
            }
            info := ResolveFuncSig(funcs, ast.ExprIdentName(fn))
            if isNone[FuncInfo](info) {
                enumType := EnumTypeForVariant(ast.ExprIdentName(fn), enums)
                if enumType == "" {
                    return ""
                }
                return enumType
            }
            item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
            return CallResultTypeForExpr(item, ast.ExprCallTypeArgs(expr), ast.ExprCallArgs(expr), env, enums, structs, funcs, methods)
        }
        if ast.ExprIsSelector(fn) {
            recvType := CanonicalTypeNameWithEnv(InferExprTypeNameFromEnv(ast.ExprSelectorTarget(fn), env, enums, structs, funcs, methods), env)
            if recvType == "" {
                return ""
            }
            if IsPackageRefType(recvType) {
                path := PackageRefPath(recvType)
                name := ast.ExprSelectorField(fn)
                info := ResolvePackageFuncSig(path, name, len(ast.ExprCallArgs(expr)))
                if isNone[FuncInfo](info) {
                    return ""
                }
                item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
                return CallResultTypeForExpr(item, ast.ExprCallTypeArgs(expr), ast.ExprCallArgs(expr), env, enums, structs, funcs, methods)
            }
            info := ResolveAnyMethodSig(methods, recvType, ast.ExprSelectorField(fn), len(ast.ExprCallArgs(expr)))
            if isNone[FuncInfo](info) {
                return ""
            }
            item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
            return CallResultTypeForExpr(item, ast.ExprCallTypeArgs(expr), ast.ExprCallArgs(expr), env, enums, structs, funcs, methods)
        }
    }
    return InferExprTypeName(expr)
}

func CallResultTypeForExpr(info FuncInfo, typeArgs []ast.TypeExpr, args []ast.Expr, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) string {
    explicit := BindExplicitTypeArgsForInfo(info, typeArgs)
    inferred := InferTypeBindings(info.ParamTypes, args, 0, explicit, env, enums, structs, funcs, methods)
    if len(info.ResultTypes) == 1 {
        return SubstituteTypeVars(info.ResultTypes[0], inferred)
    }
    if len(info.ResultTypes) > 1 {
        return "(" + JoinResultTypes(info.ResultTypes, inferred, 0) + ")"
    }
    return ""
}

func IsPackageRefType(typeName string) bool {
    return strings.HasPrefix(typeName, "pkg:")
}

func PackageRefPath(typeName string) string {
    return strings.TrimPrefix(typeName, "pkg:")
}

func PackagePathForQualifiedType(typeName string, env []TypeEntry) string {
    qualifier := QualifiedTypeQualifier(typeName)
    if qualifier == "" {
        return ""
    }
    return PackagePathForQualifier(qualifier, env, 0)
}

func PackagePathForQualifier(qualifier string, env []TypeEntry, idx int) string {
    if idx >= len(env) {
        return ""
    }
    if env[idx].Name == qualifier {
        if IsPackageRefType(env[idx].TypeName) {
            return PackageRefPath(env[idx].TypeName)
        }
    }
    return PackagePathForQualifier(qualifier, env, idx + 1)
}

func QualifiedTypeShortName(typeName string) string {
    return QualifiedTypeSuffix(typeName)
}

func QualifiedTypeBaseName(typeName string) string {
    normalized := NormalizeStructLikeType(typeName)
    bracket := FirstBracketIndex(normalized, 0)
    if bracket >= 0 {
        return QualifiedTypeShortName(PrefixString(normalized, bracket))
    }
    return QualifiedTypeShortName(normalized)
}

func PrefixString(value string, limit int) string {
    if limit <= 0 {
        return ""
    }
    if limit >= len(value) {
        return value
    }
    return value[0:limit]
}

func CanonicalStructTypeName(typeName string) string {
    canonical := LiveAnyCanonicalTypeName(typeName)
    if canonical == "" {
        return typeName
    }
    return canonical
}

func CanonicalTypeNameWithEnv(typeName string, env []TypeEntry) string {
    if strings.HasPrefix(typeName, "*") {
        base := TrimPointerPrefix(typeName)
        path := PackagePathForQualifiedType(base, env)
        if !(path == "") {
            if !IsStdlibImportPath(path) {
                LiveAnyPreload(path)
            }
        }
        canonical := LiveAnyCanonicalTypeName(base)
        if !(canonical == "") {
            return "*" + canonical
        }
        if !(path == "") {
            return "*" + ImportBaseName(path) + "." + QualifiedTypeShortName(base)
        }
        return typeName
    }
    path := PackagePathForQualifiedType(typeName, env)
    if !(path == "") {
        if !IsStdlibImportPath(path) {
            LiveAnyPreload(path)
        }
    }
    canonical := LiveAnyCanonicalTypeName(typeName)
    if !(canonical == "") {
        return canonical
    }
    if !(path == "") {
        return ImportBaseName(path) + "." + QualifiedTypeShortName(typeName)
    }
    return typeName
}

func LiveAnyPreload(path string) {
    if IsStdlibImportPath(path) {
        return
    }
    LiveEnsurePackage(path)
}

func LiveEnsurePackage(path string) {
    return
}

func LiveKnownTypeNames() []string {
    return localKnownTypeNames()
}

func LiveKnownTypeOwner(typeName string) string {
    return localKnownTypeOwner(typeName)
}

func LivePackageFunctionNames(path string) []string {
    return localPackageFunctionNames(path)
}

func LivePackageMemberNames(path string) []string {
    return localPackageMemberNames(path)
}

func LivePackageMemberType(path string, name string) string {
    return localPackageMemberType(path, name)
}

func LivePackageFuncPrototype(path string, name string) Option[FuncInfo] {
    return localPackageFuncPrototype(path, name)
}

func LivePackageFuncSig(path string, name string, argCount int) Option[FuncInfo] {
    return localPackageFuncSig(path, name, argCount)
}

func LiveMethodNames(receiverType string) []string {
    return localMethodNames(receiverType)
}

func LiveMethodPrototype(receiverType string, name string) Option[FuncInfo] {
    return localMethodPrototype(receiverType, name)
}

func LiveMethodSig(receiverType string, name string, argCount int) Option[FuncInfo] {
    return localMethodSig(receiverType, name, argCount)
}

func LiveStructFieldNames(typeName string) []string {
    return localStructFieldNames(typeName)
}

func LiveStructFieldType(typeName string, fieldName string) string {
    return localStructFieldType(typeName, fieldName)
}

func LiveInterfaceMethods(interfaceType string) []FuncInfo {
    return localInterfaceMethods(interfaceType)
}

func LiveNamedUnderlyingType(typeName string) string {
    return localNamedUnderlyingType(typeName)
}

func NormalizeResolvedFuncInfo(info FuncInfo) FuncInfo {
    return MakeSimpleFuncInfo(
        info.Name,
        info.ParamNames,
        NormalizeInteropTypeNames(info.ParamTypes, 0, []string{}),
        NormalizeInteropTypeNames(info.ResultTypes, 0, []string{}),
    )
}

func NormalizeResolvedFuncInfoOption(info Option[FuncInfo]) Option[FuncInfo] {
    if isNone[FuncInfo](info) {
        return None[FuncInfo]()
    }
    return Some[FuncInfo](NormalizeResolvedFuncInfo(unwrapOr[FuncInfo](info, EmptyFuncInfo())))
}

func NormalizeResolvedFuncInfos(items []FuncInfo, idx int, acc []FuncInfo) []FuncInfo {
    if idx >= len(items) {
        return acc
    }
    return NormalizeResolvedFuncInfos(items, idx + 1, append(acc, NormalizeResolvedFuncInfo(items[idx])))
}

func LiveAnyPackageFunctionNames(path string) []string {
    if IsStdlibImportPath(path) {
        return []string{}
    }
    LiveEnsurePackage(path)
    return LivePackageFunctionNames(path)
}

func LiveAnyPackageMemberNames(path string) []string {
    if IsStdlibImportPath(path) {
        return []string{}
    }
    LiveEnsurePackage(path)
    return LivePackageMemberNames(path)
}

func LiveAnyPackageMemberType(path string, name string) string {
    if IsStdlibImportPath(path) {
        return ""
    }
    LiveEnsurePackage(path)
    return NormalizeInteropTypeName(LivePackageMemberType(path, name))
}

func LiveAnyPackageFuncPrototype(path string, name string) Option[FuncInfo] {
    if IsStdlibImportPath(path) {
        return None[FuncInfo]()
    }
    LiveEnsurePackage(path)
    return NormalizeResolvedFuncInfoOption(LivePackageFuncPrototype(path, name))
}

func LiveAnyPackageFuncSig(path string, name string, argCount int) Option[FuncInfo] {
    if IsStdlibImportPath(path) {
        return None[FuncInfo]()
    }
    LiveEnsurePackage(path)
    return NormalizeResolvedFuncInfoOption(LivePackageFuncSig(path, name, argCount))
}

func LiveAnyMethodNames(receiverType string) []string {
    return LiveMethodNames(LiveCanonicalReceiverType(receiverType))
}

func LiveAnyMethodPrototype(receiverType string, name string) Option[FuncInfo] {
    return NormalizeResolvedFuncInfoOption(LiveMethodPrototype(LiveCanonicalReceiverType(receiverType), name))
}

func LiveAnyMethodSig(receiverType string, name string, argCount int) Option[FuncInfo] {
    return NormalizeResolvedFuncInfoOption(LiveMethodSig(LiveCanonicalReceiverType(receiverType), name, argCount))
}

func LiveAnyStructFieldNames(typeName string) []string {
    return LiveStructFieldNames(LiveCanonicalTypeOrSelf(typeName))
}

func LiveAnyStructFieldType(typeName string, fieldName string) string {
    return NormalizeInteropTypeName(LiveStructFieldType(LiveCanonicalTypeOrSelf(typeName), fieldName))
}

func LiveAnyHasStructType(typeName string) bool {
    return len(LiveAnyStructFieldNames(typeName)) > 0
}

func LiveAnyInterfaceMethods(interfaceType string) []FuncInfo {
    return NormalizeResolvedFuncInfos(LiveInterfaceMethods(LiveCanonicalTypeOrSelf(interfaceType)), 0, []FuncInfo{})
}

func LiveAnyNamedUnderlyingType(typeName string) string {
    return NormalizeInteropTypeName(LiveNamedUnderlyingType(LiveCanonicalTypeOrSelf(typeName)))
}

func LiveAnyCanonicalTypeName(typeName string) string {
    return LiveEnsureCanonicalType(typeName)
}

func LiveCanonicalTypeOrSelf(typeName string) string {
    canonical := LiveEnsureCanonicalType(typeName)
    if canonical == "" {
        return typeName
    }
    return canonical
}

func LiveCanonicalReceiverType(typeName string) string {
    if strings.HasPrefix(typeName, "*") {
        canonical := LiveEnsureCanonicalType(strings.TrimPrefix(typeName, "*"))
        if canonical == "" {
            return typeName
        }
        return "*" + canonical
    }
    return LiveCanonicalTypeOrSelf(typeName)
}

func LiveEnsureCanonicalType(typeName string) string {
    canonical := LiveCanonicalKnownType(typeName)
    if canonical == "" {
        return ""
    }
    owner := LiveKnownTypeOwner(canonical)
    if !(owner == "") {
        if !IsStdlibImportPath(owner) {
            LiveEnsurePackage(owner)
        }
    }
    return canonical
}

func LiveCanonicalKnownType(typeName string) string {
    key := LiveNormalizeOwnerType(typeName)
    if !(LiveKnownTypeOwner(key) == "") {
        return key
    }
    dot := strings.LastIndex(key, ".")
    if dot < 0 {
        return ""
    }
    suffix := SliceString(key, dot, len(key))
    return LiveUniqueKnownTypeWithSuffix(suffix, LiveKnownTypeNames(), 0, "", false)
}

func LiveUniqueKnownTypeWithSuffix(suffix string, names []string, idx int, found string, ambiguous bool) string {
    if idx >= len(names) {
        if ambiguous {
            return ""
        }
        return found
    }
    current := names[idx]
    if strings.HasSuffix(current, suffix) {
        if found == "" {
            return LiveUniqueKnownTypeWithSuffix(suffix, names, idx + 1, current, ambiguous)
        }
        if !(found == current) {
            return LiveUniqueKnownTypeWithSuffix(suffix, names, idx + 1, found, true)
        }
    }
    return LiveUniqueKnownTypeWithSuffix(suffix, names, idx + 1, found, ambiguous)
}

func LiveNormalizeOwnerType(typeName string) string {
    if strings.HasPrefix(typeName, "*") {
        return LiveNormalizeOwnerType(strings.TrimPrefix(typeName, "*"))
    }
    idx := strings.Index(typeName, "[")
    if idx >= 0 {
        return PrefixString(typeName, idx)
    }
    return typeName
}

func QualifiedTypeQualifier(typeName string) string {
    idx := strings.Index(typeName, ".")
    if idx < 0 {
        return ""
    }
    return PrefixString(typeName, idx)
}

func QualifiedTypeSuffix(typeName string) string {
    idx := strings.LastIndex(typeName, ".")
    if idx < 0 {
        return typeName
    }
    return SliceString(typeName, idx + 1, len(typeName))
}

func BindExplicitTypeArgsForInfo(info FuncInfo, typeArgs []ast.TypeExpr) []TypeBinding {
    if len(info.TypeParams) == 0 {
        return BindExplicitTypeArgs(CollectTypeVariables(info.ParamTypes, info.ResultTypes), typeArgs, 0, []TypeBinding{})
    }
    return BindExplicitTypeArgs(info.TypeParams, typeArgs, 0, []TypeBinding{})
}

func BindExplicitTypeArgs(typeVars []string, typeArgs []ast.TypeExpr, idx int, bindings []TypeBinding) []TypeBinding {
    if idx >= len(typeVars) {
        return bindings
    }
    if idx >= len(typeArgs) {
        return bindings
    }
    next := AddTypeBinding(bindings, typeVars[idx], TypeExprName(typeArgs[idx]))
    return BindExplicitTypeArgs(typeVars, typeArgs, idx + 1, next)
}

func CollectTypeVariables(params []string, results []string) []string {
    fromParams := CollectTypeVariablesFromTypes(params, 0, []string{})
    return CollectTypeVariablesFromTypes(results, 0, fromParams)
}

func CollectTypeVariablesFromTypes(items []string, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    next := CollectTypeVariablesFromType(items[idx], acc)
    return CollectTypeVariablesFromTypes(items, idx + 1, next)
}

func CollectTypeVariablesFromType(typeName string, acc []string) []string {
    if typeName == "" {
        return acc
    }
    if IsTypeVariableName(typeName) {
        return AppendUniqueString(acc, typeName)
    }
    if HasSlicePrefix(typeName) {
        return CollectTypeVariablesFromType(TrimSlicePrefix(typeName), acc)
    }
    if HasMapPrefix(typeName) {
        keyNext := CollectTypeVariablesFromType(MapKeyTypeName(typeName), acc)
        return CollectTypeVariablesFromType(MapValueTypeName(typeName), keyNext)
    }
    if HasTupleEnvelope(typeName) {
        return CollectTypeVariablesFromTypes(ParseTupleTypeNames(typeName), 0, acc)
    }
    return CollectTypeVariablesFromTypes(ParseNamedTypeArgs(typeName), 0, acc)
}

func AppendUniqueString(items []string, value string) []string {
    if StringIn(items, value) {
        return items
    }
    return append(items, value)
}

func InferTypeBindings(expected []string, args []ast.Expr, idx int, bindings []TypeBinding, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) []TypeBinding {
    if idx >= len(expected) {
        return bindings
    }
    if idx >= len(args) {
        return bindings
    }
    got := InferExprTypeNameFromEnv(args[idx], env, enums, structs, funcs, methods)
    next := BindTypeVars(expected[idx], got, bindings)
    return InferTypeBindings(expected, args, idx + 1, next, env, enums, structs, funcs, methods)
}

func BindTypeVars(expected string, got string, bindings []TypeBinding) []TypeBinding {
    expectedNorm := NormalizeInteropTypeName(expected)
    gotNorm := NormalizeInteropTypeName(got)
    if expectedNorm == "" || gotNorm == "" {
        return bindings
    }
    if IsTypeVariableName(expectedNorm) {
        return AddTypeBinding(bindings, expectedNorm, gotNorm)
    }
    if HasSlicePrefix(expectedNorm) {
        if HasSlicePrefix(gotNorm) {
            return BindTypeVars(TrimSlicePrefix(expectedNorm), TrimSlicePrefix(gotNorm), bindings)
        }
        return bindings
    }
    if HasMapPrefix(expectedNorm) {
        if HasMapPrefix(gotNorm) {
            return BindMapTypes(expectedNorm, gotNorm, bindings)
        }
        return bindings
    }
    if HasFuncType(expectedNorm) {
        if HasFuncType(gotNorm) {
            return BindFuncTypes(expectedNorm, gotNorm, bindings)
        }
        return bindings
    }
    if HasTupleEnvelope(expectedNorm) {
        if HasTupleEnvelope(gotNorm) {
            return BindTupleTypes(ParseTupleTypeNames(expectedNorm), ParseTupleTypeNames(gotNorm), 0, bindings)
        }
        return bindings
    }
    expectedBase := BaseTypeName(expectedNorm)
    gotBase := BaseTypeName(gotNorm)
    expectedArgs := ParseNamedTypeArgs(expectedNorm)
    gotArgs := ParseNamedTypeArgs(gotNorm)
    if expectedBase == gotBase {
        if len(expectedArgs) == len(gotArgs) {
            if len(expectedArgs) > 0 {
                return BindTupleTypes(expectedArgs, gotArgs, 0, bindings)
            }
        }
    }
    return bindings
}

func BindFuncTypes(expected string, got string, bindings []TypeBinding) []TypeBinding {
    expectedParams := FuncTypeParamTypeNames(expected)
    gotParams := FuncTypeParamTypeNames(got)
    if !(len(expectedParams) == len(gotParams)) {
        return bindings
    }
    expectedResults := FuncTypeResultTypeNames(expected)
    gotResults := FuncTypeResultTypeNames(got)
    if !(len(expectedResults) == len(gotResults)) {
        return bindings
    }
    next := BindTupleTypes(expectedParams, gotParams, 0, bindings)
    return BindTupleTypes(expectedResults, gotResults, 0, next)
}

func BindMapTypes(expected string, got string, bindings []TypeBinding) []TypeBinding {
    keyExpected := MapKeyTypeName(expected)
    valueExpected := MapValueTypeName(expected)
    keyGot := MapKeyTypeName(got)
    valueGot := MapValueTypeName(got)
    next := BindTypeVars(keyExpected, keyGot, bindings)
    return BindTypeVars(valueExpected, valueGot, next)
}

func BindTupleTypes(expected []string, got []string, idx int, bindings []TypeBinding) []TypeBinding {
    if idx >= len(expected) {
        return bindings
    }
    if idx >= len(got) {
        return bindings
    }
    next := BindTypeVars(expected[idx], got[idx], bindings)
    return BindTupleTypes(expected, got, idx + 1, next)
}

func AddTypeBinding(bindings []TypeBinding, name string, typeName string) []TypeBinding {
    found := LookupTypeBinding(bindings, name)
    if found == "" {
        return append(bindings, TypeBinding{
            Name: name,
            TypeName: typeName,
        })
    }
    return bindings
}

func LookupTypeBinding(bindings []TypeBinding, name string) string {
    if len(bindings) == 0 {
        return ""
    }
    if bindings[0].Name == name {
        return bindings[0].TypeName
    }
    return LookupTypeBinding(bindings[1:], name)
}

func SubstituteTypeVars(typeName string, bindings []TypeBinding) string {
    if typeName == "" {
        return ""
    }
    if IsTypeVariableName(typeName) {
        found := LookupTypeBinding(bindings, typeName)
        if found == "" {
            return typeName
        }
        return found
    }
    if HasSlicePrefix(typeName) {
        return "[]" + SubstituteTypeVars(TrimSlicePrefix(typeName), bindings)
    }
    if HasMapPrefix(typeName) {
        return "map[" + SubstituteTypeVars(MapKeyTypeName(typeName), bindings) + "]" + SubstituteTypeVars(MapValueTypeName(typeName), bindings)
    }
    if HasTupleEnvelope(typeName) {
        return "(" + JoinSubstitutedTypeNames(ParseTupleTypeNames(typeName), bindings, 0) + ")"
    }
    base := BaseTypeName(typeName)
    args := ParseNamedTypeArgs(typeName)
    if len(args) == 0 {
        return typeName
    }
    return base + "[" + JoinSubstitutedTypeNames(args, bindings, 0) + "]"
}

func JoinSubstitutedTypeNames(items []string, bindings []TypeBinding, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := SubstituteTypeVars(items[idx], bindings)
    if idx + 1 >= len(items) {
        return head
    }
    return head + ", " + JoinSubstitutedTypeNames(items, bindings, idx + 1)
}

func JoinResultTypes(items []string, bindings []TypeBinding, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := SubstituteTypeVars(items[idx], bindings)
    if idx + 1 >= len(items) {
        return head
    }
    return head + ", " + JoinResultTypes(items, bindings, idx + 1)
}

func IsTypeVariableName(typeName string) bool {
    if len(typeName) == 0 {
        return false
    }
    head := typeName[0]
    if head < "A"[0] || head > "Z"[0] {
        return false
    }
    return IsTypeVariableTail(typeName, 1)
}

func IsTypeVariableTail(typeName string, idx int) bool {
    if idx >= len(typeName) {
        return true
    }
    ch := typeName[idx]
    if ch >= "A"[0] {
        if ch <= "Z"[0] {
            return IsTypeVariableTail(typeName, idx + 1)
        }
    }
    if ch >= "a"[0] {
        if ch <= "z"[0] {
            return IsTypeVariableTail(typeName, idx + 1)
        }
    }
    if ch >= "0"[0] {
        if ch <= "9"[0] {
            return IsTypeVariableTail(typeName, idx + 1)
        }
    }
    return false
}

func BaseTypeName(typeName string) string {
    if typeName == "" {
        return ""
    }
    if HasSlicePrefix(typeName) || HasMapPrefix(typeName) || HasTupleEnvelope(typeName) || typeName == "func" {
        return typeName
    }
    idx := FirstBracketIndex(typeName, 0)
    if idx < 0 {
        return typeName
    }
    return PrefixString(typeName, idx)
}

func ParseNamedTypeArgs(typeName string) []string {
    if typeName == "" {
        return []string{}
    }
    if HasSlicePrefix(typeName) || HasMapPrefix(typeName) || HasTupleEnvelope(typeName) || typeName == "func" {
        return []string{}
    }
    start := FirstBracketIndex(typeName, 0)
    if start < 0 {
        return []string{}
    }
    return SplitTopLevelComma(TrimOuterBrackets(typeName, start))
}

func FirstBracketIndex(value string, idx int) int {
    if idx >= len(value) {
        return -1
    }
    if value[idx] == "["[0] {
        return idx
    }
    return FirstBracketIndex(value, idx + 1)
}

func TrimOuterBrackets(value string, start int) string {
    if start + 1 >= len(value) {
        return ""
    }
    return SliceString(value, start + 1, len(value) - 1)
}

func SplitTopLevelComma(value string) []string {
    return SplitTopLevelCommaLoop(value, 0, 0, 0, []string{})
}

func SplitTopLevelCommaLoop(value string, idx int, start int, depth int, acc []string) []string {
    if idx >= len(value) {
        tail := strings.TrimSpace(SliceString(value, start, len(value)))
        if tail == "" {
            return acc
        }
        return append(acc, tail)
    }
    ch := value[idx]
    if ch == "["[0] || ch == "("[0] {
        return SplitTopLevelCommaLoop(value, idx + 1, start, depth + 1, acc)
    }
    if ch == "]"[0] || ch == ")"[0] {
        return SplitTopLevelCommaLoop(value, idx + 1, start, depth - 1, acc)
    }
    if ch == ","[0] {
        if depth == 0 {
            head := strings.TrimSpace(SliceString(value, start, idx))
            if head == "" {
                return SplitTopLevelCommaLoop(value, idx + 1, idx + 1, depth, acc)
            }
            return SplitTopLevelCommaLoop(value, idx + 1, idx + 1, depth, append(acc, head))
        }
    }
    return SplitTopLevelCommaLoop(value, idx + 1, start, depth, acc)
}

func HasMapPrefix(typeName string) bool {
    return strings.HasPrefix(typeName, "map[")
}

func MapKeyTypeName(typeName string) string {
    return ParseMapTypeName(typeName, true)
}

func MapValueTypeName(typeName string) string {
    return ParseMapTypeName(typeName, false)
}

func ParseMapTypeName(typeName string, wantKey bool) string {
    close := MapKeyCloseIndex(typeName, 4, 0)
    if close < 0 {
        return ""
    }
    if wantKey {
        return strings.TrimSpace(SliceString(typeName, 4, close))
    }
    return strings.TrimSpace(SliceString(typeName, close + 1, len(typeName)))
}

func MapKeyCloseIndex(typeName string, idx int, depth int) int {
    if idx >= len(typeName) {
        return -1
    }
    ch := typeName[idx]
    if ch == "["[0] {
        return MapKeyCloseIndex(typeName, idx + 1, depth + 1)
    }
    if ch == "]"[0] {
        if depth == 0 {
            return idx
        }
        return MapKeyCloseIndex(typeName, idx + 1, depth - 1)
    }
    return MapKeyCloseIndex(typeName, idx + 1, depth)
}

func TupleExprTypeNameFromEnv(items []ast.Expr, idx int, acc []string, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) string {
    if idx >= len(items) {
        return "(" + JoinStrings(acc, 0) + ")"
    }
    got := InferExprTypeNameFromEnv(items[idx], env, enums, structs, funcs, methods)
    if got == "" {
        return ""
    }
    return TupleExprTypeNameFromEnv(items, idx + 1, append(acc, got), env, enums, structs, funcs, methods)
}

func CallResultTypeForName(name string, funcs []FuncInfo) string {
    info := ResolveFuncSig(funcs, name)
    if !isNone[FuncInfo](info) {
        item := unwrapOr[FuncInfo](info, EmptyFuncInfo())
        if len(item.ResultTypes) == 1 {
            return item.ResultTypes[0]
        }
        if len(item.ResultTypes) > 1 {
            return "(" + JoinStrings(item.ResultTypes, 0) + ")"
        }
        return ""
    }
    return ""
}

func MethodResultTypeForName(receiverType string, name string, methods []MethodInfo) string {
    info := FindMethodInfo(methods, receiverType, name)
    if !isNone[MethodInfo](info) {
        item := unwrapOr[MethodInfo](info, EmptyMethodInfo())
        if len(item.ResultTypes) == 1 {
            return item.ResultTypes[0]
        }
        if len(item.ResultTypes) > 1 {
            return "(" + JoinStrings(item.ResultTypes, 0) + ")"
        }
        return ""
    }
    return ""
}

func JoinStrings(items []string, idx int) string {
    if idx >= len(items) {
        return ""
    }
    if idx + 1 >= len(items) {
        return items[idx]
    }
    return items[idx] + ", " + JoinStrings(items, idx + 1)
}

func EntryLabel(entry NameEntry) string {
    return entry.Kind + " '" + entry.Name + "'"
}

func StructFieldNames(typeName string, structs []StructInfo) []string {
    normalized := NormalizeStructLikeType(typeName)
    info := FindStructInfo(structs, normalized)
    if isNone[StructInfo](info) {
        liveNames := LiveAnyStructFieldNames(normalized)
        if len(liveNames) > 0 {
            return liveNames
        }
        return StdlibStructFieldNames(normalized)
    }
    item := unwrapOr[StructInfo](info, EmptyStructInfo())
    return StructFieldNamesFrom(item.Fields, 0, []string{})
}

func NormalizeStructLikeType(typeName string) string {
    if strings.HasPrefix(typeName, "*") {
        return NormalizeStructLikeType(TrimPointerPrefix(typeName))
    }
    return typeName
}

func StructFieldNamesFrom(fields []FieldTypeInfo, idx int, acc []string) []string {
    if idx >= len(fields) {
        return acc
    }
    return StructFieldNamesFrom(fields, idx + 1, append(acc, fields[idx].Name))
}

func StructFieldHint(typeName string, structs []StructInfo) string {
    names := StructFieldNames(typeName, structs)
    if len(names) == 0 {
        return ""
    }
    return "Available fields on " + typeName + ": " + JoinStrings(names, 0) + "."
}

func MethodNamesForReceiver(receiverType string, methods []MethodInfo, idx int, acc []string) []string {
    if idx >= len(methods) {
        return acc
    }
    item := methods[idx]
    if BaseTypeName(item.ReceiverType) == BaseTypeName(receiverType) {
        return MethodNamesForReceiver(receiverType, methods, idx + 1, append(acc, item.Name))
    }
    return MethodNamesForReceiver(receiverType, methods, idx + 1, acc)
}

func MethodHint(receiverType string, methods []MethodInfo) string {
    names := ReceiverAllMethodNames(receiverType, methods)
    if len(names) == 0 {
        return ""
    }
    return "Available methods on " + receiverType + ": " + JoinStrings(names, 0) + "."
}

func ConcatStrings(left []string, right []string, idx int) []string {
    if idx >= len(right) {
        return left
    }
    return ConcatStrings(append(left, right[idx]), right, idx + 1)
}

func ConcatUniqueStrings(left []string, right []string, idx int) []string {
    if idx >= len(right) {
        return left
    }
    return ConcatUniqueStrings(AppendUniqueStrings(left, right[idx]), right, idx + 1)
}

func AppendUniqueStrings(items []string, next string) []string {
    if next == "" {
        return items
    }
    if StringIn(items, next) {
        return items
    }
    return append(items, next)
}

func VisibleNames(entries []NameEntry, idx int, acc []string) []string {
    if idx >= len(entries) {
        return acc
    }
    return VisibleNames(entries, idx + 1, AppendUniqueStrings(acc, entries[idx].Name))
}

func FuncNames(items []FuncInfo, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return FuncNames(items, idx + 1, AppendUniqueStrings(acc, items[idx].Name))
}

func MemberHint(receiverType string, structs []StructInfo, methods []MethodInfo) string {
    fieldHint := StructFieldHint(receiverType, structs)
    methodHint := MethodHint(receiverType, methods)
    if fieldHint == "" {
        return methodHint
    }
    if methodHint == "" {
        return fieldHint
    }
    return fieldHint + " " + methodHint
}

func EnumVariantHint(typeName string, enums []EnumInfo) string {
    info := FindEnumInfo(enums, typeName)
    if isNone[EnumInfo](info) {
        return ""
    }
    item := unwrapOr[EnumInfo](info, EmptyEnumInfo())
    if len(item.Variants) == 0 {
        return ""
    }
    return "Valid variants for " + typeName + ": " + JoinStrings(item.Variants, 0) + "."
}

func UnknownNameHint(visible []NameEntry) string {
    names := VisibleNames(visible, 0, []string{})
    if len(names) == 0 {
        return "Declare the name before using it, or fix the spelling if this is a typo."
    }
    return "Available names in this scope include: " + JoinStrings(names, 0) + "."
}

func UnknownCallHint(candidates []string) string {
    if len(candidates) == 0 {
        return "Declare the function or constructor before calling it, or fix the spelling if this is a typo."
    }
    return "Known callable names here include: " + JoinStrings(candidates, 0) + "."
}

func IsTypoLikeSuggestion(target string, candidate string) bool {
    if target == "" || candidate == "" {
        return false
    }
    left := strings.ToLower(target)
    right := strings.ToLower(candidate)
    if left == right {
        return true
    }
    if HasAdjacentSwap(left, right, 0) {
        return true
    }
    if CommonPrefixLength(left, right, 0) >= 4 {
        if AbsInt(len(left) - len(right)) <= 2 {
            return true
        }
    }
    if SubsequenceLength(left, right, 0, 0) >= len(left) - 1 {
        if AbsInt(len(left) - len(right)) <= 2 {
            return true
        }
    }
    if strings.Contains(right, left) || strings.Contains(left, right) {
        if AbsInt(len(left) - len(right)) <= 1 {
            return true
        }
    }
    return false
}

func IsBuiltinName(name string) bool {
    if name == "nil" {
        return true
    }
    return false
}

func LooksLikeEnumSymbol(name string) bool {
    if name == "" {
        return false
    }
    ch := name[0]
    if ch >= "A"[0] {
        if ch <= "Z"[0] {
            return true
        }
    }
    return false
}

func IsBuiltinCallName(name string) bool {
    if name == "len" || name == "append" {
        return true
    }
    if !(BuiltinCallResultType(name) == "") {
        return true
    }
    return false
}

func BuiltinCallResultType(name string) string {
    if name == "string" || name == "int" || name == "byte" || name == "rune" || name == "bool" {
        return name
    }
    if name == "uint" || name == "uint32" || name == "uint64" || name == "int32" || name == "int64" {
        return name
    }
    if name == "float32" || name == "float64" {
        return name
    }
    return ""
}

func CallSignatureDetail(info FuncInfo) string {
    return info.Name + "(" + JoinSignatureParams(info.ParamNames, info.ParamTypes, 0, []string{}) + ") -> (" + JoinStrings(info.ResultTypes, 0) + ")"
}

func CallExampleShape(info FuncInfo, idx int, acc []string) string {
    if idx >= len(info.ParamTypes) {
        return info.Name + "(" + JoinStrings(acc, 0) + ")"
    }
    if idx < len(info.ParamNames) {
        if !(info.ParamNames[idx] == "") {
            return CallExampleShape(info, idx + 1, append(acc, "<" + info.ParamNames[idx] + ">"))
        }
    }
    return CallExampleShape(info, idx + 1, append(acc, "<arg" + IntString(idx + 1) + ">"))
}

func SuggestionReason(target string, suggestion string) string {
    if target == "" || suggestion == "" {
        return ""
    }
    left := strings.ToLower(target)
    right := strings.ToLower(suggestion)
    if HasAdjacentSwap(left, right, 0) {
        return "The suggested name swaps two adjacent letters compared with the misspelled name."
    }
    prefix := CommonPrefixLength(left, right, 0)
    if prefix >= 3 {
        return "The suggested name shares the same leading letters and is the closest available member by spelling."
    }
    if strings.Contains(right, left) || strings.Contains(left, right) {
        return "The suggested name is the closest available member by substring match."
    }
    if SubsequenceLength(left, right, 0, 0) >= len(left) - 1 {
        return "The suggested name differs by only a very small spelling change."
    }
    return "The suggested name is the closest available member by spelling."
}

func JoinSignatureParams(names []string, types []string, idx int, acc []string) string {
    if idx >= len(types) {
        return JoinStrings(acc, 0)
    }
    if idx < len(names) {
        if !(names[idx] == "") {
            return JoinSignatureParams(names, types, idx + 1, append(acc, names[idx] + " " + types[idx]))
        }
    }
    return JoinSignatureParams(names, types, idx + 1, append(acc, types[idx]))
}

func SuggestName(target string, candidates []string, idx int, best string, bestScore int) string {
    if idx >= len(candidates) {
        if bestScore <= 0 {
            return ""
        }
        return best
    }
    score := SuggestionScore(target, candidates[idx])
    if score > bestScore {
        return SuggestName(target, candidates, idx + 1, candidates[idx], score)
    }
    return SuggestName(target, candidates, idx + 1, best, bestScore)
}

func SuggestionScore(target string, candidate string) int {
    if target == "" || candidate == "" {
        return 0
    }
    left := strings.ToLower(target)
    right := strings.ToLower(candidate)
    if left == right {
        return 1000
    }
    if HasAdjacentSwap(left, right, 0) {
        return 80 - AbsInt(len(left) - len(right))
    }
    prefix := CommonPrefixLength(left, right, 0)
    subseq := SubsequenceLength(left, right, 0, 0)
    if prefix == 0 {
        if subseq < 2 {
            if !(strings.Contains(right, left) || strings.Contains(left, right)) {
                return 0
            }
        }
    }
    baseScore := prefix * 10 + subseq * 4
    containsScore := AddContainsBonus(baseScore, left, right)
    lengthScore := containsScore - AbsInt(len(left) - len(right))
    endingScore := AddEndsWithBonus(lengthScore, left, right)
    return AddStartsWithBonus(endingScore, left, right)
}

func AddContainsBonus(score int, left string, right string) int {
    if strings.Contains(right, left) || strings.Contains(left, right) {
        return score + 5
    }
    return score
}

func AddStartsWithBonus(score int, left string, right string) int {
    if strings.HasPrefix(right, string(left[0])) {
        return score + 3
    }
    return score
}

func AddEndsWithBonus(score int, left string, right string) int {
    if len(left) == 0 || len(right) == 0 {
        return score
    }
    if left[len(left) - 1] == right[len(right) - 1] {
        return score + 2
    }
    return score
}

func CommonPrefixLength(left string, right string, idx int) int {
    if idx >= len(left) || idx >= len(right) {
        return idx
    }
    if !(left[idx] == right[idx]) {
        return idx
    }
    return CommonPrefixLength(left, right, idx + 1)
}

func AbsInt(value int) int {
    if value < 0 {
        return -value
    }
    return value
}

func HasAdjacentSwap(left string, right string, idx int) bool {
    if len(left) == len(right) {
        if idx + 1 >= len(left) {
            return false
        }
        if left[idx] == right[idx] {
            return HasAdjacentSwap(left, right, idx + 1)
        }
        if left[idx] == right[idx + 1] {
            if left[idx + 1] == right[idx] {
                return TailEquals(left, right, idx + 2)
            }
        }
    }
    return false
}

func TailEquals(left string, right string, idx int) bool {
    if idx >= len(left) {
        return true
    }
    if !(left[idx] == right[idx]) {
        return false
    }
    return TailEquals(left, right, idx + 1)
}

func LookupSubsequenceMemo(memo []SubsequenceMemoEntry, leftIdx int, rightIdx int, idx int) int {
    if idx >= len(memo) {
        return -1
    }
    if memo[idx].LeftIdx == leftIdx {
        if memo[idx].RightIdx == rightIdx {
            return memo[idx].Value
        }
    }
    return LookupSubsequenceMemo(memo, leftIdx, rightIdx, idx + 1)
}

func SubsequenceLengthMemo(left string, right string, leftIdx int, rightIdx int, memo []SubsequenceMemoEntry) SubsequenceMemoResult {
    cached := LookupSubsequenceMemo(memo, leftIdx, rightIdx, 0)
    if cached >= 0 {
        return SubsequenceMemoResult{
            Value: cached,
            Memo: memo,
        }
    }
    if leftIdx >= len(left) || rightIdx >= len(right) {
        return SubsequenceMemoResult{
            Value: 0,
            Memo: append(memo, SubsequenceMemoEntry{
                LeftIdx: leftIdx,
                RightIdx: rightIdx,
                Value: 0,
            }),
        }
    }
    if left[leftIdx] == right[rightIdx] {
        next := SubsequenceLengthMemo(left, right, leftIdx + 1, rightIdx + 1, memo)
        value := 1 + next.Value
        return SubsequenceMemoResult{
            Value: value,
            Memo: append(next.Memo, SubsequenceMemoEntry{
                LeftIdx: leftIdx,
                RightIdx: rightIdx,
                Value: value,
            }),
        }
    }
    skipRight := SubsequenceLengthMemo(left, right, leftIdx, rightIdx + 1, memo)
    skipLeft := SubsequenceLengthMemo(left, right, leftIdx + 1, rightIdx, skipRight.Memo)
    if skipRight.Value > skipLeft.Value {
        return SubsequenceMemoResult{
            Value: skipRight.Value,
            Memo: append(skipLeft.Memo, SubsequenceMemoEntry{
                LeftIdx: leftIdx,
                RightIdx: rightIdx,
                Value: skipRight.Value,
            }),
        }
    }
    return SubsequenceMemoResult{
        Value: skipLeft.Value,
        Memo: append(skipLeft.Memo, SubsequenceMemoEntry{
            LeftIdx: leftIdx,
            RightIdx: rightIdx,
            Value: skipLeft.Value,
        }),
    }
}

func SubsequenceLength(left string, right string, leftIdx int, rightIdx int) int {
    return SubsequenceLengthMemo(left, right, leftIdx, rightIdx, []SubsequenceMemoEntry{}).Value
}

func MaybeSuggestionText(value string) string {
    if value == "" {
        return ""
    }
    return "'" + value + "'"
}

func CheckSemanticExprs(exprs []ast.Expr, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(exprs) {
        return diag
    }
    next := CheckSemanticExpr(exprs[idx], diag, env, enums, structs, interfaces, funcs, methods)
    return CheckSemanticExprs(exprs, idx + 1, next, env, enums, structs, interfaces, funcs, methods)
}

func CheckSemanticExpr(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if ast.ExprIsMake(expr) {
        return CheckMakeExpr(expr, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsCall(expr) {
        checkedArgs := CheckSemanticExprs(ast.ExprCallArgs(expr), 0, diag, env, enums, structs, interfaces, funcs, methods)
        return CheckCallSignature(expr, checkedArgs, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsBinary(expr) {
        left := CheckSemanticExpr(ast.ExprBinaryLeft(expr), diag, env, enums, structs, interfaces, funcs, methods)
        return CheckSemanticExpr(ast.ExprBinaryRight(expr), left, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsUnary(expr) {
        return CheckSemanticExpr(ast.ExprUnaryOperand(expr), diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsPipeline(expr) {
        left := CheckSemanticExpr(ast.ExprPipelineLeft(expr), diag, env, enums, structs, interfaces, funcs, methods)
        return CheckSemanticExpr(ast.ExprPipelineRight(expr), left, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsSelector(expr) {
        checked := CheckSemanticExpr(ast.ExprSelectorTarget(expr), diag, env, enums, structs, interfaces, funcs, methods)
        recvType := CanonicalTypeNameWithEnv(InferExprTypeNameFromEnv(ast.ExprSelectorTarget(expr), env, enums, structs, funcs, methods), env)
        fieldName := ast.ExprSelectorField(expr)
        if recvType == "" {
            return checked
        }
        if IsPackageRefType(recvType) {
            path := PackageRefPath(recvType)
            if !(ResolvePackageValueType(path, fieldName) == "") {
                return checked
            }
            names := AnyPackageNames(path)
            if len(names) > 0 {
                suggestion := SuggestName(fieldName, names, 0, "", 0)
                if IsTypoLikeSuggestion(fieldName, suggestion) {
                    return checked.ErrorDetailedSuggested(
                        diagnostic.TypeErrorCategory(),
                        expr.TokenPos(),
                        "FTYPE056",
                        "unknown selector "+fieldName+" on package "+path,
                        "The selector does not resolve to an exported package symbol in " + path + ". " + SuggestionReason(fieldName, suggestion),
                        MaybeSuggestionText(suggestion),
                        "Known exported names in " + path + " include: " + JoinStrings(names, 0) + ".",
                    )
                }
            }
            return checked
        }
        if !(FieldTypeForStruct(recvType, fieldName, structs) == "") {
            return checked
        }
        if !isNone[MethodInfo](FindMethodInfo(methods, recvType, fieldName)) {
            return checked
        }
        methodNames := ReceiverAllMethodNames(recvType, methods)
        if len(methodNames) > 0 {
            if StringIn(methodNames, fieldName) {
                return checked
            }
        }
        if !IsKnownStructType(recvType, structs) {
            return checked
        }
        members := ConcatStrings(StructFieldNames(recvType, structs), methodNames, 0)
        suggestion := SuggestName(fieldName, members, 0, "", 0)
        return checked.ErrorDetailedSuggested(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE055",
            "unknown selector "+fieldName+" on "+recvType,
            "The selector does not resolve to a field or method on the receiver type. " + SuggestionReason(fieldName, suggestion),
            MaybeSuggestionText(suggestion),
            MemberHint(recvType, structs, methods),
        )
    }
    if ast.ExprIsIndex(expr) {
        left := CheckSemanticExpr(ast.ExprIndexTarget(expr), diag, env, enums, structs, interfaces, funcs, methods)
        return CheckSemanticExpr(ast.ExprIndexValue(expr), left, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsSlice(expr) {
        left := CheckSemanticExpr(ast.ExprSliceTarget(expr), diag, env, enums, structs, interfaces, funcs, methods)
        low := CheckOptionalExprSemantic(ast.ExprSliceLow(expr), left, env, enums, structs, interfaces, funcs, methods)
        return CheckOptionalExprSemantic(ast.ExprSliceHigh(expr), low, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsMapLit(expr) {
        return CheckMapLiteralExpr(expr, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsStructLit(expr) {
        return CheckStructLiteralExpr(expr, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsCopyUpdate(expr) {
        return CheckCopyUpdateExpr(expr, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsSliceLit(expr) {
        return CheckSemanticExprs(ast.ExprSliceLitElems(expr), 0, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsFuncLit(expr) {
        return CheckSemanticBlock(
            ast.ExprFuncLitBody(expr),
            ast.ExprFuncLitResults(expr),
            diag,
            ParamTypeEnv(ast.ExprFuncLitParams(expr), 0, env),
            enums,
            structs,
            interfaces,
            funcs,
            methods,
        )
    }
    return diag
}

func CheckMakeExpr(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    checked := CheckSemanticExprs(ast.ExprMakeArgs(expr), 0, diag, env, enums, structs, interfaces, funcs, methods)
    typeName := TypeExprName(ast.ExprMakeType(expr))
    target := MakeTargetTypeName(typeName)
    if target == "" {
        return checked.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE067",
            "make requires a slice, map, or chan type, got "+typeName,
            "The built-in make only constructs slices, maps, chans, or named stdlib types whose underlying type is one of those kinds.",
            "Use make with []T, map[K]V, chan T, or a compatible named stdlib type.",
        )
    }
    args := ast.ExprMakeArgs(expr)
    if MakeTargetKind(target) == "slice" {
        return CheckMakeSliceArgs(expr, args, checked, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckMakeSizedArgs(expr, args, checked, env, enums, structs, interfaces, funcs, methods)
}

func MakeTargetTypeName(typeName string) string {
    if HasSlicePrefix(typeName) || HasMapPrefix(typeName) || HasChanPrefix(typeName) {
        return typeName
    }
    underlying := StdlibNamedUnderlyingType(typeName)
    if underlying == "" {
        return ""
    }
    if HasSlicePrefix(underlying) || HasMapPrefix(underlying) || HasChanPrefix(underlying) {
        return underlying
    }
    return ""
}

func MakeTargetKind(typeName string) string {
    if HasSlicePrefix(typeName) {
        return "slice"
    }
    if HasMapPrefix(typeName) {
        return "map"
    }
    if HasChanPrefix(typeName) {
        return "chan"
    }
    return ""
}

func HasChanPrefix(typeName string) bool {
    return strings.HasPrefix(typeName, "chan ") || strings.HasPrefix(typeName, "<-chan ")
}

func CheckMakeSliceArgs(expr ast.Expr, args []ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if len(args) < 1 || len(args) > 2 {
        return diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE068",
            "make on slice expects 1 or 2 size arguments, got "+IntString(len(args)),
            "Slice construction with make expects a length and an optional capacity.",
            "Use make([]T, len) or make([]T, len, cap).",
        )
    }
    return CheckMakeSizeArgTypes(args, 0, diag, env, enums, structs, interfaces, funcs, methods)
}

func CheckMakeSizedArgs(expr ast.Expr, args []ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if len(args) > 1 {
        return diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE069",
            "make on map or chan expects at most 1 size argument, got "+IntString(len(args)),
            "Map and chan construction with make takes an optional size hint.",
            "Use make(map[K]V) / make(map[K]V, n) or make(chan T) / make(chan T, n).",
        )
    }
    return CheckMakeSizeArgTypes(args, 0, diag, env, enums, structs, interfaces, funcs, methods)
}

func CheckMakeSizeArgTypes(args []ast.Expr, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(args) {
        return diag
    }
    got := InferExprTypeNameFromEnv(args[idx], env, enums, structs, funcs, methods)
    if !(got == "") {
        if !ArgumentTypeCompatible("int", got, interfaces, methods) {
            return diag.ErrorDetailed(
                diagnostic.TypeErrorCategory(),
                args[idx].TokenPos(),
                "FTYPE070",
                "make size argument must be int, got "+got,
                "The built-in make expects integer size arguments.",
                "Change this argument so it produces int.",
            )
        }
    }
    return CheckMakeSizeArgTypes(args, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
}

func CheckMapLiteralExpr(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    keyType := MapLiteralKeyTypeName(expr)
    valueType := MapLiteralValueTypeName(expr)
    return CheckMapEntries(ast.ExprMapLitEntries(expr), keyType, valueType, 0, diag, env, enums, structs, interfaces, funcs, methods)
}

func MapLiteralKeyTypeName(expr ast.Expr) string {
    named := ast.ExprMapLitTypeName(expr)
    if !(named == "") {
        underlying := StdlibNamedUnderlyingType(named)
        if HasMapPrefix(underlying) {
            return MapKeyTypeName(underlying)
        }
    }
    return TypeExprName(ast.ExprMapLitKeyType(expr))
}

func MapLiteralValueTypeName(expr ast.Expr) string {
    named := ast.ExprMapLitTypeName(expr)
    if !(named == "") {
        underlying := StdlibNamedUnderlyingType(named)
        if HasMapPrefix(underlying) {
            return MapValueTypeName(underlying)
        }
    }
    return TypeExprName(ast.ExprMapLitValueType(expr))
}

func CheckMapEntries(entries []ast.MapEntry, keyType string, valueType string, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(entries) {
        return diag
    }
    keyDiag := CheckSemanticExpr(entries[idx].Key, diag, env, enums, structs, interfaces, funcs, methods)
    valueDiag := CheckSemanticExpr(entries[idx].Value, keyDiag, env, enums, structs, interfaces, funcs, methods)
    gotKey := InferExprTypeNameFromEnv(entries[idx].Key, env, enums, structs, funcs, methods)
    gotValue := InferExprTypeNameFromEnv(entries[idx].Value, env, enums, structs, funcs, methods)
    keyChecked := CheckMapEntryKeyType(entries[idx], keyType, gotKey, valueDiag, interfaces, methods)
    nextDiag := CheckMapEntryValueType(entries[idx], valueType, gotValue, keyChecked, interfaces, methods)
    return CheckMapEntries(entries, keyType, valueType, idx + 1, nextDiag, env, enums, structs, interfaces, funcs, methods)
}

func CheckMapEntryKeyType(entry ast.MapEntry, expected string, got string, diag diagnostic.Diagnostics, interfaces []InterfaceInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if expected == "" || got == "" {
        return diag
    }
    if ArgumentTypeCompatible(expected, got, interfaces, methods) {
        return diag
    }
    return diag.ErrorDetailed(
        diagnostic.TypeErrorCategory(),
        ast.ExprPos(entry.Key),
        "FTYPE065",
        "map key type mismatch: expected "+expected+", got "+got,
        "The map literal key expression does not match the expected key type.",
        "",
    )
}

func CheckMapEntryValueType(entry ast.MapEntry, expected string, got string, diag diagnostic.Diagnostics, interfaces []InterfaceInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if expected == "" || got == "" {
        return diag
    }
    if ArgumentTypeCompatible(expected, got, interfaces, methods) {
        return diag
    }
    return diag.ErrorDetailed(
        diagnostic.TypeErrorCategory(),
        ast.ExprPos(entry.Value),
        "FTYPE066",
        "map value type mismatch: expected "+expected+", got "+got,
        "The map literal value expression does not match the expected value type.",
        "",
    )
}

func CheckStructLiteralExpr(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    checked := CheckFieldInitExprsSemantic(ast.ExprStructLitFields(expr), 0, diag, env, enums, structs, interfaces, funcs, methods)
    structType := ast.ExprStructLitType(expr)
    canonicalType := CanonicalTypeNameWithEnv(structType, env)
    if !IsKnownStructType(canonicalType, structs) {
        if len(ast.ExprStructLitFields(expr)) == 0 {
            underlying := StdlibNamedUnderlyingType(canonicalType)
            if underlying == "" {
                if HasMapPrefix(LiveAnyNamedUnderlyingType(canonicalType)) || HasSlicePrefix(LiveAnyNamedUnderlyingType(canonicalType)) {
                    return checked
                }
            }
            if HasMapPrefix(underlying) || HasSlicePrefix(underlying) {
                return checked
            }
        }
        pkgPath := PackagePathForQualifiedType(canonicalType, env)
        typeName := QualifiedTypeShortName(canonicalType)
        if !(pkgPath == "") {
            names := AnyPackageTypeNames(pkgPath)
            suggestion := SuggestName(typeName, names, 0, "", 0)
            return checked.ErrorDetailedSuggested(
                diagnostic.TypeErrorCategory(),
                expr.TokenPos(),
                "FTYPE049",
                "unknown struct type "+canonicalType,
                "The struct literal targets a package-qualified type that does not resolve to a known struct. " + SuggestionReason(typeName, suggestion),
                MaybeSuggestionText(suggestion),
                "Known exported names in " + pkgPath + " include: " + JoinStrings(names, 0) + ".",
            )
        }
        return checked.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE049",
            "unknown struct type "+canonicalType,
            "The struct literal targets a type that does not resolve to a known struct.",
            "",
        )
    }
    return CheckStructLiteralFields(ast.ExprStructLitFields(expr), canonicalType, 0, checked, env, enums, structs, interfaces, funcs, methods)
}

func CanonicalStructTypeOrSelf(typeName string) string {
    canonical := CanonicalStructTypeName(typeName)
    if canonical == "" {
        return typeName
    }
    return canonical
}

func CheckStructLiteralFields(fields []ast.FieldInit, structType string, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    name := ast.FieldInitNameValue(fields[idx])
    fieldType := FieldTypeForStruct(structType, name, structs)
    if fieldType == "" {
        suggestion := SuggestName(name, StructFieldNames(structType, structs), 0, "", 0)
        return CheckStructLiteralFields(
            fields,
            structType,
            idx + 1,
            diag.ErrorDetailedSuggested(
                diagnostic.TypeErrorCategory(),
                ast.FieldInitExprValue(fields[idx]).TokenPos(),
                "FTYPE050",
                "unknown field "+name+" on "+structType,
                "The struct literal initializes a field that is not declared on this struct type. " + SuggestionReason(name, suggestion),
                MaybeSuggestionText(suggestion),
                StructFieldHint(structType, structs),
            ),
            env,
            enums,
            structs,
            interfaces,
            funcs,
            methods,
        )
    }
    got := InferExprTypeNameFromEnv(ast.FieldInitExprValue(fields[idx]), env, enums, structs, funcs, methods)
    if got == "" {
        return CheckStructLiteralFields(fields, structType, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ArgumentTypeCompatible(fieldType, got, interfaces, methods) {
        return CheckStructLiteralFields(fields, structType, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckStructLiteralFields(
        fields,
        structType,
        idx + 1,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            ast.FieldInitExprValue(fields[idx]).TokenPos(),
            "FTYPE051",
            "field type mismatch for "+name+": expected "+fieldType+", got "+got,
            "The initializer expression type does not match the declared field type.",
            "",
        ),
        env,
        enums,
        structs,
        interfaces,
        funcs,
        methods,
    )
}

func CheckCopyUpdateExpr(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    base := CheckSemanticExpr(ast.ExprCopyUpdateSource(expr), diag, env, enums, structs, interfaces, funcs, methods)
    sourceType := InferExprTypeNameFromEnv(ast.ExprCopyUpdateSource(expr), env, enums, structs, funcs, methods)
    checked := CheckFieldUpdateExprsSemantic(ast.ExprCopyUpdateUpdates(expr), 0, base, env, enums, structs, interfaces, funcs, methods)
    if sourceType == "" {
        return checked
    }
    if !IsKnownStructType(sourceType, structs) {
        return checked.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            expr.TokenPos(),
            "FTYPE052",
            "copy-update requires a struct source, got "+sourceType,
            "Copy-update can only rebuild declared struct values.",
            "Use a struct literal or a value whose inferred type is a struct.",
        )
    }
    return CheckFieldUpdatePaths(ast.ExprCopyUpdateUpdates(expr), sourceType, 0, checked, env, enums, structs, interfaces, funcs, methods)
}

func CheckFieldUpdatePaths(fields []ast.FieldUpdate, structType string, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    path := ast.FieldUpdatePathValue(fields[idx])
    fieldType := ResolveFieldPathType(structType, path, structs)
    if fieldType == "" {
        suggestion := SuggestName(path[0], StructFieldNames(structType, structs), 0, "", 0)
        return CheckFieldUpdatePaths(
            fields,
            structType,
            idx + 1,
            diag.ErrorDetailedSuggested(
                diagnostic.TypeErrorCategory(),
                ast.FieldUpdateExprValue(fields[idx]).TokenPos(),
                "FTYPE053",
                "unknown update path "+JoinStrings(path, 0)+" on "+structType,
                "The copy-update path does not resolve against the source struct type. " + SuggestionReason(path[0], suggestion),
                MaybeSuggestionText(suggestion),
                StructFieldHint(structType, structs),
            ),
            env,
            enums,
            structs,
            interfaces,
            funcs,
            methods,
        )
    }
    got := InferExprTypeNameFromEnv(ast.FieldUpdateExprValue(fields[idx]), env, enums, structs, funcs, methods)
    if got == "" {
        return CheckFieldUpdatePaths(fields, structType, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ArgumentTypeCompatible(fieldType, got, interfaces, methods) {
        return CheckFieldUpdatePaths(fields, structType, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckFieldUpdatePaths(
        fields,
        structType,
        idx + 1,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            ast.FieldUpdateExprValue(fields[idx]).TokenPos(),
            "FTYPE054",
            "update type mismatch for "+JoinStrings(path, 0)+": expected "+fieldType+", got "+got,
            "The assigned update value does not match the resolved field-path type.",
            "",
        ),
        env,
        enums,
        structs,
        interfaces,
        funcs,
        methods,
    )
}

func CheckOptionalExprSemantic(value Option[ast.Expr], diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if ast.ExprOptionIsNone(value) {
        return diag
    }
    return CheckSemanticExpr(ast.ExprOptionValue(value), diag, env, enums, structs, interfaces, funcs, methods)
}

func CheckFieldInitExprsSemantic(fields []ast.FieldInit, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    next := CheckSemanticExpr(ast.FieldInitExprValue(fields[idx]), diag, env, enums, structs, interfaces, funcs, methods)
    return CheckFieldInitExprsSemantic(fields, idx + 1, next, env, enums, structs, interfaces, funcs, methods)
}

func CheckFieldUpdateExprsSemantic(fields []ast.FieldUpdate, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    next := CheckSemanticExpr(ast.FieldUpdateExprValue(fields[idx]), diag, env, enums, structs, interfaces, funcs, methods)
    return CheckFieldUpdateExprsSemantic(fields, idx + 1, next, env, enums, structs, interfaces, funcs, methods)
}

func CheckCallSignature(expr ast.Expr, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    fn := ast.ExprCallFunc(expr)
    if ast.ExprIsIdent(fn) {
        name := ast.ExprIdentName(fn)
        if IsBuiltinCallName(name) {
            return diag
        }
        if !(LookupTypeEnv(env, name) == "") {
            return diag
        }
        sig := ResolveFuncSig(funcs, name)
        if isNone[FuncInfo](sig) {
            candidates := FuncNames(funcs, 0, []string{})
            suggestion := SuggestName(name, candidates, 0, "", 0)
            if !IsTypoLikeSuggestion(name, suggestion) {
                return diag
            }
            return diag.ErrorDetailedSuggested(
                diagnostic.TypeErrorCategory(),
                expr.TokenPos(),
                "FTYPE063",
                "unknown call target "+name,
                "The call does not resolve to a declared function or enum constructor.",
                MaybeSuggestionText(suggestion),
                UnknownCallHint(candidates),
            )
        }
        return CheckResolvedCall(ast.ExprCallArgs(expr), sig, expr.TokenPos(), diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ast.ExprIsSelector(fn) {
        recvType := CanonicalTypeNameWithEnv(InferExprTypeNameFromEnv(ast.ExprSelectorTarget(fn), env, enums, structs, funcs, methods), env)
        if IsPackageRefType(recvType) {
            path := PackageRefPath(recvType)
            sig := ResolvePackageFuncSig(path, ast.ExprSelectorField(fn), len(ast.ExprCallArgs(expr)))
            if isNone[FuncInfo](sig) {
                callablesInPkg := AnyPackageCallableNames(path)
                if len(callablesInPkg) > 0 {
                    suggestion := SuggestName(ast.ExprSelectorField(fn), callablesInPkg, 0, "", 0)
                    if IsTypoLikeSuggestion(ast.ExprSelectorField(fn), suggestion) {
                        return diag.ErrorDetailedSuggested(
                            diagnostic.TypeErrorCategory(),
                            expr.TokenPos(),
                            "FTYPE064",
                            "unknown package function "+path+"."+ast.ExprSelectorField(fn),
                            "The call target does not resolve to an exported function or named type constructor in package " + path + ". " + SuggestionReason(ast.ExprSelectorField(fn), suggestion),
                            MaybeSuggestionText(suggestion),
                            "Known callable names in " + path + " include: " + JoinStrings(callablesInPkg, 0) + ".",
                        )
                    }
                }
                return diag
            }
            return CheckResolvedCall(ast.ExprCallArgs(expr), sig, expr.TokenPos(), diag, env, enums, structs, interfaces, funcs, methods)
        }
        sig := ResolveAnyMethodSig(methods, recvType, ast.ExprSelectorField(fn), len(ast.ExprCallArgs(expr)))
        if isNone[FuncInfo](sig) {
            methodNames := ReceiverAllMethodNames(recvType, methods)
            if !(recvType == "") {
                if len(methodNames) > 0 {
                    return diag.ErrorDetailedSuggested(
                        diagnostic.TypeErrorCategory(),
                        expr.TokenPos(),
                        "FTYPE062",
                        "unknown method "+ast.ExprSelectorField(fn)+" on "+recvType,
                        "The call target does not resolve to a declared method on the receiver type.",
                        MaybeSuggestionText(SuggestName(ast.ExprSelectorField(fn), methodNames, 0, "", 0)),
                        MethodHint(recvType, methods),
                    )
                }
            }
        }
        return CheckResolvedCall(ast.ExprCallArgs(expr), sig, expr.TokenPos(), diag, env, enums, structs, interfaces, funcs, methods)
    }
    return diag
}

func CheckResolvedCall(args []ast.Expr, sig Option[FuncInfo], pos token.Pos, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if !isNone[FuncInfo](sig) {
        info := unwrapOr[FuncInfo](sig, EmptyFuncInfo())
        if len(args) == len(info.ParamTypes) {
            return CheckCallArgTypes(args, info, 0, diag, env, enums, structs, interfaces, funcs, methods)
        }
        if len(args) == 1 {
            got := InferExprTypeNameFromEnv(args[0], env, enums, structs, funcs, methods)
            if HasTupleEnvelope(got) {
                elems := ParseTupleTypeNames(got)
                if len(elems) == len(info.ParamTypes) {
                    return CheckExpandedCallArgTypes(args[0], elems, info, 0, diag, env, enums, structs, interfaces, funcs, methods)
                }
            }
        }
        return diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            pos,
            "FTYPE060",
            "argument count mismatch: expected "+IntString(len(info.ParamTypes))+", got "+IntString(len(args)),
            "Resolved callee signature is " + CallSignatureDetail(info) + ". Supplied argument types are " + ArgumentTypesSummary(args, 0, []string{}, env, enums, structs, funcs, methods) + ".",
            "Pass exactly the number of arguments required by the resolved function or method. Expected parameters are " + ArgumentParameterSummary(info, 0, []string{}) + ". Example call shape: " + CallExampleShape(info, 0, []string{}) + ".",
        )
    }
    return diag
}

func CheckCallArgTypes(args []ast.Expr, info FuncInfo, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(args) {
        return diag
    }
    got := InferExprTypeNameFromEnv(args[idx], env, enums, structs, funcs, methods)
    if info.ParamTypes[idx] == "" {
        return CheckCallArgTypes(args, info, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if got == "" {
        return CheckCallArgTypes(args, info, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ArgumentTypeCompatible(info.ParamTypes[idx], got, interfaces, methods) {
        return CheckCallArgTypes(args, info, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckCallArgTypes(
        args,
        info,
        idx + 1,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            args[idx].TokenPos(),
            "FTYPE061",
            "argument type mismatch for "+ArgumentLabel(info, idx)+": expected "+info.ParamTypes[idx]+", got "+got,
            "Parameter " + ArgumentLabel(info, idx) + " of " + CallSignatureDetail(info) + " expects " + info.ParamTypes[idx] + ", but this argument is inferred as " + got + ". " + ReturnExprReason(args[idx], got, env, enums, structs, funcs, methods),
            "Change this argument so it produces " + info.ParamTypes[idx] + ", or call a different function whose parameter type matches the current expression.",
        ),
        env,
        enums,
        structs,
        interfaces,
        funcs,
        methods,
    )
}

func CheckExpandedCallArgTypes(source ast.Expr, got []string, info FuncInfo, idx int, diag diagnostic.Diagnostics, env []TypeEntry, enums []EnumInfo, structs []StructInfo, interfaces []InterfaceInfo, funcs []FuncInfo, methods []MethodInfo) diagnostic.Diagnostics {
    if idx >= len(got) {
        return diag
    }
    if idx >= len(info.ParamTypes) {
        return diag
    }
    if info.ParamTypes[idx] == "" || got[idx] == "" {
        return CheckExpandedCallArgTypes(source, got, info, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    if ArgumentTypeCompatible(info.ParamTypes[idx], got[idx], interfaces, methods) {
        return CheckExpandedCallArgTypes(source, got, info, idx + 1, diag, env, enums, structs, interfaces, funcs, methods)
    }
    return CheckExpandedCallArgTypes(
        source,
        got,
        info,
        idx + 1,
        diag.ErrorDetailed(
            diagnostic.TypeErrorCategory(),
            source.TokenPos(),
            "FTYPE061",
            "expanded argument type mismatch for "+ArgumentLabel(info, idx)+": expected "+info.ParamTypes[idx]+", got "+got[idx],
            "A single call expression is forwarding multiple results into this callee. Position " + ArgumentLabel(info, idx) + " expects " + info.ParamTypes[idx] + ", but the forwarded result is inferred as " + got[idx] + ". " + ReturnExprReason(source, "(" + JoinStrings(got, 0) + ")", env, enums, structs, funcs, methods),
            "Adjust the inner call so its forwarded result list matches the callee signature, or pass arguments explicitly.",
        ),
        env,
        enums,
        structs,
        interfaces,
        funcs,
        methods,
    )
}

func ArgumentTypesSummary(args []ast.Expr, idx int, acc []string, env []TypeEntry, enums []EnumInfo, structs []StructInfo, funcs []FuncInfo, methods []MethodInfo) string {
    if idx >= len(args) {
        return "[" + JoinStrings(acc, 0) + "]"
    }
    got := InferExprTypeNameFromEnv(args[idx], env, enums, structs, funcs, methods)
    if got == "" {
        return ArgumentTypesSummary(args, idx + 1, append(acc, "#" + IntString(idx + 1) + ": ?"), env, enums, structs, funcs, methods)
    }
    return ArgumentTypesSummary(args, idx + 1, append(acc, "#" + IntString(idx + 1) + ": " + got), env, enums, structs, funcs, methods)
}

func ArgumentParameterSummary(info FuncInfo, idx int, acc []string) string {
    if idx >= len(info.ParamTypes) {
        return "[" + JoinStrings(acc, 0) + "]"
    }
    if idx < len(info.ParamNames) {
        if !(info.ParamNames[idx] == "") {
            return ArgumentParameterSummary(info, idx + 1, append(acc, "#" + IntString(idx + 1) + " " + info.ParamNames[idx] + ": " + info.ParamTypes[idx]))
        }
    }
    return ArgumentParameterSummary(info, idx + 1, append(acc, "#" + IntString(idx + 1) + ": " + info.ParamTypes[idx]))
}

func ArgumentLabel(info FuncInfo, idx int) string {
    if idx < len(info.ParamNames) {
        if !(info.ParamNames[idx] == "") {
            return "#" + IntString(idx + 1) + " '" + info.ParamNames[idx] + "'"
        }
    }
    return "#" + IntString(idx + 1)
}

func ResolveFuncSig(funcs []FuncInfo, name string) Option[FuncInfo] {
    if len(funcs) == 0 {
        return ResolveCompanionFuncSig(name)
    }
    if funcs[0].Name == name {
        return Some[FuncInfo](funcs[0])
    }
    return ResolveFuncSig(funcs[1:], name)
}

func ResolveCompanionFuncSig(name string) Option[FuncInfo] {
    if name == "PackageFunctionNames" || name == "PackageMemberNames" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"path"}, []string{"string"}, []string{"[]string"}))
    }
    if name == "localPackageFunctionNames" || name == "localPackageMemberNames" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"path"}, []string{"string"}, []string{"[]string"}))
    }
    if name == "MethodNames" || name == "GeneratedStructFieldNames" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"typeName"}, []string{"string"}, []string{"[]string"}))
    }
    if name == "localMethodNames" || name == "localStructFieldNames" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"typeName"}, []string{"string"}, []string{"[]string"}))
    }
    if name == "localKnownTypeNames" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"[]string"}))
    }
    if name == "PackageMemberType" || name == "GeneratedStructFieldType" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"typeName", "name"}, []string{"string", "string"}, []string{"string"}))
    }
    if name == "localPackageMemberType" || name == "localStructFieldType" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"typeName", "name"}, []string{"string", "string"}, []string{"string"}))
    }
    if name == "NamedUnderlyingType" || name == "localKnownTypeOwner" || name == "localNamedUnderlyingType" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"typeName"}, []string{"string"}, []string{"string"}))
    }
    if name == "PackageFuncPrototype" || name == "localPackageFuncPrototype" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"path", "name"}, []string{"string", "string"}, []string{"Option[FuncInfo]"}))
    }
    if name == "PackageFuncSig" || name == "localPackageFuncSig" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"path", "name", "argCount"}, []string{"string", "string", "int"}, []string{"Option[FuncInfo]"}))
    }
    if name == "MethodPrototype" || name == "localMethodPrototype" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"receiverType", "name"}, []string{"string", "string"}, []string{"Option[FuncInfo]"}))
    }
    if name == "MethodSig" || name == "localMethodSig" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"receiverType", "name", "argCount"}, []string{"string", "string", "int"}, []string{"Option[FuncInfo]"}))
    }
    if name == "InterfaceMethods" || name == "localInterfaceMethods" {
        return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"interfaceType"}, []string{"string"}, []string{"[]FuncInfo"}))
    }
    return None[FuncInfo]()
}

func ResolveMethodSig(methods []MethodInfo, receiverType string, name string) Option[FuncInfo] {
    info := FindMethodInfo(methods, receiverType, name)
    if !isNone[MethodInfo](info) {
        item := unwrapOr[MethodInfo](info, EmptyMethodInfo())
        return Some[FuncInfo](FuncInfo{
            Name: item.Name,
            TypeParams: []string{},
            ParamNames: item.ParamNames,
            ParamTypes: item.ParamTypes,
            ResultTypes: item.ResultTypes,
        })
    }
    return None[FuncInfo]()
}

func ResolveAnyMethodSig(methods []MethodInfo, receiverType string, name string, argCount int) Option[FuncInfo] {
    info := ResolveMethodSig(methods, receiverType, name)
    if !isNone[FuncInfo](info) {
        return info
    }
    live := LiveAnyMethodSig(receiverType, name, argCount)
    if !isNone[FuncInfo](live) {
        return live
    }
    generated := StdlibGeneratedMethodSig(receiverType, name, argCount)
    if !isNone[FuncInfo](generated) {
        return generated
    }
    exactCommon := ResolveStdlibExactMethodSig(receiverType, name, argCount)
    if !isNone[FuncInfo](exactCommon) {
        return exactCommon
    }
    common := ResolveStdlibCommonMethodSig(name, argCount)
    if !isNone[FuncInfo](common) {
        return common
    }
    prototype := StdlibGeneratedMethodPrototype(receiverType, name)
    if !isNone[FuncInfo](prototype) {
        return prototype
    }
    pointerType := PointerReceiverFallbackType(receiverType)
    if !(pointerType == "") {
        pointerInfo := ResolveMethodSig(methods, pointerType, name)
        if !isNone[FuncInfo](pointerInfo) {
            return pointerInfo
        }
        pointerLive := LiveAnyMethodSig(pointerType, name, argCount)
        if !isNone[FuncInfo](pointerLive) {
            return pointerLive
        }
        pointerGenerated := StdlibGeneratedMethodSig(pointerType, name, argCount)
        if !isNone[FuncInfo](pointerGenerated) {
            return pointerGenerated
        }
        pointerExactCommon := ResolveStdlibExactMethodSig(pointerType, name, argCount)
        if !isNone[FuncInfo](pointerExactCommon) {
            return pointerExactCommon
        }
        pointerPrototype := StdlibGeneratedMethodPrototype(pointerType, name)
        if !isNone[FuncInfo](pointerPrototype) {
            return pointerPrototype
        }
    }
    if StringIn(StdlibGeneratedMethodNames(receiverType), name) {
        return Some[FuncInfo](VariadicFuncInfo(name, []string{}, []string{}, "any", argCount, []string{"any"}))
    }
    if !(pointerType == "") {
        if StringIn(StdlibGeneratedMethodNames(pointerType), name) {
            return Some[FuncInfo](VariadicFuncInfo(name, []string{}, []string{}, "any", argCount, []string{"any"}))
        }
    }
    return None[FuncInfo]()
}

func PointerReceiverFallbackType(receiverType string) string {
    if receiverType == "" {
        return ""
    }
    if strings.HasPrefix(receiverType, "*") {
        return ""
    }
    return "*" + receiverType
}

func ReceiverMethodNames(receiverType string, methods []MethodInfo) []string {
    names := MethodNamesForReceiver(receiverType, methods, 0, []string{})
    pointerType := PointerReceiverFallbackType(receiverType)
    if !(pointerType == "") {
        return ConcatStrings(names, MethodNamesForReceiver(pointerType, methods, 0, []string{}), 0)
    }
    return names
}

func ResolveStdlibExactMethodSig(receiverType string, name string, argCount int) Option[FuncInfo] {
    if receiverType == "sql.IsolationLevel" {
        if name == "String" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"string"}))
            }
        }
    }
    if receiverType == "*cookiejar.Jar" {
        if name == "Cookies" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"u"}, []string{"*url.URL"}, []string{"[]*http.Cookie"}))
            }
        }
        if name == "SetCookies" {
            if argCount == 2 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"u", "cookies"}, []string{"*url.URL", "[]*http.Cookie"}, []string{}))
            }
        }
    }
    if receiverType == "driver.Connector" {
        if name == "Connect" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"ctx"}, []string{"context.Context"}, []string{"driver.Conn", "error"}))
            }
        }
        if name == "Driver" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"driver.Driver"}))
            }
        }
    }
    if receiverType == "driver.Driver" {
        if name == "Open" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"name"}, []string{"string"}, []string{"driver.Conn", "error"}))
            }
        }
    }
    if receiverType == "driver.DriverContext" {
        if name == "OpenConnector" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"name"}, []string{"string"}, []string{"driver.Connector", "error"}))
            }
        }
    }
    if receiverType == "driver.Conn" {
        if name == "Prepare" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"query"}, []string{"string"}, []string{"driver.Stmt", "error"}))
            }
        }
        if name == "Close" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"error"}))
            }
        }
        if name == "Begin" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"driver.Tx", "error"}))
            }
        }
    }
    if receiverType == "driver.ConnPrepareContext" {
        if name == "PrepareContext" {
            if argCount == 2 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"ctx", "query"}, []string{"context.Context", "string"}, []string{"driver.Stmt", "error"}))
            }
        }
    }
    if receiverType == "driver.SessionResetter" {
        if name == "ResetSession" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"ctx"}, []string{"context.Context"}, []string{"error"}))
            }
        }
    }
    if receiverType == "driver.Validator" {
        if name == "IsValid" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"bool"}))
            }
        }
    }
    if receiverType == "driver.Stmt" {
        if name == "Close" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"error"}))
            }
        }
        if name == "NumInput" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"int"}))
            }
        }
        if name == "Exec" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"args"}, []string{"[]driver.Value"}, []string{"driver.Result", "error"}))
            }
        }
        if name == "Query" {
            if argCount == 1 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"args"}, []string{"[]driver.Value"}, []string{"driver.Rows", "error"}))
            }
        }
    }
    if receiverType == "driver.Tx" {
        if name == "Commit" || name == "Rollback" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"error"}))
            }
        }
    }
    if receiverType == "driver.Rows" {
        if name == "Columns" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"[]string"}))
            }
        }
        if name == "Close" {
            if argCount == 0 {
                return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{}, []string{}, []string{"error"}))
