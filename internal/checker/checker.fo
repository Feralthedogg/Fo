            return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"name"}, []string{"string"}, []string{"*template.Template"}))
        }
    }
    if name == "Must" {
        if argCount == 2 {
            return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"t", "err"}, []string{"*template.Template", "error"}, []string{"*template.Template"}))
        }
    }
    if name == "ParseFS" {
        if argCount >= 1 {
            return Some[FuncInfo](VariadicFuncInfo(name, []string{"fsys"}, []string{"fs.FS"}, "string", argCount, []string{"*template.Template", "error"}))
        }
    }
    if name == "ParseFiles" {
        return Some[FuncInfo](VariadicFuncInfo(name, []string{}, []string{}, "string", argCount, []string{"*template.Template", "error"}))
    }
    if name == "ParseGlob" {
        if argCount == 1 {
            return Some[FuncInfo](MakeSimpleFuncInfo(name, []string{"pattern"}, []string{"string"}, []string{"*template.Template", "error"}))
        }
    }
    return None[FuncInfo]()
}

