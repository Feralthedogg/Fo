func MakeSimpleFuncInfo(name string, paramNames []string, paramTypes []string, resultTypes []string) FuncInfo {
    return FuncInfo{
        Name: name,
        TypeParams: []string{},
        ParamNames: paramNames,
        ParamTypes: paramTypes,
        ResultTypes: resultTypes,
    }
}

func VariadicFuncInfo(name string, fixedNames []string, fixedTypes []string, variadicType string, argCount int, resultTypes []string) FuncInfo {
    return FuncInfo{
        Name: name,
        TypeParams: []string{},
        ParamNames: ExpandVariadicNames(fixedNames, len(fixedTypes), argCount, 0, []string{}),
        ParamTypes: ExpandVariadicTypes(fixedTypes, variadicType, argCount, 0, []string{}),
        ResultTypes: resultTypes,
    }
}

func ExpandVariadicTypes(fixed []string, variadicType string, total int, idx int, acc []string) []string {
    if idx >= total {
        return acc
    }
    if idx < len(fixed) {
        return ExpandVariadicTypes(fixed, variadicType, total, idx + 1, append(acc, fixed[idx]))
    }
    return ExpandVariadicTypes(fixed, variadicType, total, idx + 1, append(acc, variadicType))
}

func ExpandVariadicNames(fixedNames []string, fixedCount int, total int, idx int, acc []string) []string {
    if idx >= total {
        return acc
    }
    if idx < len(fixedNames) {
        return ExpandVariadicNames(fixedNames, fixedCount, total, idx + 1, append(acc, fixedNames[idx]))
    }
    return ExpandVariadicNames(fixedNames, fixedCount, total, idx + 1, append(acc, "arg" + IntString(idx + 1)))
}

func FindEnumConstructor(funcs []FuncInfo, enumName string, variantName string) Option[FuncInfo] {
    if len(funcs) == 0 {
        return None[FuncInfo]()
    }
    if funcs[0].Name == variantName {
        if len(funcs[0].ResultTypes) == 1 {
            if BaseTypeName(funcs[0].ResultTypes[0]) == BaseTypeName(enumName) {
                return Some[FuncInfo](funcs[0])
            }
        }
    }
    return FindEnumConstructor(funcs[1:], enumName, variantName)
}

func FindMethodInfo(methods []MethodInfo, receiverType string, name string) Option[MethodInfo] {
    if len(methods) == 0 {
        return None[MethodInfo]()
    }
    if BaseTypeName(methods[0].ReceiverType) == BaseTypeName(receiverType) {
        if methods[0].Name == name {
            return Some[MethodInfo](methods[0])
        }
    }
    return FindMethodInfo(methods[1:], receiverType, name)
}

func CheckOptionalExpr(value Option[ast.Expr], visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if ast.ExprOptionIsNone(value) {
        return diag
    }
    return CheckExpr(ast.ExprOptionValue(value), visible, diag, externs)
}

func CheckCallExpr(expr ast.Expr, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    fn := ast.ExprCallFunc(expr)
    next := CheckCallTargetExpr(fn, visible, diag, externs)
    if ast.ExprIsIdent(fn) {
        name := ast.ExprIdentName(fn)
        if IsExternName(externs, name) {
            if IsPureExternName(name) {
                return next
            }
            return next.ErrorWithHint(
                diagnostic.PurityCategory(),
                expr.TokenPos(),
                "cannot call extern function '"+name+"' inside a pure Fo function",
                "Create and compose effect descriptions in Fo, then execute them only at the bridge layer.",
            )
        }
    }
    return next
}

func CheckCallTargetExpr(fn ast.Expr, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if ast.ExprIsIdent(fn) {
        return diag
    }
    if ast.ExprIsSelector(fn) {
        return CheckExpr(ast.ExprSelectorTarget(fn), visible, diag, externs)
    }
    return CheckExpr(fn, visible, diag, externs)
}

func CheckFieldInitExprs(fields []ast.FieldInit, idx int, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    next := CheckExpr(ast.FieldInitExprValue(fields[idx]), visible, diag, externs)
    return CheckFieldInitExprs(fields, idx + 1, visible, next, externs)
}

func CheckFieldUpdateExprs(fields []ast.FieldUpdate, idx int, visible []NameEntry, diag diagnostic.Diagnostics, externs []string) diagnostic.Diagnostics {
    if idx >= len(fields) {
        return diag
    }
    next := CheckExpr(ast.FieldUpdateExprValue(fields[idx]), visible, diag, externs)
    return CheckFieldUpdateExprs(fields, idx + 1, visible, next, externs)
}

func IsExternName(names []string, name string) bool {
    if len(names) == 0 {
        return false
    }
    if names[0] == name {
        return true
    }
    return IsExternName(names[1:], name)
}

func IsPureExternName(name string) bool {
    if name == "emptyMap" {
        return true
    }
    if name == "mapEntries" {
        return true
    }
    if name == "mapKeys" {
        return true
    }
    if name == "sumValues" {
        return true
    }
    if name == "lookupMap" {
        return true
    }
    if name == "freezeMap" {
        return true
    }
    if name == "put" {
        return true
    }
    if name == "remove" {
        return true
    }
    if name == "makeCmd" {
        return true
    }
    if name == "mapCmd" {
        return true
    }
    if name == "flatMapCmd" {
        return true
    }
    if name == "zipCmd" {
        return true
    }
    if name == "thenCmd" {
        return true
    }
    if name == "pureCmd" {
        return true
    }
    if name == "failCmd" {
        return true
    }
    if name == "sequenceCmd" {
        return true
    }
    if name == "runCmdValue" {
        return true
    }
    if name == "makeTask" {
        return true
    }
    if name == "runTask" {
        return true
    }
    if name == "awaitTask" {
        return true
    }
    if name == "parallelCmd" {
        return true
    }
    if name == "parallel" {
        return true
    }
    if name == "pureTask" {
        return true
    }
    if name == "mapTask" {
        return true
    }
    if name == "flatMapTask" {
        return true
    }
    if name == "map2Task" {
        return true
    }
    if name == "raceTask" {
        return true
    }
    if name == "allTasks" {
        return true
    }
    if name == "runTaskValue" {
        return true
    }
    return false
}

func ExtendSeen(decl ast.Decl, seen []NameEntry) []NameEntry {
    kind := ast.DeclKind(decl)
    if kind == "" {
        return seen
    }
    return append(seen, NameEntry{
        Name: ast.DeclName(decl),
        Kind: kind,
        Pos: ast.DeclPos(decl),
    })
}

func FindNameEntry(entries []NameEntry, name string) Option[NameEntry] {
    if len(entries) == 0 {
        return None[NameEntry]()
    }
    if entries[0].Name == name {
        return Some[NameEntry](entries[0])
    }
    return FindNameEntry(entries[1:], name)
}

func FindLastNameEntry(entries []NameEntry, name string) Option[NameEntry] {
    if len(entries) == 0 {
        return None[NameEntry]()
    }
    tail := FindLastNameEntry(entries[1:], name)
    if !isNone[NameEntry](tail) {
        return tail
    }
    if entries[0].Name == name {
        return Some[NameEntry](entries[0])
    }
    return None[NameEntry]()
}

func SuggestedRelatedPos(entries []NameEntry, suggestion string) token.Pos {
    if suggestion == "" {
        return token.MakePos("", 0, 0, 0)
    }
    entry := FindLastNameEntry(entries, suggestion)
    if isNone[NameEntry](entry) {
        return token.MakePos("", 0, 0, 0)
    }
    return unwrapOr[NameEntry](entry, EmptyNameEntry()).Pos
}

func SuggestedRelatedMessage(entries []NameEntry, suggestion string) string {
    if suggestion == "" {
        return ""
    }
    entry := FindLastNameEntry(entries, suggestion)
    if isNone[NameEntry](entry) {
        return ""
    }
    item := unwrapOr[NameEntry](entry, EmptyNameEntry())
    return "nearby " + EntryLabel(item) + " declared here"
}

