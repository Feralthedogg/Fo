    cur := p.Current()
    if cur.Type == token.EqType() {
        right := p.Advance().ParseSumForBlock()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseEqualityTailForBlock(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParseSum() ExprResult {
    left := p.ParseProduct()
    return left.Next.ParseSumTail(left.Expr)
}

func (p Parser) ParseSumForBlock() ExprResult {
    left := p.ParseProductForBlock()
    return left.Next.ParseSumTailForBlock(left.Expr)
}

func (p Parser) ParseSumTail(left ast.Expr) ExprResult {
    cur := p.Current()
    if IsSumOp(cur.Type) {
        right := p.Advance().ParseProduct()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseSumTail(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

