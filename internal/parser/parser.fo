}

func (p Parser) ParseProduct() ExprResult {
    left := p.ParseUnary()
    return left.Next.ParseProductTail(left.Expr)
}

func (p Parser) ParseProductForBlock() ExprResult {
    left := p.ParseUnaryForBlock()
    return left.Next.ParseProductTailForBlock(left.Expr)
}

func (p Parser) ParseProductTail(left ast.Expr) ExprResult {
    cur := p.Current()
    if IsProductOp(cur.Type) {
        right := p.Advance().ParseUnary()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseProductTail(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParseProductTailForBlock(left ast.Expr) ExprResult {
    cur := p.Current()
    if IsProductOp(cur.Type) {
        right := p.Advance().ParseUnaryForBlock()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseProductTailForBlock(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParseUnary() ExprResult {
    cur := p.Current()
    if cur.Type == token.MinusType() || cur.Type == token.NotType() {
        operand := p.Advance().ParseUnary()
        return ExprResult{
            Next: operand.Next,
            Expr: ast.MakeUnaryExpr(cur.Pos, cur.Type, operand.Expr),
        }
    }
    return p.ParsePostfix()
}

func (p Parser) ParseUnaryForBlock() ExprResult {
    cur := p.Current()
    if cur.Type == token.MinusType() || cur.Type == token.NotType() {
        operand := p.Advance().ParseUnaryForBlock()
        return ExprResult{
            Next: operand.Next,
            Expr: ast.MakeUnaryExpr(cur.Pos, cur.Type, operand.Expr),
        }
    }
    return p.ParsePostfixForBlock()
}

func (p Parser) ParsePostfix() ExprResult {
    primary := p.ParsePrimary()
    return primary.Next.ParsePostfixTail(primary.Expr)
}

func (p Parser) ParsePostfixForBlock() ExprResult {
    primary := p.ParsePrimary()
    return primary.Next.ParsePostfixTailForBlock(primary.Expr)
}

type GenericCallResult struct {
    Ok bool
    Next Parser
    Expr ast.Expr
}

func (p Parser) ParsePostfixTail(left ast.Expr) ExprResult {
    cur := p.Current()
    if cur.Type == token.LBracketType() {
        if p.LooksLikeGenericCall() {
            generic := p.TryParseGenericCall(left)
            if generic.Ok {
                return generic.Next.ParsePostfixTail(generic.Expr)
            }
        }
    }
    if cur.Type == token.DotType() {
        fieldTok := p.Advance().Expect(token.IdentType())
        expr := ast.MakeSelectorExpr(cur.Pos, left, fieldTok.Tok.Literal)
        return fieldTok.Next.ParsePostfixTail(expr)
    }
    if cur.Type == token.LParenType() {
        args := p.ParseCallArgs()
        expr := ast.MakeCallExpr(cur.Pos, left, args.Args)
        return args.Next.ParsePostfixTail(expr)
    }
    if cur.Type == token.LBracketType() {
        idx := p.ParseIndexOrSlice(left)
        return idx.Next.ParsePostfixTail(idx.Expr)
    }
    if cur.Type == token.LBraceType() {
        if ast.ExprIsSelector(left) {
            if !p.IsStructLiteralStart() {
                qname := ast.ExprQualifiedName(left)
                if !(qname == "") {
                    if p.LooksLikeMapLiteralEntries() {
                        lit := p.ParseMapLiteral(
                            qname,
                            ast.MakeNamedType(cur.Pos, "any"),
                            ast.MakeNamedType(cur.Pos, "any"),
                            ast.ExprPos(left),
                        )
                        return lit.Next.ParsePostfixTail(lit.Expr)
                    }
                    lit := p.ParseNamedSliceLiteral(qname, ast.ExprPos(left))
                    return lit.Next.ParsePostfixTail(lit.Expr)
                }
            }
        }
        if ast.ExprIsIdent(left) {
            if p.IsStructLiteralStart() {
                if IsConstructorPatternName(ast.ExprIdentName(left)) {
                    lit := p.ParseStructLiteral(ast.ExprIdentName(left), ast.ExprPos(left))
                    return lit.Next.ParsePostfixTail(lit.Expr)
                }
                update := p.ParseCopyUpdate(left, ast.ExprPos(left))
                return update.Next.ParsePostfixTail(update.Expr)
            }
        }
        if ast.ExprIsSelector(left) {
            if p.IsStructLiteralStart() {
                qname := ast.ExprQualifiedName(left)
                if !(qname == "") {
                    if IsConstructorPatternName(ast.ExprSelectorField(left)) {
                        lit := p.ParseStructLiteral(qname, ast.ExprPos(left))
                        return lit.Next.ParsePostfixTail(lit.Expr)
                    }
                }
            }
        }
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParsePostfixTailForBlock(left ast.Expr) ExprResult {
    cur := p.Current()
    if cur.Type == token.LBracketType() {
        if p.LooksLikeGenericCall() {
            generic := p.TryParseGenericCall(left)
            if generic.Ok {
                return generic.Next.ParsePostfixTailForBlock(generic.Expr)
            }
        }
    }
    if cur.Type == token.DotType() {
        fieldTok := p.Advance().Expect(token.IdentType())
        expr := ast.MakeSelectorExpr(cur.Pos, left, fieldTok.Tok.Literal)
        return fieldTok.Next.ParsePostfixTailForBlock(expr)
    }
    if cur.Type == token.LParenType() {
        args := p.ParseCallArgs()
        expr := ast.MakeCallExpr(cur.Pos, left, args.Args)
        return args.Next.ParsePostfixTailForBlock(expr)
    }
    if cur.Type == token.LBracketType() {
        idx := p.ParseIndexOrSlice(left)
        return idx.Next.ParsePostfixTailForBlock(idx.Expr)
    }
    if cur.Type == token.LBraceType() {
        return ExprResult{
            Next: p,
            Expr: left,
        }
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) TryParseGenericCall(left ast.Expr) GenericCallResult {
    if ast.ExprIsIdent(left) {
        open := p.Expect(token.LBracketType())
        typeArgs := open.Next.ParseTypeExprList(token.RBracketType(), []ast.TypeExpr{})
        if typeArgs.Next.Current().Type == token.LParenType() {
            args := typeArgs.Next.ParseCallArgs()
            return GenericCallResult{
                Ok: true,
                Next: args.Next,
                Expr: ast.MakeCallExprWithTypeArgs(ast.ExprPos(left), left, typeArgs.Types, args.Args),
            }
        }
        return GenericCallResult{
            Ok: false,
            Next: p,
            Expr: left,
        }
    }
    if ast.ExprIsSelector(left) {
        open := p.Expect(token.LBracketType())
        typeArgs := open.Next.ParseTypeExprList(token.RBracketType(), []ast.TypeExpr{})
        if typeArgs.Next.Current().Type == token.LParenType() {
            args := typeArgs.Next.ParseCallArgs()
            return GenericCallResult{
                Ok: true,
                Next: args.Next,
                Expr: ast.MakeCallExprWithTypeArgs(ast.ExprPos(left), left, typeArgs.Types, args.Args),
            }
        }
        return GenericCallResult{
            Ok: false,
            Next: p,
            Expr: left,
        }
    }
    return GenericCallResult{
        Ok: false,
        Next: p,
        Expr: left,
    }
}

func (p Parser) IsStructLiteralStart() bool {
    next := p.Peek()
    if next.Type == token.RBraceType() {
        return true
    }
    if next.Type == token.IdentType() {
        after := p.PeekN(2)
        if after.Type == token.ColonType() {
            return true
        }
        if after.Type == token.DotType() {
            return true
        }
    }
    return false
}

func (p Parser) LooksLikeGenericCall() bool {
    return p.HasGenericCallSuffix(p.Index + 1, 0)
}

func (p Parser) HasGenericCallSuffix(idx int, depth int) bool {
    if idx >= len(p.Tokens) {
        return false
    }
    cur := p.Tokens[idx]
    if cur.Type == token.LBracketType() || cur.Type == token.LParenType() || cur.Type == token.LBraceType() {
        return p.HasGenericCallSuffix(idx + 1, depth + 1)
    }
    if cur.Type == token.RParenType() || cur.Type == token.RBraceType() {
        if depth == 0 {
            return false
        }
        return p.HasGenericCallSuffix(idx + 1, depth - 1)
    }
    if cur.Type == token.RBracketType() {
        if depth == 0 {
            if idx + 1 >= len(p.Tokens) {
                return false
            }
            return p.Tokens[idx + 1].Type == token.LParenType()
        }
        return p.HasGenericCallSuffix(idx + 1, depth - 1)
    }
    return p.HasGenericCallSuffix(idx + 1, depth)
}

func (p Parser) LooksLikeMapLiteralEntries() bool {
    return p.HasTopLevelColon(p.Index + 1, 0)
}

func (p Parser) HasTopLevelColon(idx int, depth int) bool {
    if idx >= len(p.Tokens) {
        return false
    }
    cur := p.Tokens[idx]
    if cur.Type == token.RBraceType() {
        if depth == 0 {
            return false
        }
        return p.HasTopLevelColon(idx + 1, depth - 1)
    }
    if cur.Type == token.LBraceType() || cur.Type == token.LParenType() || cur.Type == token.LBracketType() {
        return p.HasTopLevelColon(idx + 1, depth + 1)
    }
    if cur.Type == token.RParenType() || cur.Type == token.RBracketType() {
        if depth == 0 {
            return false
        }
        return p.HasTopLevelColon(idx + 1, depth - 1)
    }
    if cur.Type == token.ColonType() {
        if depth == 0 {
            return true
        }
    }
    if cur.Type == token.CommaType() {
        if depth == 0 {
            return false
        }
    }
    return p.HasTopLevelColon(idx + 1, depth)
}

type ArgsResult struct {
    Next Parser
    Args []ast.Expr
}

func (p Parser) ParseCallArgs() ArgsResult {
    open := p.Expect(token.LParenType())
    return open.Next.ParseArgs([]ast.Expr{})
}

func (p Parser) ParseArgs(acc []ast.Expr) ArgsResult {
    cur := p.Current()
    if cur.Type == token.RParenType() {
        end := p.Expect(token.RParenType())
        return ArgsResult{
            Next: end.Next,
            Args: acc,
        }
    }
    expr := p.ParseExpr()
    nextAcc := append(acc, expr.Expr)
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseArgs(nextAcc)
    }
    return nextParser.ParseArgs(nextAcc)
}

type StructLitResult struct {
    Next Parser
    Expr ast.Expr
}

type MapLitResult struct {
    Next Parser
    Expr ast.Expr
}

type NamedSliceLitResult struct {
    Next Parser
    Expr ast.Expr
}

func (p Parser) ParseStructLiteral(name string, pos token.Pos) StructLitResult {
    open := p.Expect(token.LBraceType())
    fields := open.Next.ParseStructLiteralFields([]ast.FieldInit{})
    return StructLitResult{
        Next: fields.Next,
        Expr: ast.MakeStructLit(pos, name, fields.Fields),
    }
}

func (p Parser) ParseMapLiteral(typeName string, keyType ast.TypeExpr, valueType ast.TypeExpr, pos token.Pos) MapLitResult {
    open := p.Expect(token.LBraceType())
    entries := open.Next.ParseMapLiteralEntries([]ast.MapEntry{})
    return MapLitResult{
        Next: entries.Next,
        Expr: ast.MakeMapLit(pos, typeName, keyType, valueType, entries.Entries),
    }
}

func (p Parser) ParseNamedSliceLiteral(typeName string, pos token.Pos) NamedSliceLitResult {
    open := p.Expect(token.LBraceType())
    elems := open.Next.ParseExprList([]ast.Expr{})
    return NamedSliceLitResult{
        Next: elems.Next,
        Expr: ast.MakeNamedSliceLit(pos, typeName, elems.Exprs),
    }
}

func (p Parser) ParseCopyUpdate(source ast.Expr, pos token.Pos) StructLitResult {
    open := p.Expect(token.LBraceType())
    updates := open.Next.ParseCopyUpdateFields([]ast.FieldUpdate{})
    return StructLitResult{
        Next: updates.Next,
        Expr: ast.MakeCopyUpdateExpr(pos, source, updates.Updates),
    }
}

type StructLiteralFieldsResult struct {
    Next Parser
    Fields []ast.FieldInit
}

func (p Parser) ParseStructLiteralFields(acc []ast.FieldInit) StructLiteralFieldsResult {
    cur := p.Current()
    if cur.Type == token.RBraceType() {
        end := p.Expect(token.RBraceType())
        return StructLiteralFieldsResult{
            Next: end.Next,
            Fields: acc,
        }
    }
    nameTok := p.Expect(token.IdentType())
    colon := nameTok.Next.Expect(token.ColonType())
    expr := colon.Next.ParseExpr()
    nextAcc := append(acc, ast.MakeFieldInit(nameTok.Tok.Literal, expr.Expr))
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseStructLiteralFields(nextAcc)
    }
    return nextParser.ParseStructLiteralFields(nextAcc)
}

type CopyUpdateFieldsResult struct {
    Next Parser
    Updates []ast.FieldUpdate
}

type MapLiteralEntriesResult struct {
    Next Parser
    Entries []ast.MapEntry
}

func (p Parser) ParseMapLiteralEntries(acc []ast.MapEntry) MapLiteralEntriesResult {
    cur := p.Current()
    if cur.Type == token.RBraceType() {
        end := p.Expect(token.RBraceType())
        return MapLiteralEntriesResult{
            Next: end.Next,
            Entries: acc,
        }
    }
    key := p.ParseExpr()
    colon := key.Next.Expect(token.ColonType())
    value := colon.Next.ParseExpr()
    nextAcc := append(acc, ast.MakeMapEntry(key.Expr, value.Expr))
    nextParser := value.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseMapLiteralEntries(nextAcc)
    }
    return nextParser.ParseMapLiteralEntries(nextAcc)
}

func (p Parser) ParseCopyUpdateFields(acc []ast.FieldUpdate) CopyUpdateFieldsResult {
    cur := p.Current()
    if cur.Type == token.RBraceType() {
        end := p.Expect(token.RBraceType())
        return CopyUpdateFieldsResult{
            Next: end.Next,
            Updates: acc,
        }
    }
    path := p.ParseFieldPath([]string{})
    colon := path.Next.Expect(token.ColonType())
    expr := colon.Next.ParseExpr()
    nextAcc := append(acc, ast.MakeFieldUpdate(path.Path, expr.Expr))
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseCopyUpdateFields(nextAcc)
    }
    return nextParser.ParseCopyUpdateFields(nextAcc)
}

type FieldPathResult struct {
    Next Parser
    Path []string
}

func (p Parser) ParseFieldPath(acc []string) FieldPathResult {
    nameTok := p.Expect(token.IdentType())
    nextAcc := append(acc, nameTok.Tok.Literal)
    nextParser := nameTok.Next
    if nextParser.Current().Type == token.DotType() {
        return nextParser.Advance().ParseFieldPath(nextAcc)
    }
    return FieldPathResult{
        Next: nextParser,
        Path: nextAcc,
    }
}

type IndexOrSliceResult struct {
    Next Parser
    Expr ast.Expr
}

func (p Parser) ParseIndexOrSlice(left ast.Expr) IndexOrSliceResult {
    open := p.Expect(token.LBracketType())
    if open.Next.Current().Type == token.ColonType() {
        afterColon := open.Next.Advance()
        if afterColon.Current().Type == token.RBracketType() {
            close := afterColon.Expect(token.RBracketType())
            return IndexOrSliceResult{
                Next: close.Next,
                Expr: ast.MakeSliceExpr(open.Tok.Pos, left, None[ast.Expr](), None[ast.Expr]()),
            }
        }
        high := afterColon.ParseExpr()
        close := high.Next.Expect(token.RBracketType())
        return IndexOrSliceResult{
            Next: close.Next,
            Expr: ast.MakeSliceExpr(open.Tok.Pos, left, None[ast.Expr](), Some[ast.Expr](high.Expr)),
        }
    }
    first := open.Next.ParseExpr()
    if first.Next.Current().Type == token.ColonType() {
        afterColon := first.Next.Advance()
        if afterColon.Current().Type == token.RBracketType() {
            close := afterColon.Expect(token.RBracketType())
            return IndexOrSliceResult{
                Next: close.Next,
                Expr: ast.MakeSliceExpr(open.Tok.Pos, left, Some[ast.Expr](first.Expr), None[ast.Expr]()),
            }
        }
        high := afterColon.ParseExpr()
        close := high.Next.Expect(token.RBracketType())
        return IndexOrSliceResult{
            Next: close.Next,
            Expr: ast.MakeSliceExpr(open.Tok.Pos, left, Some[ast.Expr](first.Expr), Some[ast.Expr](high.Expr)),
        }
    }
    close := first.Next.Expect(token.RBracketType())
    return IndexOrSliceResult{
        Next: close.Next,
        Expr: ast.MakeIndexExpr(open.Tok.Pos, left, first.Expr),
    }
}

func (p Parser) ParsePrimary() ExprResult {
    cur := p.Current()
    if cur.Type == token.IdentType() {
        if cur.Literal == "make" {
            if p.Peek().Type == token.LParenType() {
                return p.ParseMakeExpr()
            }
        }
        if cur.Literal == "map" {
            if p.Peek().Type == token.LBracketType() {
                typ := p.ParseMapTypeExpr()
                if typ.Next.Current().Type == token.LBraceType() {
                    lit := typ.Next.ParseMapLiteral(
                        "",
                        ast.TypeExprMapKey(TypeOrAny(typ.Type)),
                        ast.TypeExprMapValue(TypeOrAny(typ.Type)),
                        cur.Pos,
                    )
                    return ExprResult{
                        Next: lit.Next,
                        Expr: lit.Expr,
                    }
                }
            }
        }
        return ExprResult{
            Next: p.Advance(),
            Expr: ast.MakeIdent(cur.Pos, cur.Literal),
        }
    }
    if cur.Type == token.IntLitType() || cur.Type == token.FloatLitType() || cur.Type == token.StringLitType() || cur.Type == token.RuneLitType() || cur.Type == token.TrueType() || cur.Type == token.FalseType() {
        return ExprResult{
            Next: p.Advance(),
            Expr: ast.MakeBasicLit(cur.Pos, cur.Type, cur.Literal),
        }
    }
    if cur.Type == token.LParenType() {
        return p.ParseParenOrTuple()
    }
    if cur.Type == token.FuncType() {
        return p.ParseFuncLiteral()
    }
    if cur.Type == token.LBracketType() {
        if p.Peek().Type == token.RBracketType() {
            return p.ParseSliceLiteral()
        }
    }
    next := p{
        Diag: p.Diag.ErrorDetailedSuggested(
            diagnostic.SyntaxCategory(),
            cur.Pos,
            "FSYNTAX005",
            "expected expression, found '" + token.TypeString(cur.Type) + "'",
            ExpressionStartDetail(cur),
            SuggestExpressionStart(cur),
            ExpressionStartHint(cur),
        ),
    }
    return ExprResult{
        Next: next.Advance(),
        Expr: ast.MakeIdent(cur.Pos, "<error>"),
    }
}

func (p Parser) ParseMakeExpr() ExprResult {
    makeTok := p.Expect(token.IdentType())
    open := makeTok.Next.Expect(token.LParenType())
    typ := open.Next.ParseTypeExpr()
    if typ.Next.Current().Type == token.RParenType() {
        close := typ.Next.Expect(token.RParenType())
        return ExprResult{
            Next: close.Next,
            Expr: ast.MakeMakeExpr(makeTok.Tok.Pos, TypeOrAny(typ.Type), []ast.Expr{}),
        }
    }
    comma := typ.Next.Expect(token.CommaType())
    args := comma.Next.ParseMakeArgs([]ast.Expr{})
    return ExprResult{
        Next: args.Next,
        Expr: ast.MakeMakeExpr(makeTok.Tok.Pos, TypeOrAny(typ.Type), args.Exprs),
    }
}

func (p Parser) ParseFuncLiteral() ExprResult {
    fnTok := p.Expect(token.FuncType())
    params := fnTok.Next.ParseParamList()
    result := params.Next.ParseOptionalResultType()
    body := result.Next.ParseBlock()
    return ExprResult{
        Next: body.Next,
        Expr: ast.MakeFuncLit(
            fnTok.Tok.Pos,
            params.Fields,
            MaybeTypeExprSlice(result.Type),
            body.Block,
        ),
    }
}

func (p Parser) ParseParenOrTuple() ExprResult {
    open := p.Expect(token.LParenType())
    if open.Next.Current().Type == token.RParenType() {
        close := open.Next.Expect(token.RParenType())
        return ExprResult{
            Next: close.Next,
            Expr: ast.MakeTupleLit(open.Tok.Pos, []ast.Expr{}),
        }
    }

    first := open.Next.ParseExpr()
    if first.Next.Current().Type == token.CommaType() {
        elems := first.Next.Advance().ParseTupleElems([]ast.Expr{first.Expr})
        return ExprResult{
            Next: elems.Next,
            Expr: ast.MakeTupleLit(open.Tok.Pos, elems.Exprs),
        }
    }

    close := first.Next.Expect(token.RParenType())
    return ExprResult{
        Next: close.Next,
        Expr: first.Expr,
    }
}

func (p Parser) ParseTupleElems(acc []ast.Expr) ExprListResult {
    cur := p.Current()
    if cur.Type == token.RParenType() {
        end := p.Expect(token.RParenType())
        return ExprListResult{
            Next: end.Next,
            Exprs: acc,
        }
    }
    expr := p.ParseExpr()
    nextAcc := append(acc, expr.Expr)
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseTupleElems(nextAcc)
    }
    return nextParser.ParseTupleElems(nextAcc)
}

func (p Parser) ParseSliceLiteral() ExprResult {
    open := p.Expect(token.LBracketType())
    close := open.Next.Expect(token.RBracketType())
    elem := close.Next.ParseTypeExpr()
    lbrace := elem.Next.Expect(token.LBraceType())
    elems := lbrace.Next.ParseExprList([]ast.Expr{})
    return ExprResult{
        Next: elems.Next,
        Expr: ast.MakeSliceLit(open.Tok.Pos, TypeOrAny(elem.Type), elems.Exprs),
    }
}

type ExprListResult struct {
    Next Parser
    Exprs []ast.Expr
}

func (p Parser) ParseMakeArgs(acc []ast.Expr) ExprListResult {
    cur := p.Current()
    if cur.Type == token.RParenType() {
        end := p.Expect(token.RParenType())
        return ExprListResult{
            Next: end.Next,
            Exprs: acc,
        }
    }
    expr := p.ParseExpr()
    nextAcc := append(acc, expr.Expr)
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseMakeArgs(nextAcc)
    }
    return nextParser.ParseMakeArgs(nextAcc)
}

func (p Parser) ParseExprList(acc []ast.Expr) ExprListResult {
    cur := p.Current()
    if cur.Type == token.RBraceType() {
        end := p.Expect(token.RBraceType())
        return ExprListResult{
            Next: end.Next,
            Exprs: acc,
        }
    }
    expr := p.ParseExpr()
    nextAcc := append(acc, expr.Expr)
    nextParser := expr.Next
    if nextParser.Current().Type == token.CommaType() {
        return nextParser.Advance().ParseExprList(nextAcc)
    }
    return nextParser.ParseExprList(nextAcc)
}

func MaybeTypeExprSlice(value Option[ast.TypeExpr]) []ast.TypeExpr {
    if isNone[ast.TypeExpr](value) {
        return []ast.TypeExpr{}
    }
    v := unwrapOr[ast.TypeExpr](value, ast.MakeNamedType(ast.ZeroPos(), "any"))
    return []ast.TypeExpr{v}
}

func TypeOrAny(value Option[ast.TypeExpr]) ast.TypeExpr {
    if isNone[ast.TypeExpr](value) {
        return ast.MakeNamedType(ast.ZeroPos(), "any")
    }
    return unwrapOr[ast.TypeExpr](value, ast.MakeNamedType(ast.ZeroPos(), "any"))
}

func IsComparisonOp(t token.Type) bool {
    if t == token.LtType() {
        return true
    }
    if t == token.GtType() {
        return true
    }
    if t == token.LteType() {
        return true
    }
    if t == token.GteType() {
        return true
    }
    return false
}

func IsSumOp(t token.Type) bool {
    if t == token.PlusType() {
        return true
    }
    if t == token.MinusType() {
        return true
    }
    return false
}

func IsProductOp(t token.Type) bool {
    if t == token.StarType() {
        return true
    }
    if t == token.SlashType() {
        return true
    }
    if t == token.PercentType() {
        return true
    }
    return false
}
