}

func (p Parser) ParseComparison() ExprResult {
    left := p.ParseEquality()
    return left.Next.ParseComparisonTail(left.Expr)
}

func (p Parser) ParseComparisonForBlock() ExprResult {
    left := p.ParseEqualityForBlock()
    return left.Next.ParseComparisonTailForBlock(left.Expr)
}

func (p Parser) ParseComparisonTail(left ast.Expr) ExprResult {
    cur := p.Current()
    if IsComparisonOp(cur.Type) {
        right := p.Advance().ParseEquality()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseComparisonTail(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParseComparisonTailForBlock(left ast.Expr) ExprResult {
    cur := p.Current()
    if IsComparisonOp(cur.Type) {
        right := p.Advance().ParseEqualityForBlock()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseComparisonTailForBlock(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

func (p Parser) ParseEquality() ExprResult {
    left := p.ParseSum()
    return left.Next.ParseEqualityTail(left.Expr)
}

func (p Parser) ParseEqualityForBlock() ExprResult {
    left := p.ParseSumForBlock()
    return left.Next.ParseEqualityTailForBlock(left.Expr)
}

func (p Parser) ParseEqualityTail(left ast.Expr) ExprResult {
    cur := p.Current()
    if cur.Type == token.EqType() {
        right := p.Advance().ParseSum()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseEqualityTail(expr)
    }
    return ExprResult{
        Next: p,
        Expr: left,
    }
}

