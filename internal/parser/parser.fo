    cur := p.Current()
    if cur.Type == token.LandType() {
        right := p.Advance().ParseComparisonForBlock()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseLogicalAndTailForBlock(expr)
