    cur := p.Current()
    if IsSumOp(cur.Type) {
        right := p.Advance().ParseProductForBlock()
        expr := ast.MakeBinaryExpr(cur.Pos, cur.Type, left, right.Expr)
        return right.Next.ParseSumTailForBlock(expr)
    }
    return ExprResult{
        Next: p,
