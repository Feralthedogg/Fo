package ast

import "github.com/Feralthedogg/Fo/internal/token"

type Node interface {
    TokenPos() token.Pos
    nodeTag()
}

type Decl interface {
    TokenPos() token.Pos
    nodeTag()
    declTag()
}

type Stmt interface {
    TokenPos() token.Pos
    nodeTag()
    stmtTag()
}

type Expr interface {
    TokenPos() token.Pos
    nodeTag()
    exprTag()
}

type Pattern interface {
    TokenPos() token.Pos
    nodeTag()
    patternTag()
}

type File struct {
    Package Option[PackageDecl]
    Imports []ImportDecl
    Decls []Decl
}

func (f File) TokenPos() token.Pos {
    if isNone[PackageDecl](f.Package) {
        return ZeroPos()
    }
    pkg := unwrapOr(f.Package, MakePackageDecl(ZeroPos(), ""))
    return pkg.TokenPos()
}

func (f File) nodeTag() {
}

