func DeclName(decl Decl) string {
    match decl {
    case FuncDecl{Name: name}:
        return name
    case TypeDecl{Name: name}:
        return name
    case _:
        return ""
    }
}

func DeclWithExtern(decl Decl, isExtern bool) Decl {
    match decl {
    case FuncDecl{Pos: pos, Receiver: receiver, Name: name, TypeParams: typeParams, Params: params, Results: results, Body: body}:
        return FuncDecl{
            Pos: pos,
            IsExtern: isExtern,
            Receiver: receiver,
            Name: name,
            TypeParams: typeParams,
            Params: params,
            Results: results,
            Body: body,
        }
    case _:
        return decl
    }
}

func DeclWithTypeParams(decl Decl, params []TypeParam) Decl {
    match decl {
    case FuncDecl{Pos: pos, IsExtern: isExtern, Receiver: receiver, Name: name, Params: fields, Results: results, Body: body}:
        return FuncDecl{
            Pos: pos,
            IsExtern: isExtern,
            Receiver: receiver,
            Name: name,
            TypeParams: params,
            Params: fields,
            Results: results,
            Body: body,
        }
    case TypeDecl{Pos: pos, Name: name, Def: def, Deriving: names}:
        return TypeDecl{
            Pos: pos,
            Name: name,
            TypeParams: params,
            Def: def,
            Deriving: names,
        }
    case _:
        return decl
    }
}

func DeclPos(decl Decl) token.Pos {
    return decl.TokenPos()
}

func DeclIsTopLevelFunc(decl Decl) bool {
    match decl {
    case FuncDecl{Receiver: recv}:
        return isNone[FieldDef](recv)
    case _:
        return false
    }
}

func DeclIsFuncDecl(decl Decl) bool {
    match decl {
    case FuncDecl{}:
        return true
    case _:
        return false
    }
}

func DeclIsTypeDecl(decl Decl) bool {
    match decl {
    case TypeDecl{}:
        return true
    case _:
        return false
    }
}

func DeclKind(decl Decl) string {
    if DeclIsTopLevelFunc(decl) {
        return "func"
    }
    if DeclIsTypeDecl(decl) {
        return "type"
    }
    return ""
}

func FilePackageName(file File) string {
    if isNone[PackageDecl](file.Package) {
        return ""
    }
    return unwrapOr(file.Package, MakePackageDecl(ZeroPos(), "")).Name
}

func ImportPath(imp ImportDecl) string {
    return imp.Path
}

