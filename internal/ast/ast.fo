func ZeroPos() token.Pos {
    return token.MakePos("", 0, 0, 0)
}

func MakePackageDecl(pos token.Pos, name string) PackageDecl {
    return PackageDecl{
        Pos: pos,
        Name: name,
    }
}

func MakeImportDecl(pos token.Pos, path string) ImportDecl {
    return ImportDecl{
        Pos: pos,
        Path: path,
    }
}

func MakeIdent(pos token.Pos, name string) Ident {
    return Ident{
        Pos: pos,
        Name: name,
    }
}

func MakeFile(pkg PackageDecl) File {
    return File{
        Package: Some[PackageDecl](pkg),
        Imports: []ImportDecl{},
        Decls: []Decl{},
    }
}

func EmptyFile() File {
    return File{
        Package: None[PackageDecl](),
        Imports: []ImportDecl{},
        Decls: []Decl{},
    }
}

func FileWithPackage(file File, pkg PackageDecl) File {
    return file{
        Package: Some[PackageDecl](pkg),
    }
}

func FileWithDecl(file File, decl Decl) File {
    return file{
        Decls: append(file.Decls, decl),
    }
}

func FileWithImport(file File, decl ImportDecl) File {
    return file{
        Imports: append(file.Imports, decl),
    }
}

func MakeNamedType(pos token.Pos, name string) NamedType {
    return NamedType{
        Pos: pos,
        Name: name,
        TypeArgs: []TypeExpr{},
    }
}

func MakeNamedTypeWithArgs(pos token.Pos, name string, typeArgs []TypeExpr) NamedType {
    return NamedType{
        Pos: pos,
        Name: name,
        TypeArgs: typeArgs,
    }
}

func MakeSliceType(pos token.Pos, elem TypeExpr) SliceType {
    return SliceType{
        Pos: pos,
        Elem: elem,
    }
}

func MakeMapType(pos token.Pos, key TypeExpr, value TypeExpr) MapType {
    return MapType{
        Pos: pos,
        Key: key,
        Value: value,
    }
}

func MakeFuncType(pos token.Pos, params []TypeExpr, results []TypeExpr) FuncType {
    return FuncType{
        Pos: pos,
        Params: params,
        Results: results,
    }
}

func MakeChanType(pos token.Pos, elem TypeExpr, receiveOnly bool) ChanType {
    return ChanType{
        Pos: pos,
        Elem: elem,
        ReceiveOnly: receiveOnly,
    }
}

func MakeQualifiedType(pos token.Pos, pkg string, name string) QualifiedType {
    return QualifiedType{
        Pos: pos,
        Package: pkg,
        Name: name,
        TypeArgs: []TypeExpr{},
    }
}

func MakeQualifiedTypeWithArgs(pos token.Pos, pkg string, name string, args []TypeExpr) QualifiedType {
    return QualifiedType{
        Pos: pos,
        Package: pkg,
        Name: name,
        TypeArgs: args,
    }
}

func MakeFuncDecl(pos token.Pos, name string, results []TypeExpr, body BlockStmt) FuncDecl {
    return FuncDecl{
        Pos: pos,
        IsExtern: false,
        Receiver: None[FieldDef](),
        Name: name,
        TypeParams: []TypeParam{},
        Params: []FieldDef{},
        Results: results,
        Body: Some[BlockStmt](body),
    }
}

func MakeTypeDeclStruct(pos token.Pos, name string, fields []FieldDef) TypeDecl {
    return TypeDecl{
        Pos: pos,
        Name: name,
        TypeParams: []TypeParam{},
        Def: StructDef{
            Pos: pos,
            Fields: fields,
        },
        Deriving: []string{},
    }
}

func MakeVariant(pos token.Pos, name string, fields []TypeExpr) Variant {
    return Variant{
        Pos: pos,
        Name: name,
        Fields: fields,
    }
}

func MakeTypeDeclEnum(pos token.Pos, name string, variants []Variant) TypeDecl {
    return TypeDecl{
        Pos: pos,
        Name: name,
        TypeParams: []TypeParam{},
        Def: EnumDef{
            Pos: pos,
            Variants: variants,
        },
        Deriving: []string{},
    }
}

func MakeMethodSig(pos token.Pos, name string, params []FieldDef, results []TypeExpr) MethodSig {
    return MethodSig{
        Pos: pos,
        Name: name,
        Params: params,
        Results: results,
    }
}

func MakeTypeDeclInterface(pos token.Pos, name string, methods []MethodSig) TypeDecl {
    return TypeDecl{
        Pos: pos,
        Name: name,
        TypeParams: []TypeParam{},
        Def: InterfaceDef{
            Pos: pos,
            Methods: methods,
        },
        Deriving: []string{},
    }
}

func MakeFieldDef(pos token.Pos, name string, typ TypeExpr) FieldDef {
    return FieldDef{
        Pos: pos,
        Name: name,
        Type: typ,
        Variadic: false,
    }
}

func MakeVariadicFieldDef(pos token.Pos, name string, typ TypeExpr) FieldDef {
    return FieldDef{
        Pos: pos,
        Name: name,
        Type: typ,
        Variadic: true,
    }
}

func MakeBlockStmt(pos token.Pos) BlockStmt {
    return BlockStmt{
        Pos: pos,
        Stmts: []Stmt{},
