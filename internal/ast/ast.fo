}

func DeclReceiverField(decl Decl) FieldDef {
    match decl {
    case FuncDecl{Receiver: recv}:
        return unwrapOr[FieldDef](recv, MakeFieldDef(ZeroPos(), "_", MakeNamedType(ZeroPos(), "any")))
    case _:
        return MakeFieldDef(ZeroPos(), "_", MakeNamedType(ZeroPos(), "any"))
    }
}

