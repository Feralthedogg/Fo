func DeclBodyBlock(decl Decl) BlockStmt {
    match decl {
    case FuncDecl{Body: body}:
        if isNone[BlockStmt](body) {
            return MakeBlockStmt(ZeroPos())
        }
        return unwrapOr(body, MakeBlockStmt(ZeroPos()))
    case _:
        return MakeBlockStmt(ZeroPos())
    }
}

