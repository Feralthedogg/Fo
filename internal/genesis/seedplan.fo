    return []string{
        "go.mod",
        "go.sum",
        "SEED.txt",
        "cmd/fo/main.go",
        "cmd/fohost/main.go",
        "internal/ast/ast.go",
        "internal/checker/checker.go",
        "internal/checker/stdlibindex_generated.go",
        "internal/checker/localindex_generated.go",
        "internal/codegen/codegen.go",
        "internal/diagnostic/diagnostic.go",
