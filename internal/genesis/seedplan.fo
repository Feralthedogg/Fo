func SeedFilesExpr() Expr {
    return TupleExpr([]Expr{
        FileExpr(TextExpr("go.mod"), TextExpr(SeedGoModContent())),
        FileExpr(TextExpr("go.sum"), TextExpr("generated")),
        FileExpr(TextExpr("SEED.txt"), SeedManifestExpr()),
        FileExpr(TextExpr("cmd/fo/main.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/ast/ast.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/checker/checker.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/checker/stdlibindex_generated.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/checker/localindex_generated.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/codegen/codegen.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/diagnostic/diagnostic.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/driver/driver.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/fomod/fomod.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/hostplan/hostplan.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/lexer/lexer.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/token/token.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/parser/parser.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/project/project.go"), TextExpr("generated")),
        FileExpr(TextExpr("internal/toolchain/toolchain.go"), TextExpr("generated")),
        FileExpr(TextExpr("cmd/fohost/main.go"), TextExpr("generated")),
        FileExpr(TextExpr("stdlib/fo/runtime.go"), TextExpr("generated")),
        FileExpr(TextExpr("stdlib/fo/collections_generated.go"), TextExpr("generated")),
        FileExpr(TextExpr("stdlib/fo/effects_generated.go"), TextExpr("generated")),
        FileExpr(TextExpr("stdlib/fo/bridge.go"), TextExpr("generated")),
    })
}

func SeedPlanExpr() Expr {
    return PlanExpr(
        TextExpr("seed_snapshot"),
        TextExpr("bootstrap/seed"),
        SeedFilesExpr(),
        TextExpr("seed planned"),
    )
}
