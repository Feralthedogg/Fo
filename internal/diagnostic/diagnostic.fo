package diagnostic

import "fmt"
import "strings"
import "github.com/Feralthedogg/Fo/internal/token"

type Severity enum {
    Error
    Warning
    Info
}

type Category enum {
    Lexical
    Syntax
    TypeError
    Purity
    Immutability
    Exhaustiveness
    Recursion
}

type Diagnostic struct {
    Severity Severity
    Category Category
    Pos token.Pos
    Code string
    Message string
    Detail string
    Suggestion string
    Hint string
    RelatedPos token.Pos
    RelatedMessage string
}

type Diagnostics struct {
    Items []Diagnostic
    HasError bool
    Sources []SourceContext
}

type SourceContext struct {
    Lines []string
    Filename string
}

func New() Diagnostics {
    return Diagnostics{
        Items: []Diagnostic{},
        HasError: false,
        Sources: []SourceContext{},
    }
}

func NewSourceContext(src string, filename string) SourceContext {
    return SourceContext{
        Lines: strings.Split(src, "\n"),
        Filename: filename,
    }
}

func SeverityString(s Severity) string {
    match s {
    case Error:
        return "error"
    case Warning:
        return "warning"
    case Info:
        return "info"
    }
}

func CategoryString(c Category) string {
    match c {
    case Lexical:
        return "lexical"
    case Syntax:
        return "syntax"
    case TypeError:
        return "type"
    case Purity:
        return "purity"
    case Immutability:
        return "immutability"
    case Exhaustiveness:
        return "exhaustiveness"
    case Recursion:
        return "recursion"
    }
}

func SyntaxCategory() Category {
    return Syntax
}

func LexicalCategory() Category {
    return Lexical
}

func TypeErrorCategory() Category {
    return TypeError
}

func PurityCategory() Category {
    return Purity
}

func ImmutabilityCategory() Category {
    return Immutability
}

func ExhaustivenessCategory() Category {
    return Exhaustiveness
}

func PosString(p token.Pos) string {
    if p.File == "" {
        return fmt.Sprintf("%d:%d", p.Line, p.Column)
    }
    return fmt.Sprintf("%s:%d:%d", p.File, p.Line, p.Column)
}

func (d Diagnostic) String() string {
    prefix := PosString(d.Pos) + ": " + SeverityString(d.Severity) + CodeSuffix(d.Code)
    return prefix + ": " + d.Message + FormatDetail(d.Detail) + FormatSuggestion(d.Suggestion) + FormatInlineRelated(d) + FormatHint(d.Hint)
}

func (d Diagnostics) Add(diag Diagnostic) Diagnostics {
    return Diagnostics{
        Items: append(d.Items, diag),
        HasError: d.HasError || IsError(diag.Severity),
        Sources: d.Sources,
    }
}

func (d Diagnostics) Error(cat Category, pos token.Pos, msg string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: "",
        Message: msg,
        Detail: "",
        Suggestion: "",
        Hint: "",
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
}

func (d Diagnostics) ErrorWithHint(cat Category, pos token.Pos, msg string, hint string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: "",
        Message: msg,
        Detail: "",
        Suggestion: "",
        Hint: hint,
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
}

func (d Diagnostics) ErrorDetailed(cat Category, pos token.Pos, code string, msg string, detail string, hint string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: code,
        Message: msg,
        Detail: detail,
        Suggestion: "",
        Hint: hint,
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
}

func (d Diagnostics) ErrorRelated(cat Category, pos token.Pos, code string, msg string, detail string, hint string, relatedPos token.Pos, relatedMessage string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: code,
        Message: msg,
        Detail: detail,
        Suggestion: "",
        Hint: hint,
        RelatedPos: relatedPos,
        RelatedMessage: relatedMessage,
    })
}

func (d Diagnostics) ErrorDetailedSuggested(cat Category, pos token.Pos, code string, msg string, detail string, suggestion string, hint string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: code,
        Message: msg,
        Detail: detail,
        Suggestion: suggestion,
        Hint: hint,
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
}

func (d Diagnostics) ErrorRelatedSuggested(cat Category, pos token.Pos, code string, msg string, detail string, suggestion string, hint string, relatedPos token.Pos, relatedMessage string) Diagnostics {
    return d.Add(Diagnostic{
        Severity: Error,
        Category: cat,
        Pos: pos,
        Code: code,
        Message: msg,
        Detail: detail,
        Suggestion: suggestion,
        Hint: hint,
        RelatedPos: relatedPos,
        RelatedMessage: relatedMessage,
    })
}

