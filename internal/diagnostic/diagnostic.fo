    return d.Add(Diagnostic{
        Severity: Warning,
        Category: cat,
        Pos: pos,
        Code: "",
        Message: msg,
        Detail: "",
        Suggestion: "",
        Hint: "",
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
