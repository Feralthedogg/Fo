        Message: msg,
        Detail: "",
        Suggestion: "",
        Hint: "",
        RelatedPos: token.MakePos("", 0, 0, 0),
        RelatedMessage: "",
    })
}

func (d Diagnostics) WithSource(src string, filename string) Diagnostics {
    return d{
        Sources: AppendSourceContext(d.Sources, NewSourceContext(src, filename)),
    }
}

func (d Diagnostics) Merge(other Diagnostics) Diagnostics {
    return Diagnostics{
        Items: AppendDiagnosticItems(d.Items, other.Items, 0),
        HasError: d.HasError || other.HasError,
        Sources: MergeSourceContexts(d.Sources, other.Sources, 0),
    }
}

func (d Diagnostics) Len() int {
    return len(d.Items)
}

func (d Diagnostics) Snapshot() int {
    return len(d.Items)
}

func (d Diagnostics) Restore(n int) Diagnostics {
    if n < 0 {
        return New()
    }
    if n >= len(d.Items) {
        return d
    }
    trimmed := TrimDiagnostics(d.Items, n, 0, []Diagnostic{})
    return Diagnostics{
        Items: trimmed,
        HasError: AnyError(trimmed),
        Sources: d.Sources,
    }
}

func (d Diagnostics) Format() string {
    if len(d.Sources) > 0 {
        body := FormatAllWithSources(d.Sources, d.Items, 0)
        if len(d.Items) == 0 {
            return body
        }
        return body + "\n" + Summary(d.Items, 0, 0, 0)
    }
    body := JoinDiagnostics(d.Items, 0)
    if len(d.Items) == 0 {
        return body
    }
    return body + "\n" + Summary(d.Items, 0, 0, 0)
}

func (sc SourceContext) FormatDiagnostic(d Diagnostic) string {
    lineBlock := FormatLineBlock(sc.Lines, d.Pos.Line, d.Pos.Column)
    relatedBlock := FormatRelatedBlock(sc, d)
    detailBlock := FormatDetail(d.Detail)
    suggestionBlock := FormatSuggestion(d.Suggestion)
    hintBlock := FormatHint(d.Hint)
    return SeverityHeader(d) + ": " + d.Message +
        "\n  --> " + PosString(d.Pos) +
        lineBlock +
        detailBlock +
        suggestionBlock +
        relatedBlock +
        hintBlock
}

func (sc SourceContext) FormatAll(diags Diagnostics) string {
    body := JoinFormattedDiagnostics(sc, diags.Items, 0)
    if diags.Len() == 0 {
        return body
    }
    return body + "\n" + Summary(diags.Items, 0, 0, 0)
}

func JoinFormattedDiagnostics(sc SourceContext, items []Diagnostic, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := sc.FormatDiagnostic(items[idx])
    if idx + 1 >= len(items) {
        return head
    }
    return head + "\n" + JoinFormattedDiagnostics(sc, items, idx + 1)
}

func FormatAllWithSources(sources []SourceContext, items []Diagnostic, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := FormatDiagnosticWithSources(sources, items[idx])
    if idx + 1 >= len(items) {
        return head
    }
    return head + "\n" + FormatAllWithSources(sources, items, idx + 1)
}

func FormatDiagnosticWithSources(sources []SourceContext, diag Diagnostic) string {
    ctx := FindSourceContext(sources, diag.Pos.File, 0)
    if ctx.Filename == "" {
        if len(sources) == 1 {
            return sources[0].FormatDiagnostic(diag)
        }
    }
    if ctx.Filename == "" {
        return diag.String()
    }
    return ctx.FormatDiagnostic(diag)
}

func FormatLineBlock(lines []string, line int, col int) string {
    if line <= 0 || line > len(lines) {
        return ""
    }
    prev := FormatPrevLine(lines, line)
    text := lines[line - 1]
    next := FormatNextLine(lines, line)
    underline := strings.Repeat(" ", SafeColumn(col) - 1) + "^"
    width := len(fmt.Sprintf("%d", MaxInt(line + 1, line)))
    return prev +
        "\n " + strings.Repeat(" ", width) + " |\n " +
        fmt.Sprintf("%d", line) + " | " + text + "\n " +
        strings.Repeat(" ", width) + " | " + underline +
        next + "\n " +
        strings.Repeat(" ", width) + " |"
}

func FormatHint(hint string) string {
    if hint == "" {
        return ""
    }
    return "\n  hint: " + hint
}

func CodeSuffix(code string) string {
    if code == "" {
        return ""
    }
    return "[" + code + "]"
}

func FormatDetail(detail string) string {
    if detail == "" {
        return ""
    }
    return "\n  detail: " + detail
}

func FormatSuggestion(suggestion string) string {
    if suggestion == "" {
        return ""
    }
    return "\n  did you mean: " + suggestion
}

func FormatInlineRelated(d Diagnostic) string {
    if d.RelatedMessage == "" {
        return ""
    }
    return "\n  related: " + PosString(d.RelatedPos) + ": " + d.RelatedMessage
}

func FormatRelatedBlock(sc SourceContext, d Diagnostic) string {
    if d.RelatedMessage == "" {
        return ""
    }
    related := "\n  related: " + PosString(d.RelatedPos) + ": " + d.RelatedMessage
    if d.RelatedPos.File == sc.Filename {
        if d.RelatedPos.Line > 0 {
            if d.RelatedPos.Line <= len(sc.Lines) {
                return related + FormatLineBlock(sc.Lines, d.RelatedPos.Line, d.RelatedPos.Column)
            }
        }
    }
    return related
}

func SeverityHeader(d Diagnostic) string {
    return SeverityString(d.Severity) + "[" + CategoryString(d.Category) + "]" + CodeSuffix(d.Code)
}

func AppendSourceContext(items []SourceContext, next SourceContext) []SourceContext {
    if next.Filename == "" {
        return items
    }
    if HasSourceContext(items, next.Filename, 0) {
        return items
    }
    return append(items, next)
}

func MergeSourceContexts(left []SourceContext, right []SourceContext, idx int) []SourceContext {
    if idx >= len(right) {
        return left
    }
    return MergeSourceContexts(AppendSourceContext(left, right[idx]), right, idx + 1)
}

func HasSourceContext(items []SourceContext, filename string, idx int) bool {
    if idx >= len(items) {
        return false
    }
    if items[idx].Filename == filename {
        return true
    }
    return HasSourceContext(items, filename, idx + 1)
}

func FindSourceContext(items []SourceContext, filename string, idx int) SourceContext {
    if idx >= len(items) {
        return SourceContext{
            Lines: []string{},
            Filename: "",
        }
    }
    if items[idx].Filename == filename {
        return items[idx]
    }
    return FindSourceContext(items, filename, idx + 1)
}

func AppendDiagnosticItems(left []Diagnostic, right []Diagnostic, idx int) []Diagnostic {
    if idx >= len(right) {
        return left
    }
    return AppendDiagnosticItems(append(left, right[idx]), right, idx + 1)
}

func LineNumberPadding(line int, maxLine int) string {
    width := len(fmt.Sprintf("%d", maxLine))
    return strings.Repeat(" ", width - len(fmt.Sprintf("%d", line)))
}

func FormatPrevLine(lines []string, line int) string {
    if !(line > 1) {
        return ""
    }
    return "\n " + LineNumberPadding(line - 1, line + 1) + fmt.Sprintf("%d", line - 1) + " | " + lines[line - 2]
}

func FormatNextLine(lines []string, line int) string {
    if !(line < len(lines)) {
        return ""
    }
    return "\n " + LineNumberPadding(line + 1, line + 1) + fmt.Sprintf("%d", line + 1) + " | " + lines[line]
}

func SafeColumn(col int) int {
    if col <= 0 {
        return 1
    }
    return col
}

func MaxInt(a int, b int) int {
    if a > b {
        return a
    }
    return b
}

func Summary(items []Diagnostic, idx int, errs int, warns int) string {
    if idx >= len(items) {
        return SummaryCounts(errs, warns)
    }

    item := items[idx]
    match item.Severity {
    case Error:
        return Summary(items, idx + 1, errs + 1, warns)
    case Warning:
        return Summary(items, idx + 1, errs, warns + 1)
    case Info:
        return Summary(items, idx + 1, errs, warns)
    }
}

func SummaryCounts(errs int, warns int) string {
    if errs > 0 {
        if warns > 0 {
            return fmt.Sprintf("%d error(s), %d warning(s)", errs, warns)
        }
        return fmt.Sprintf("%d error(s)", errs)
    }
    if warns > 0 {
        return fmt.Sprintf("%d warning(s)", warns)
    }
    return ""
}

func IsError(s Severity) bool {
    match s {
    case Error:
        return true
    case Warning:
        return false
    case Info:
        return false
    }
}

func AnyError(items []Diagnostic) bool {
    return AnyErrorFrom(items, 0)
}

func AnyErrorFrom(items []Diagnostic, idx int) bool {
    if idx >= len(items) {
        return false
    }
    if IsError(items[idx].Severity) {
        return true
    }
    return AnyErrorFrom(items, idx + 1)
}

func JoinDiagnostics(items []Diagnostic, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := items[idx].String()
    if idx + 1 >= len(items) {
        return head
    }
    return head + "\n" + JoinDiagnostics(items, idx + 1)
}

func TrimDiagnostics(items []Diagnostic, limit int, idx int, acc []Diagnostic) []Diagnostic {
    if idx >= limit {
        return acc
    }
    if idx >= len(items) {
        return acc
    }
    return TrimDiagnostics(items, limit, idx + 1, append(acc, items[idx]))
}
