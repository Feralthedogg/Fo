package codegen

import "github.com/Feralthedogg/Fo/internal/ast"
import "github.com/Feralthedogg/Fo/internal/token"
import "strings"

type EnumVariantInfo struct {
    Name string
    ParentName string
    FieldTypes []string
    TypeParams []string
    Erased bool
}

func EmptyEnumVariantInfo() EnumVariantInfo {
    return EnumVariantInfo{
        Name: "",
        ParentName: "",
        FieldTypes: []string{},
        TypeParams: []string{},
        Erased: false,
    }
}

type EnumInfo struct {
    Name string
    TypeParams []string
    Variants []EnumVariantInfo
}

func EmptyEnumInfo() EnumInfo {
    return EnumInfo{
        Name: "",
        TypeParams: []string{},
        Variants: []EnumVariantInfo{},
    }
}

type CodegenBinding struct {
    Name string
    TypeName string
}

type PipelineStage struct {
    Kind string
    Func ast.Expr
    Init Option[ast.Expr]
}

func EmptyPipelineStage() PipelineStage {
    return PipelineStage{
        Kind: "",
        Func: ast.MakeIdent(ast.ZeroPos(), ""),
        Init: None[ast.Expr](),
    }
}

type PipelineFusion struct {
    Source ast.Expr
    Stages []PipelineStage
}

func EmptyPipelineFusion() PipelineFusion {
    return PipelineFusion{
        Source: ast.MakeIdent(ast.ZeroPos(), ""),
        Stages: []PipelineStage{},
    }
}

type TailLowerInfo struct {
    Ok bool
    Terminal bool
    HasTail bool
}

func MakeTailLowerInfo(ok bool, terminal bool, hasTail bool) TailLowerInfo {
    return TailLowerInfo{
        Ok: ok,
        Terminal: terminal,
        HasTail: hasTail,
    }
}

func Generate(file ast.File) string {
    header := "// Code generated by Fo stage. DO NOT EDIT.\n\n"
    pkg := ast.FilePackageName(file)
    enums := CollectEnumInfos(file.Decls, 0, []EnumInfo{})
    bindings := CollectPackageBindings(file.Decls, enums, 0, []CodegenBinding{})
    decls := GenerateDecls(file.Decls, enums, pkg, bindings)
    imports := GenerateImports(file.Imports, decls)
    if pkg == "" {
        return header + imports + decls
    }
    if imports == "" {
        return header + "package " + pkg + "\n\n" + decls
    }
    return header + "package " + pkg + "\n\n" + imports + "\n" + decls
}

func GenerateImports(imports []ast.ImportDecl, decls string) string {
    basePaths := CollectImportPaths(imports, 0, []string{})
    paths := MaybeAppendPreludeImport(basePaths, decls)
    if len(paths) == 0 {
        return ""
    }
    if len(paths) == 1 {
        return "import " + NormalizeImportPath(paths[0]) + "\n"
    }
    return "import (\n" + GenerateImportPathLines(paths, "    ", 0) + ")\n"
}

func CollectImportPaths(imports []ast.ImportDecl, idx int, acc []string) []string {
    if idx >= len(imports) {
        return acc
    }
    return CollectImportPaths(imports, idx + 1, AppendImportPath(acc, ast.ImportPath(imports[idx])))
}

func MaybeAppendPreludeImport(paths []string, decls string) []string {
    if NeedsPreludeImport(decls) {
        return AppendImportPath(paths, "github.com/Feralthedogg/Fo/stdlib/fo")
    }
    return paths
}

func NeedsPreludeImport(decls string) bool {
    if strings.Contains(decls, "base.Option") || strings.Contains(decls, "base.Result") {
        return true
    }
    if strings.Contains(decls, "base.Some") || strings.Contains(decls, "base.None") {
        return true
    }
    if strings.Contains(decls, "base.Ok") || strings.Contains(decls, "base.Err") {
        return true
    }
    if strings.Contains(decls, "base.UnwrapOr") || strings.Contains(decls, "base.IsNone") || strings.Contains(decls, "base.IsSome") {
        return true
    }
    if strings.Contains(decls, "base.MapOption") || strings.Contains(decls, "base.FlatMapOption") {
        return true
    }
    if strings.Contains(decls, "base.MapResult") || strings.Contains(decls, "base.FlatMapResult") {
        return true
    }
    if strings.Contains(decls, "base.Cmd") || strings.Contains(decls, "base.Task") {
        return true
    }
    return false
}

func AppendImportPath(paths []string, path string) []string {
    if path == "" {
        return paths
    }
    if ContainsString(paths, path, 0) {
        return paths
    }
    return append(paths, path)
}

func ContainsString(items []string, value string, idx int) bool {
    if idx >= len(items) {
        return false
    }
    if items[idx] == value {
        return true
    }
    return ContainsString(items, value, idx + 1)
}

func GenerateImportPathLines(paths []string, indent string, idx int) string {
    if idx >= len(paths) {
        return ""
    }
    return indent + NormalizeImportPath(paths[idx]) + "\n" + GenerateImportPathLines(paths, indent, idx + 1)
}

func NormalizeImportPath(path string) string {
    quote := QuoteString()
    trimmed := StripTrailingQuote(StripLeadingQuote(path, quote), quote)
    return quote + trimmed + quote
}

func StripLeadingQuote(path string, quote string) string {
    next := strings.TrimPrefix(path, quote)
    if next == path {
        return path
    }
    return StripLeadingQuote(next, quote)
}

func StripTrailingQuote(path string, quote string) string {
    next := strings.TrimSuffix(path, quote)
    if next == path {
        return path
    }
    return StripTrailingQuote(next, quote)
}

func QuoteString() string {
    return string(byte(34))
}

func GenerateDecls(decls []ast.Decl, enums []EnumInfo, pkg string, bindings []CodegenBinding) string {
    if len(decls) == 0 {
        return ""
    }
    head := GenerateDecl(decls[0], enums, pkg, bindings)
    tail := GenerateDecls(decls[1:], enums, pkg, bindings)
    if tail == "" {
        return head
    }
    return head + "\n" + tail
}

func GenerateDecl(decl ast.Decl, enums []EnumInfo, pkg string, bindings []CodegenBinding) string {
    if ast.DeclIsFuncDecl(decl) {
        return GenerateFuncDecl(decl, enums, pkg, bindings)
    }
    if ast.DeclIsTypeDecl(decl) {
        return GenerateTypeDecl(decl, enums)
    }
    return "/* unsupported declaration */"
}

func GenerateTypeDecl(decl ast.Decl, enums []EnumInfo) string {
    baseName := ast.DeclName(decl)
    name := baseName + GenerateDeclTypeParams(ast.DeclTypeParams(decl))
    methods := ast.DeclInterfaceMethods(decl)
    if ast.DeclIsInterfaceType(decl) {
        if len(methods) == 0 {
            return "type " + GenerateGoName(name) + " interface{}\n"
        }
        return "type " + GenerateGoName(name) + " interface {\n" + GenerateMethodLines(methods, "    ") + "}"
    }
    variants := ast.DeclEnumVariants(decl)
    if len(variants) > 0 {
        return GenerateEnumDecl(baseName, ast.DeclTypeParams(decl), variants)
    }
    fields := ast.DeclStructFields(decl)
    if ast.DeclIsStructType(decl) {
        if len(fields) == 0 {
            return "type " + GenerateGoName(name) + " struct{}\n"
        }
        return "type " + GenerateGoName(name) + " struct {\n" + GenerateFieldLines(fields, "    ") + "}"
    }
    if len(fields) == 0 {
        return "/* unsupported type decl " + ast.DeclName(decl) + " */"
    }
    return "type " + GenerateGoName(name) + " struct {\n" + GenerateFieldLines(fields, "    ") + "}"
}

func GenerateMethodLines(methods []ast.MethodSig, indent string) string {
    if len(methods) == 0 {
        return ""
    }
    return indent + GenerateMethodSig(methods[0]) + "\n" + GenerateMethodLines(methods[1:], indent)
}

func GenerateMethodSig(method ast.MethodSig) string {
    return GenerateFuncSignature(
        ast.MethodSigName(method),
        []ast.TypeParam{},
        ast.MethodSigParams(method),
        ast.MethodSigResults(method),
    )
}

func GenerateEnumDecl(name string, typeParams []ast.TypeParam, variants []ast.Variant) string {
    return GenerateEnumTagDecl(name, variants) +
        "type " + GenerateGoName(name + GenerateDeclTypeParams(typeParams)) + " struct {\n" +
        GenerateEnumStorageFields(name, variants, 0, "    ") +
        "}\n\n" +
        GenerateEnumConstructors(name, typeParams, variants)
}

func GenerateEnumTagDecl(name string, variants []ast.Variant) string {
    return "type " + EnumTagTypeName(name) + " int\n\n" +
        "const (\n" +
        GenerateEnumTagConstLines(name, variants, 0, "    ") +
        ")\n\n"
}

func GenerateEnumTagConstLines(parent string, variants []ast.Variant, idx int, indent string) string {
    if idx >= len(variants) {
        return ""
    }
    return indent + EnumTagConstName(parent, ast.VariantName(variants[idx])) + " " + EnumTagTypeName(parent) + " = iota\n" +
        GenerateEnumTagConstLines(parent, variants, idx + 1, indent)
}

func EnumTagTypeName(parent string) string {
    return GenerateGoName(parent + "Tag")
}

func EnumTagConstName(parent string, variant string) string {
    return GenerateGoName(parent + variant + "Tag")
}

func EnumTagConstRef(variantName string, tagType string) string {
    return TypeQualifierPrefix(tagType) + EnumTagConstName(ShortBaseTypeName(tagType), variantName)
}

func GenerateEnumStorageFields(parent string, variants []ast.Variant, idx int, indent string) string {
    if idx >= len(variants) {
        return indent + "Tag " + EnumTagTypeName(parent) + "\n"
    }
    if idx == 0 {
        return indent + "Tag " + EnumTagTypeName(parent) + "\n" +
            GenerateEnumVariantStorageFields(variants, idx, indent)
    }
    return GenerateEnumVariantStorageFields(variants, idx, indent)
}

func GenerateEnumVariantStorageFields(variants []ast.Variant, idx int, indent string) string {
    if idx >= len(variants) {
        return ""
    }
    return GenerateEnumVariantFieldLines(ast.VariantName(variants[idx]), ast.VariantFields(variants[idx]), 0, indent) +
        GenerateEnumVariantStorageFields(variants, idx + 1, indent)
}

func GenerateEnumVariantFieldLines(variantName string, fields []ast.TypeExpr, idx int, indent string) string {
    if idx >= len(fields) {
        return ""
    }
    head := indent + EnumStorageFieldName(variantName, idx) + " " + GenerateTypeExpr(fields[idx]) + "\n"
    return head + GenerateEnumVariantFieldLines(variantName, fields, idx + 1, indent)
}

func EnumStorageFieldName(variantName string, idx int) string {
    return GenerateGoName(variantName) + "Value" + IntString(idx)
}

func GenerateEnumConstructors(parent string, typeParams []ast.TypeParam, variants []ast.Variant) string {
    if len(variants) == 0 {
        return ""
    }
    head := GenerateEnumVariant(parent, typeParams, variants[0])
    tail := GenerateEnumConstructors(parent, typeParams, variants[1:])
    if tail == "" {
        return head
    }
    return head + "\n\n" + tail
}

func GenerateEnumVariant(parent string, typeParams []ast.TypeParam, variant ast.Variant) string {
    signature := GenerateFuncSignature(ast.VariantName(variant), typeParams, GenerateEnumConstructorParams(ast.VariantFields(variant), 0, []ast.FieldDef{}), []ast.TypeExpr{EnumResultType(parent, typeParams, variant.TokenPos())})
    body := GenerateEnumConstructorBody(parent, typeParams, variant)
    if body == "" {
        return "func " + signature + " { return " + GenerateVariantReturnType(parent, typeParams) + "{ Tag: " + EnumTagConstName(parent, ast.VariantName(variant)) + " } }"
    }
    return "func " + signature + " { return " + body + " }"
}

func EnumResultType(parent string, typeParams []ast.TypeParam, pos token.Pos) ast.TypeExpr {
    if len(typeParams) == 0 {
        return ast.MakeNamedType(pos, parent)
    }
    return ast.MakeNamedTypeWithArgs(pos, parent, EnumTypeParamExprs(typeParams, 0, []ast.TypeExpr{}))
}

func EnumTypeParamExprs(params []ast.TypeParam, idx int, acc []ast.TypeExpr) []ast.TypeExpr {
    if idx >= len(params) {
        return acc
    }
    return EnumTypeParamExprs(params, idx + 1, append(acc, ast.MakeNamedType(params[idx].Pos, ast.TypeParamName(params[idx]))))
}

func GenerateEnumConstructorParams(fields []ast.TypeExpr, idx int, acc []ast.FieldDef) []ast.FieldDef {
    if idx >= len(fields) {
        return acc
    }
    return GenerateEnumConstructorParams(fields, idx + 1, append(acc, ast.MakeFieldDef(fields[idx].TokenPos(), "value" + IntString(idx), fields[idx])))
}

func GenerateEnumConstructorBody(parent string, typeParams []ast.TypeParam, variant ast.Variant) string {
    if len(ast.VariantFields(variant)) == 0 {
        return GenerateVariantReturnType(parent, typeParams) + "{ Tag: " + EnumTagConstName(parent, ast.VariantName(variant)) + " }"
    }
    return GenerateVariantReturnType(parent, typeParams) + "{ " +
        "Tag: " + EnumTagConstName(parent, ast.VariantName(variant)) +
        GenerateEnumConstructorFieldInits(ast.VariantName(variant), ast.VariantFields(variant), 0) + " }"
}

func GenerateVariantReturnType(parent string, typeParams []ast.TypeParam) string {
    return GenerateGoName(parent) + GenerateTypeParamNamesSuffix(typeParams, 0)
}

func GenerateEnumConstructorFieldInits(variantName string, fields []ast.TypeExpr, idx int) string {
    if idx >= len(fields) {
        return ""
    }
    head := ", " + EnumStorageFieldName(variantName, idx) + ": value" + IntString(idx)
    return head + GenerateEnumConstructorFieldInits(variantName, fields, idx + 1)
}

func GenerateTypeParamNamesSuffix(params []ast.TypeParam, idx int) string {
    if len(params) == 0 {
        return ""
    }
    return "[" + GenerateTypeParamNamesOnly(params, 0) + "]"
}

func GenerateTypeParamNamesOnly(params []ast.TypeParam, idx int) string {
    if idx >= len(params) {
        return ""
    }
    head := ast.TypeParamName(params[idx])
    if idx + 1 >= len(params) {
        return head
    }
    return head + ", " + GenerateTypeParamNamesOnly(params, idx + 1)
}

func GenerateFieldLines(fields []ast.FieldDef, indent string) string {
    if len(fields) == 0 {
        return ""
    }
    return indent + GenerateGoName(ast.FieldName(fields[0])) + " " + GenerateTypeExpr(ast.FieldType(fields[0])) + "\n" +
        GenerateFieldLines(fields[1:], indent)
}

func GenerateFuncDecl(decl ast.Decl, enums []EnumInfo, pkg string, bindings []CodegenBinding) string {
    signature := GenerateFuncSignature(ast.DeclName(decl), ast.DeclTypeParams(decl), ast.DeclParams(decl), ast.DeclResults(decl))
    fullSignature := MaybeReceiverSignature(decl, signature)
    env := ConcatBindings(GenerateFuncBindings(decl), bindings)
    resultTypes := TypeExprNames(ast.DeclResults(decl), 0, []string{})
    if ast.DeclIsExtern(decl) {
        return GenerateExternBridgeDecl(fullSignature, decl, pkg)
    }
    if CanLowerSelfTailCall(decl) {
        return fullSignature + " " + GenerateSelfTailCallBlock(decl, resultTypes, env, enums)
    }
    return fullSignature + " " + GenerateBlock(ast.DeclBodyBlock(decl), "    ", resultTypes, env, enums)
}

func GenerateExternBridgeDecl(fullSignature string, decl ast.Decl, pkg string) string {
    if !(pkg == "main") {
        return fullSignature + " { panic(`extern bridge`) }"
    }
    results := ast.DeclResults(decl)
    if len(results) == 0 {
        return fullSignature + " { base.CallExtern[base.Unit](" + ExternBridgeName(pkg, decl) + GenerateExternBridgeArgs(ast.DeclParams(decl), 0) + ") }"
    }
    if len(results) == 1 {
        return fullSignature + " { return base.CallExtern[" + GenerateTypeExpr(results[0]) + "](" + ExternBridgeName(pkg, decl) + GenerateExternBridgeArgs(ast.DeclParams(decl), 0) + ") }"
    }
    return fullSignature + " { panic(`extern bridge`) }"
}

func ExternBridgeName(pkg string, decl ast.Decl) string {
    return QuoteString() + pkg + "." + ast.DeclName(decl) + QuoteString()
}

func GenerateExternBridgeArgs(params []ast.FieldDef, idx int) string {
    if idx >= len(params) {
        return ""
    }
    return ", " + GenerateGoName(ast.FieldName(params[idx])) + GenerateExternBridgeArgs(params, idx + 1)
}

func CanLowerSelfTailCall(decl ast.Decl) bool {
    if ast.DeclHasReceiver(decl) {
        return false
    }
    info := AnalyzeTailLowerStatements(
        ast.BlockStatements(ast.DeclBodyBlock(decl)),
        ast.DeclName(decl),
        len(ast.DeclParams(decl)),
        len(ast.DeclResults(decl)) == 0,
    )
    if !info.Ok {
        return false
    }
    if !info.Terminal {
        return false
    }
    return info.HasTail
}

func IsSingleReturnBlock(block ast.BlockStmt) bool {
    stmts := ast.BlockStatements(block)
    if len(stmts) < 1 || len(stmts) > 1 {
        return false
    }
    return ast.StmtIsReturn(stmts[0])
}

func GenerateSelfTailCallBlock(decl ast.Decl, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    return "{\n" +
        "    for {\n" +
        GenerateTailLoopStatements(
            ast.BlockStatements(ast.DeclBodyBlock(decl)),
            ast.DeclName(decl),
            ast.DeclParams(decl),
            "        ",
            resultTypes,
            env,
            enums,
        ) +
        "    }\n" +
        "}"
}

func GenerateTailAssignment(params []ast.FieldDef, args []ast.Expr, enums []EnumInfo, idx int) string {
    names := GenerateTailAssignmentNamesFiltered(params, args, idx)
    values := GenerateTailAssignmentValuesFiltered(params, args, enums, idx)
    if names == "" {
        return "/* no-op */"
    }
    return names + " = " + values
}

func GenerateTailAssignmentNamesFiltered(params []ast.FieldDef, args []ast.Expr, idx int) string {
    if idx >= len(params) {
        return ""
    }
    if TailArgMatchesParam(params[idx], args[idx]) {
        return GenerateTailAssignmentNamesFiltered(params, args, idx + 1)
    }
    head := GenerateGoName(ast.FieldName(params[idx]))
    tail := GenerateTailAssignmentNamesFiltered(params, args, idx + 1)
    if tail == "" {
        return head
    }
    return head + ", " + tail
}

func GenerateTailAssignmentValuesFiltered(params []ast.FieldDef, args []ast.Expr, enums []EnumInfo, idx int) string {
    if idx >= len(args) {
        return ""
    }
    if TailArgMatchesParam(params[idx], args[idx]) {
        return GenerateTailAssignmentValuesFiltered(params, args, enums, idx + 1)
    }
    head := GenerateExpr(args[idx], enums)
    tail := GenerateTailAssignmentValuesFiltered(params, args, enums, idx + 1)
    if tail == "" {
        return head
    }
    return head + ", " + tail
}

func TailArgMatchesParam(param ast.FieldDef, arg ast.Expr) bool {
    if ast.ExprIsIdent(arg) {
        return ast.ExprIdentName(arg) == ast.FieldName(param)
    }
    return false
}

func GenerateTailLoopStatements(stmts []ast.Stmt, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(stmts) == 0 {
        return ""
    }
    if IsVoidTailCallPair(stmts, fnName, len(params), len(resultTypes) == 0) {
        return indent + GenerateTailAssignment(params, ast.ExprCallArgs(ast.StmtExprValue(stmts[0])), enums, 0) + "\n" +
            indent + "continue\n"
    }
    stmt := stmts[0]
    rest := stmts[1:]
    if ast.StmtIsBind(stmt) || ast.StmtIsExpr(stmt) {
        nextEnv := CodegenEnvAfterStmt(stmt, env, enums)
        return GenerateStmt(stmt, rest, indent, resultTypes, env, enums) +
            GenerateTailLoopStatements(rest, fnName, params, indent, resultTypes, nextEnv, enums)
    }
    if ast.StmtIsReturn(stmt) {
        if IsTailCallReturnStmt(stmt, fnName, len(params)) {
            return indent + GenerateTailAssignment(params, ast.ExprCallArgs(ast.StmtReturnResults(stmt)[0]), enums, 0) + "\n" +
                indent + "continue\n"
        }
        return GenerateStmt(stmt, rest, indent, resultTypes, env, enums)
    }
    if ast.StmtIsIf(stmt) {
        return indent + "if " + GenerateExpr(ast.StmtIfCond(stmt), enums) + " " +
            GenerateTailLoopBlock(ast.BlockStatements(ast.StmtIfBody(stmt)), fnName, params, indent, indent + "    ", resultTypes, env, enums) + "\n" +
            GenerateTailLoopStatements(rest, fnName, params, indent, resultTypes, env, enums)
    }
    if ast.StmtIsSwitch(stmt) {
        return GenerateTailSwitchStmt(stmt, fnName, params, indent, resultTypes, env, enums) +
            GenerateTailLoopStatements(rest, fnName, params, indent, resultTypes, env, enums)
    }
    if ast.StmtIsMatch(stmt) {
        return GenerateTailMatchStmt(stmt, fnName, params, indent, resultTypes, env, enums) +
            GenerateTailLoopStatements(rest, fnName, params, indent, resultTypes, env, enums)
    }
    return GenerateStmt(stmt, rest, indent, resultTypes, env, enums)
}

func GenerateTailLoopBlock(stmts []ast.Stmt, fnName string, params []ast.FieldDef, outerIndent string, innerIndent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    body := GenerateTailLoopStatements(stmts, fnName, params, innerIndent, resultTypes, env, enums)
    if body == "" {
        return "{\n" + outerIndent + "}"
    }
    return "{\n" + body + outerIndent + "}"
}

func IsTailCallReturnStmt(stmt ast.Stmt, fnName string, paramCount int) bool {
    if !ast.StmtIsReturn(stmt) {
        return false
    }
    results := ast.StmtReturnResults(stmt)
    if !(len(results) == 1) {
        return false
    }
    return IsSelfTailCallExpr(results[0], fnName, paramCount)
}

func GenerateTailSwitchStmt(stmt ast.Stmt, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    head := GenerateSwitchHead(ast.StmtSwitchTag(stmt), indent)
    return head + " {\n" + GenerateTailSwitchCases(ast.StmtSwitchCases(stmt), fnName, params, indent + "    ", resultTypes, env, enums) + indent + "}\n"
}

func GenerateTailSwitchCases(cases []ast.CaseClause, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(cases) == 0 {
        return ""
    }
    return GenerateTailSwitchCase(cases[0], fnName, params, indent, resultTypes, env, enums) +
        GenerateTailSwitchCases(cases[1:], fnName, params, indent, resultTypes, env, enums)
}

func GenerateTailSwitchCase(c ast.CaseClause, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if ast.SwitchCaseIsDefault(c) {
        return indent + "default:\n" + GenerateTailLoopStatements(ast.SwitchCaseBody(c), fnName, params, indent + "    ", resultTypes, env, enums)
    }
    return indent + "case " + GenerateExprs(ast.SwitchCaseExprs(c), enums) + ":\n" +
        GenerateTailLoopStatements(ast.SwitchCaseBody(c), fnName, params, indent + "    ", resultTypes, env, enums)
}

func AnalyzeTailLowerStatements(stmts []ast.Stmt, fnName string, paramCount int, zeroResult bool) TailLowerInfo {
    if len(stmts) == 0 {
        return MakeTailLowerInfo(true, false, false)
    }
    if IsVoidTailCallPair(stmts, fnName, paramCount, zeroResult) {
        return MakeTailLowerInfo(true, true, true)
    }
    stmt := stmts[0]
    rest := stmts[1:]
    if ast.StmtIsBind(stmt) {
        if ExprContainsSelfCall(ast.StmtBindValue(stmt), fnName) {
            return MakeTailLowerInfo(false, false, false)
        }
        return AnalyzeTailLowerStatements(rest, fnName, paramCount, zeroResult)
    }
    if ast.StmtIsExpr(stmt) {
        if ExprContainsSelfCall(ast.StmtExprValue(stmt), fnName) {
            return MakeTailLowerInfo(false, false, false)
        }
        return AnalyzeTailLowerStatements(rest, fnName, paramCount, zeroResult)
    }
    if ast.StmtIsReturn(stmt) {
        return AnalyzeTailReturnStmt(stmt, fnName, paramCount)
    }
    if ast.StmtIsIf(stmt) {
        if ExprContainsSelfCall(ast.StmtIfCond(stmt), fnName) {
            return MakeTailLowerInfo(false, false, false)
        }
        bodyInfo := AnalyzeTailLowerStatements(ast.BlockStatements(ast.StmtIfBody(stmt)), fnName, paramCount, zeroResult)
        if !bodyInfo.Ok {
            return bodyInfo
        }
        restInfo := AnalyzeTailLowerStatements(rest, fnName, paramCount, zeroResult)
        if !restInfo.Ok {
            return restInfo
        }
        return MakeTailLowerInfo(true, restInfo.Terminal, bodyInfo.HasTail || restInfo.HasTail)
    }
    if ast.StmtIsSwitch(stmt) {
        if SwitchTagContainsSelfCall(ast.StmtSwitchTag(stmt), fnName) {
            return MakeTailLowerInfo(false, false, false)
        }
        if SwitchCasesContainSelfCall(ast.StmtSwitchCases(stmt), fnName, 0) {
            return MakeTailLowerInfo(false, false, false)
        }
        casesInfo := AnalyzeTailSwitchCases(ast.StmtSwitchCases(stmt), fnName, paramCount, zeroResult, 0)
        if !casesInfo.Ok {
            return casesInfo
        }
        restInfo := AnalyzeTailLowerStatements(rest, fnName, paramCount, zeroResult)
        if !restInfo.Ok {
            return restInfo
        }
        return MakeTailLowerInfo(
            true,
            TailLowerSwitchTerminal(restInfo.Terminal, casesInfo.Terminal, SwitchCasesHaveDefault(ast.StmtSwitchCases(stmt), 0)),
            TailLowerEither(casesInfo.HasTail, restInfo.HasTail),
        )
    }
    if ast.StmtIsMatch(stmt) {
        if ExprContainsSelfCall(ast.StmtMatchTag(stmt), fnName) {
            return MakeTailLowerInfo(false, false, false)
        }
        casesInfo := AnalyzeTailMatchCases(ast.StmtMatchCases(stmt), fnName, paramCount, zeroResult, 0)
        if !casesInfo.Ok {
            return casesInfo
        }
        restInfo := AnalyzeTailLowerStatements(rest, fnName, paramCount, zeroResult)
        if !restInfo.Ok {
            return restInfo
        }
        return MakeTailLowerInfo(true, restInfo.Terminal || casesInfo.Terminal, casesInfo.HasTail || restInfo.HasTail)
    }
    return MakeTailLowerInfo(false, false, false)
}

func AnalyzeTailReturnStmt(stmt ast.Stmt, fnName string, paramCount int) TailLowerInfo {
    results := ast.StmtReturnResults(stmt)
    if len(results) == 0 {
        return MakeTailLowerInfo(true, true, false)
    }
    if len(results) == 1 {
        if IsSelfTailCallExpr(results[0], fnName, paramCount) {
            return MakeTailLowerInfo(true, true, true)
        }
    }
    if ExprListContainsSelfCall(results, fnName, 0) {
        return MakeTailLowerInfo(false, false, false)
    }
    return MakeTailLowerInfo(true, true, false)
}

func AnalyzeTailSwitchCases(cases []ast.CaseClause, fnName string, paramCount int, zeroResult bool, idx int) TailLowerInfo {
    if idx >= len(cases) {
        return MakeTailLowerInfo(true, true, false)
    }
    head := AnalyzeTailLowerStatements(ast.SwitchCaseBody(cases[idx]), fnName, paramCount, zeroResult)
    if !head.Ok {
        return head
    }
    tail := AnalyzeTailSwitchCases(cases, fnName, paramCount, zeroResult, idx + 1)
    if !tail.Ok {
        return tail
    }
    return MakeTailLowerInfo(true, TailLowerBoth(head.Terminal, tail.Terminal), TailLowerEither(head.HasTail, tail.HasTail))
}

func AnalyzeTailMatchCases(cases []ast.MatchCase, fnName string, paramCount int, zeroResult bool, idx int) TailLowerInfo {
    if idx >= len(cases) {
        return MakeTailLowerInfo(true, true, false)
    }
    head := AnalyzeTailLowerStatements(ast.MatchCaseBody(cases[idx]), fnName, paramCount, zeroResult)
    if !head.Ok {
        return head
    }
    tail := AnalyzeTailMatchCases(cases, fnName, paramCount, zeroResult, idx + 1)
    if !tail.Ok {
        return tail
    }
    return MakeTailLowerInfo(true, TailLowerBoth(head.Terminal, tail.Terminal), TailLowerEither(head.HasTail, tail.HasTail))
}

func TailLowerBoth(left bool, right bool) bool {
    if !left {
        return false
    }
    return right
}

func TailLowerEither(left bool, right bool) bool {
    if left {
        return true
    }
    return right
}

func TailLowerSwitchTerminal(restTerminal bool, casesTerminal bool, hasDefault bool) bool {
    if restTerminal {
        return true
    }
    if !casesTerminal {
        return false
    }
    return hasDefault
}

func IsVoidTailCallPair(stmts []ast.Stmt, fnName string, paramCount int, zeroResult bool) bool {
    if !zeroResult {
        return false
    }
    if len(stmts) < 2 {
        return false
    }
    if !ast.StmtIsExpr(stmts[0]) {
        return false
    }
    if !IsSelfTailCallExpr(ast.StmtExprValue(stmts[0]), fnName, paramCount) {
        return false
    }
    if !ast.StmtIsReturn(stmts[1]) {
        return false
    }
    return len(ast.StmtReturnResults(stmts[1])) == 0
}

func IsSelfTailCallExpr(expr ast.Expr, fnName string, paramCount int) bool {
    if !ast.ExprIsCall(expr) {
        return false
    }
    fn := ast.ExprCallFunc(expr)
    if !ast.ExprIsIdent(fn) {
        return false
    }
    if !StringsEqual(ast.ExprIdentName(fn), fnName) {
        return false
    }
    return len(ast.ExprCallArgs(expr)) == paramCount
}

func SwitchTagContainsSelfCall(tag Option[ast.Expr], fnName string) bool {
    if ast.ExprOptionIsNone(tag) {
        return false
    }
    return ExprContainsSelfCall(ast.ExprOptionValue(tag), fnName)
}

func SwitchCasesContainSelfCall(cases []ast.CaseClause, fnName string, idx int) bool {
    if idx >= len(cases) {
        return false
    }
    if ExprListContainsSelfCall(ast.SwitchCaseExprs(cases[idx]), fnName, 0) {
        return true
    }
    return SwitchCasesContainSelfCall(cases, fnName, idx + 1)
}

func SwitchCasesHaveDefault(cases []ast.CaseClause, idx int) bool {
    if idx >= len(cases) {
        return false
    }
    if ast.SwitchCaseIsDefault(cases[idx]) {
        return true
    }
    return SwitchCasesHaveDefault(cases, idx + 1)
}

func ExprListContainsSelfCall(exprs []ast.Expr, fnName string, idx int) bool {
    if idx >= len(exprs) {
        return false
    }
    if ExprContainsSelfCall(exprs[idx], fnName) {
        return true
    }
    return ExprListContainsSelfCall(exprs, fnName, idx + 1)
}

func ExprContainsSelfCall(expr ast.Expr, fnName string) bool {
    if ast.ExprIsCall(expr) {
        if IsSelfTailCallExpr(expr, fnName, len(ast.ExprCallArgs(expr))) {
            return true
        }
        if ExprContainsSelfCall(ast.ExprCallFunc(expr), fnName) {
            return true
        }
        return ExprListContainsSelfCall(ast.ExprCallArgs(expr), fnName, 0)
    }
    if ast.ExprIsTuple(expr) {
        return ExprListContainsSelfCall(ast.ExprTupleElems(expr), fnName, 0)
    }
    if ast.ExprIsPipeline(expr) {
        if ExprContainsSelfCall(ast.ExprPipelineLeft(expr), fnName) {
            return true
        }
        return ExprContainsSelfCall(ast.ExprPipelineRight(expr), fnName)
    }
    if ast.ExprIsUnary(expr) {
        return ExprContainsSelfCall(ast.ExprUnaryOperand(expr), fnName)
    }
    if ast.ExprIsBinary(expr) {
        if ExprContainsSelfCall(ast.ExprBinaryLeft(expr), fnName) {
            return true
        }
        return ExprContainsSelfCall(ast.ExprBinaryRight(expr), fnName)
    }
    if ast.ExprIsSelector(expr) {
        return ExprContainsSelfCall(ast.ExprSelectorTarget(expr), fnName)
    }
    if ast.ExprIsIndex(expr) {
        if ExprContainsSelfCall(ast.ExprIndexTarget(expr), fnName) {
            return true
        }
        return ExprContainsSelfCall(ast.ExprIndexValue(expr), fnName)
    }
    if ast.ExprIsSlice(expr) {
        if ExprContainsSelfCall(ast.ExprSliceTarget(expr), fnName) {
            return true
        }
        if !ast.ExprOptionIsNone(ast.ExprSliceLow(expr)) {
            if ExprContainsSelfCall(ast.ExprOptionValue(ast.ExprSliceLow(expr)), fnName) {
                return true
            }
        }
        if !ast.ExprOptionIsNone(ast.ExprSliceHigh(expr)) {
            return ExprContainsSelfCall(ast.ExprOptionValue(ast.ExprSliceHigh(expr)), fnName)
        }
        return false
    }
    if ast.ExprIsStructLit(expr) {
        return FieldInitExprsContainSelfCall(ast.ExprStructLitFields(expr), fnName, 0)
    }
    if ast.ExprIsSliceLit(expr) {
        return ExprListContainsSelfCall(ast.ExprSliceLitElems(expr), fnName, 0)
    }
    if ast.ExprIsCopyUpdate(expr) {
        if ExprContainsSelfCall(ast.ExprCopyUpdateSource(expr), fnName) {
            return true
        }
        return FieldUpdateExprsContainSelfCall(ast.ExprCopyUpdateUpdates(expr), fnName, 0)
    }
    if ast.ExprIsFuncLit(expr) {
        return true
    }
    return false
}

func FieldInitExprsContainSelfCall(fields []ast.FieldInit, fnName string, idx int) bool {
    if idx >= len(fields) {
        return false
    }
    if ExprContainsSelfCall(ast.FieldInitExprValue(fields[idx]), fnName) {
        return true
    }
    return FieldInitExprsContainSelfCall(fields, fnName, idx + 1)
}

func FieldUpdateExprsContainSelfCall(fields []ast.FieldUpdate, fnName string, idx int) bool {
    if idx >= len(fields) {
        return false
    }
    if ExprContainsSelfCall(ast.FieldUpdateExprValue(fields[idx]), fnName) {
        return true
    }
    return FieldUpdateExprsContainSelfCall(fields, fnName, idx + 1)
}

func GenerateFuncBindings(decl ast.Decl) []CodegenBinding {
    params := GenerateFieldBindings(ast.DeclParams(decl), 0, []CodegenBinding{})
    if ast.DeclHasReceiver(decl) {
        receiver := ast.DeclReceiverField(decl)
        return append(params, CodegenBinding{
            Name: ast.FieldName(receiver),
            TypeName: GenerateTypeExpr(ast.FieldType(receiver)),
        })
    }
    return params
}

func GenerateFieldBindings(fields []ast.FieldDef, idx int, acc []CodegenBinding) []CodegenBinding {
    if idx >= len(fields) {
        return acc
    }
    return GenerateFieldBindings(fields, idx + 1, append(acc, CodegenBinding{
        Name: ast.FieldName(fields[idx]),
        TypeName: GenerateTypeExpr(ast.FieldType(fields[idx])),
    }))
}

func ConcatBindings(left []CodegenBinding, right []CodegenBinding) []CodegenBinding {
    if len(right) == 0 {
        return left
    }
    return ConcatBindings(append(left, right[0]), right[1:])
}

func CollectPackageBindings(decls []ast.Decl, enums []EnumInfo, idx int, acc []CodegenBinding) []CodegenBinding {
    if idx >= len(decls) {
        return CollectEnumConstructorBindings(enums, 0, acc)
    }
    if ast.DeclIsFuncDecl(decls[idx]) {
        if !ast.DeclHasReceiver(decls[idx]) {
            next := append(acc, CodegenBinding{
                Name: ast.DeclName(decls[idx]),
                TypeName: GenerateFuncTypeExpr(FieldTypesFromDefs(ast.DeclParams(decls[idx]), 0, []ast.TypeExpr{}), ast.DeclResults(decls[idx])),
            })
            return CollectPackageBindings(decls, enums, idx + 1, next)
        }
    }
    return CollectPackageBindings(decls, enums, idx + 1, acc)
}

func FieldTypesFromDefs(fields []ast.FieldDef, idx int, acc []ast.TypeExpr) []ast.TypeExpr {
    if idx >= len(fields) {
        return acc
    }
    return FieldTypesFromDefs(fields, idx + 1, append(acc, ast.FieldType(fields[idx])))
}

func CollectEnumConstructorBindings(enums []EnumInfo, idx int, acc []CodegenBinding) []CodegenBinding {
    if idx >= len(enums) {
        return acc
    }
    next := CollectEnumVariantBindings(enums[idx], 0, acc)
    return CollectEnumConstructorBindings(enums, idx + 1, next)
}

func CollectEnumVariantBindings(info EnumInfo, idx int, acc []CodegenBinding) []CodegenBinding {
    if idx >= len(info.Variants) {
        return acc
    }
    next := append(acc, CodegenBinding{
        Name: info.Variants[idx].Name,
        TypeName: GenerateVariantBindingType(info, info.Variants[idx]),
    })
    return CollectEnumVariantBindings(info, idx + 1, next)
}

func GenerateVariantBindingType(info EnumInfo, variant EnumVariantInfo) string {
    return GenerateFuncTypeStringFromNames(variant.FieldTypes, 0, VariantParentTypeName(variant, []ast.TypeExpr{}))
}

func GenerateFuncTypeStringFromNames(params []string, idx int, result string) string {
    if idx >= len(params) {
        if result == "" {
            return "func()"
        }
        return "func() " + result
    }
    if idx == 0 {
        if result == "" {
            return "func(" + JoinStrings(params, 0) + ")"
        }
        return "func(" + JoinStrings(params, 0) + ") " + result
    }
    return ""
}

func GenerateReceiverPrefix(field ast.FieldDef) string {
    return "(" + GenerateGoName(ast.FieldName(field)) + " " + GenerateTypeExpr(ast.FieldType(field)) + ") "
}

func MaybeReceiverSignature(decl ast.Decl, signature string) string {
    if ast.DeclHasReceiver(decl) {
        return "func " + GenerateReceiverPrefix(ast.DeclReceiverField(decl)) + signature
    }
    return "func " + signature
}

func GenerateFuncSignature(name string, typeParams []ast.TypeParam, params []ast.FieldDef, results []ast.TypeExpr) string {
    suffix := GenerateResultSuffix(results)
    prefix := GenerateGoName(name) + GenerateFuncTypeParams(typeParams, params, results)
    if suffix == "" {
        return prefix + "(" + GenerateParams(params) + ")"
    }
    return prefix + "(" + GenerateParams(params) + ") " + suffix
}

func GenerateFuncTypeParams(typeParams []ast.TypeParam, params []ast.FieldDef, results []ast.TypeExpr) string {
    if len(typeParams) == 0 {
        return ""
    }
    return "[" + GenerateFuncTypeParamItems(typeParams, params, results, 0) + "]"
}

func GenerateFuncTypeParamItems(typeParams []ast.TypeParam, params []ast.FieldDef, results []ast.TypeExpr, idx int) string {
    if idx >= len(typeParams) {
        return ""
    }
    head := ast.TypeParamName(typeParams[idx]) + " " + GenerateEffectiveTypeParamConstraint(typeParams[idx], params, results)
    if idx + 1 >= len(typeParams) {
        return head
    }
    return head + ", " + GenerateFuncTypeParamItems(typeParams, params, results, idx + 1)
}

func GenerateEffectiveTypeParamConstraint(param ast.TypeParam, params []ast.FieldDef, results []ast.TypeExpr) string {
    if NeedsComparableConstraint(ast.TypeParamName(param), params, 0, results, 0) {
        return "comparable"
    }
    return GenerateTypeParamConstraint(ast.TypeParamConstraint(param))
}

func NeedsComparableConstraint(name string, params []ast.FieldDef, paramIdx int, results []ast.TypeExpr, resultIdx int) bool {
    if paramIdx < len(params) {
        if TypeExprUsesMapKeyParam(ast.FieldType(params[paramIdx]), name) {
            return true
        }
        return NeedsComparableConstraint(name, params, paramIdx + 1, results, resultIdx)
    }
    if resultIdx < len(results) {
        if TypeExprUsesMapKeyParam(results[resultIdx], name) {
            return true
        }
        return NeedsComparableConstraint(name, params, paramIdx, results, resultIdx + 1)
    }
    return false
}

func TypeExprUsesMapKeyParam(expr ast.TypeExpr, name string) bool {
    if ast.TypeExprIsMap(expr) {
        if GenerateTypeExpr(ast.TypeExprMapKey(expr)) == name {
            return true
        }
        if TypeExprUsesMapKeyParam(ast.TypeExprMapValue(expr), name) {
            return true
        }
        return false
    }
    if ast.TypeExprIsSlice(expr) {
        return TypeExprUsesMapKeyParam(ast.TypeExprSliceElem(expr), name)
    }
    if ast.TypeExprIsChan(expr) {
        return TypeExprUsesMapKeyParam(ast.TypeExprChanElem(expr), name)
    }
    if ast.TypeExprIsTuple(expr) {
        return TypeExprListUsesMapKeyParam(ast.TypeExprTupleElems(expr), name, 0)
    }
    if ast.TypeExprIsFunc(expr) {
        if TypeExprListUsesMapKeyParam(ast.TypeExprFuncParams(expr), name, 0) {
            return true
        }
        return TypeExprListUsesMapKeyParam(ast.TypeExprFuncResults(expr), name, 0)
    }
    return TypeExprListUsesMapKeyParam(ast.TypeExprNamedArgs(expr), name, 0)
}

func TypeExprListUsesMapKeyParam(items []ast.TypeExpr, name string, idx int) bool {
    if idx >= len(items) {
        return false
    }
    if TypeExprUsesMapKeyParam(items[idx], name) {
        return true
    }
    return TypeExprListUsesMapKeyParam(items, name, idx + 1)
}

func GenerateDeclTypeParams(params []ast.TypeParam) string {
    if len(params) == 0 {
        return ""
    }
    return "[" + GenerateTypeParams(params, 0) + "]"
}

func GenerateTypeParams(params []ast.TypeParam, idx int) string {
    if idx >= len(params) {
        return ""
    }
    head := ast.TypeParamName(params[idx]) + " " + GenerateTypeParamConstraint(ast.TypeParamConstraint(params[idx]))
    if idx + 1 >= len(params) {
        return head
    }
    return head + ", " + GenerateTypeParams(params, idx + 1)
}

func GenerateTypeParamConstraint(value Option[ast.TypeExpr]) string {
    if isNone[ast.TypeExpr](value) {
        return "any"
    }
    return GenerateTypeExpr(unwrapOr[ast.TypeExpr](value, ast.MakeNamedType(ast.ZeroPos(), "any")))
}

func GenerateParams(params []ast.FieldDef) string {
    if len(params) == 0 {
        return ""
    }
    head := GenerateParam(params[0])
    if len(params) == 1 {
        return head
    }
    return head + ", " + GenerateParams(params[1:])
}

func GenerateParam(field ast.FieldDef) string {
    if ast.FieldIsVariadic(field) {
        if ast.TypeExprIsSlice(ast.FieldType(field)) {
            return GenerateGoName(ast.FieldName(field)) + " ..." + GenerateTypeExpr(ast.TypeExprSliceElem(ast.FieldType(field)))
        }
    }
    return GenerateGoName(ast.FieldName(field)) + " " + GenerateTypeExpr(ast.FieldType(field))
}

func GenerateResultSuffix(results []ast.TypeExpr) string {
    if len(results) == 0 {
        return ""
    }
    if len(results) == 1 {
        return GenerateTypeExpr(results[0])
    }
    return "(" + GenerateTypeExprs(results) + ")"
}

func GenerateTypeExprs(results []ast.TypeExpr) string {
    if len(results) == 0 {
        return ""
    }
    if len(results) == 1 {
        return GenerateTypeExpr(results[0])
    }
    return GenerateTypeExpr(results[0]) + ", " + GenerateTypeExprs(results[1:])
}

func GenerateTypeExpr(expr ast.TypeExpr) string {
    if ast.TypeExprIsQualified(expr) {
        baseName := ast.TypeExprQualifiedPackage(expr) + "." + GenerateGoName(ast.TypeExprQualifiedName(expr))
        return baseName + GenerateTypeArgSuffix(ast.TypeExprQualifiedArgs(expr))
    }
    if ast.TypeExprIsMap(expr) {
        return "map[" + GenerateTypeExpr(ast.TypeExprMapKey(expr)) + "]" + GenerateTypeExpr(ast.TypeExprMapValue(expr))
    }
    if ast.TypeExprIsTuple(expr) {
        return GenerateTupleTypeExpr(ast.TypeExprTupleElems(expr), 0)
    }
    if ast.TypeExprIsSlice(expr) {
        return "[]" + GenerateTypeExpr(ast.TypeExprSliceElem(expr))
    }
    if ast.TypeExprIsChan(expr) {
        if ast.TypeExprChanReceiveOnly(expr) {
            return "<-chan " + GenerateTypeExpr(ast.TypeExprChanElem(expr))
        }
        return "chan " + GenerateTypeExpr(ast.TypeExprChanElem(expr))
    }
    if ast.TypeExprIsFunc(expr) {
        return GenerateFuncTypeExpr(ast.TypeExprFuncParams(expr), ast.TypeExprFuncResults(expr))
    }
    name := ast.TypeExprNamedName(expr)
    if name == "" {
        return "any"
    }
    prelude := PreludeTypeName(name)
    if prelude == "" {
        return GenerateGoName(name) + GenerateTypeArgSuffix(ast.TypeExprNamedArgs(expr))
    }
    return prelude + GenerateTypeArgSuffix(ast.TypeExprNamedArgs(expr))
}

func GenerateTypeArgSuffix(args []ast.TypeExpr) string {
    if len(args) == 0 {
        return ""
    }
    return "[" + GenerateTypeExprs(args) + "]"
}

func GenerateTupleTypeExpr(items []ast.TypeExpr, idx int) string {
    if len(items) == 0 {
        return "struct{}"
    }
    return "struct{ " + GenerateTupleTypeFields(items, 0) + " }"
}

func GenerateTupleTypeFields(items []ast.TypeExpr, idx int) string {
    if idx >= len(items) {
        return ""
    }
    head := "V" + IntString(idx) + " " + GenerateTypeExpr(items[idx]) + ";"
    return head + GenerateTupleTypeFields(items, idx + 1)
}

func GenerateFuncTypeExpr(params []ast.TypeExpr, results []ast.TypeExpr) string {
    suffix := GenerateResultSuffix(results)
    if suffix == "" {
        return "func(" + GenerateTypeExprs(params) + ")"
    }
    return "func(" + GenerateTypeExprs(params) + ") " + suffix
}

func GenerateBlock(block ast.BlockStmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    body := GenerateStatements(ast.BlockStatements(block), indent, resultTypes, env, enums)
    if body == "" {
        return "{\n}"
    }
    return "{\n" + body + "}"
}

func GenerateStatements(stmts []ast.Stmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(stmts) == 0 {
        return ""
    }
    fusedPair := GenerateBindReturnPipelineFusion(stmts, indent, resultTypes, env, enums)
    if HasText(fusedPair) {
        tail := GenerateStatements(stmts[2:], indent, resultTypes, CodegenEnvAfterStmt(stmts[0], env, enums), enums)
        return fusedPair + tail
    }
    head := GenerateStmt(stmts[0], stmts[1:], indent, resultTypes, env, enums)
    tail := GenerateStatements(stmts[1:], indent, resultTypes, CodegenEnvAfterStmt(stmts[0], env, enums), enums)
    return head + tail
}

func GenerateStmt(stmt ast.Stmt, tail []ast.Stmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if ast.StmtIsBind(stmt) {
        names := ast.StmtBindNames(stmt)
        if len(names) == 0 {
            return indent + "/* unsupported bind */\n"
        }
        if len(names) > 1 {
            if ast.ExprIsTuple(ast.StmtBindValue(stmt)) {
                return indent + JoinNameList(names, 0) + " := " + GenerateExprs(ast.ExprTupleElems(ast.StmtBindValue(stmt)), enums) + "\n"
            }
            return indent + JoinNameList(names, 0) + " := " + GenerateExpr(ast.StmtBindValue(stmt), enums) + "\n"
        }
        fused := GenerateBindPipelineFusion(names[0], ast.StmtBindValue(stmt), indent, env, enums)
        if HasText(fused) {
            return fused
        }
        if ast.ExprIsCopyUpdate(ast.StmtBindValue(stmt)) {
            return GenerateBindCopyUpdate(names[0], ast.StmtBindValue(stmt), tail, indent, enums)
        }
        return indent + GenerateGoName(names[0]) + " := " + GenerateExpr(ast.StmtBindValue(stmt), enums) + "\n"
    }
    if ast.StmtIsIf(stmt) {
        return indent + "if " + GenerateExpr(ast.StmtIfCond(stmt), enums) + " " +
            GenerateBlock(ast.StmtIfBody(stmt), indent + "    ", resultTypes, env, enums) + "\n"
    }
    if ast.StmtIsSwitch(stmt) {
        return GenerateSwitchStmt(stmt, indent, resultTypes, env, enums)
    }
    if ast.StmtIsMatch(stmt) {
        return GenerateMatchStmt(stmt, indent, resultTypes, env, enums)
    }
    if ast.StmtIsReturn(stmt) {
        results := ast.StmtReturnResults(stmt)
        if len(results) == 0 {
            return indent + "return\n"
        }
        if len(results) == 1 {
            if len(resultTypes) > 1 {
                if ast.ExprIsTuple(results[0]) {
                    return indent + "return " + GenerateExprs(ast.ExprTupleElems(results[0]), enums) + "\n"
                }
            }
        }
        if len(results) == 1 {
            fused := GenerateReturnPipelineFusion(results[0], indent, resultTypes, enums)
            if HasText(fused) {
                return fused
            }
        }
        if len(results) == 1 {
            if ast.ExprIsCopyUpdate(results[0]) {
                return GenerateReturnCopyUpdate(results[0], indent, enums)
            }
        }
        return indent + "return " + GenerateExprs(results, enums) + "\n"
    }
    if ast.StmtIsExpr(stmt) {
        return indent + GenerateExpr(ast.StmtExprValue(stmt), enums) + "\n"
    }
    return indent + "/* unsupported statement */\n"
}

func CodegenEnvAfterStmt(stmt ast.Stmt, env []CodegenBinding, enums []EnumInfo) []CodegenBinding {
    if !ast.StmtIsBind(stmt) {
        return env
    }
    names := ast.StmtBindNames(stmt)
    if len(names) == 0 {
        return env
    }
    inferred := InferExprTypeName(ast.StmtBindValue(stmt), env, enums)
    if !HasText(inferred) {
        return env
    }
    return ExtendCodegenEnv(names, inferred, env, 0)
}

func ExtendCodegenEnv(names []string, inferred string, env []CodegenBinding, idx int) []CodegenBinding {
    if len(names) == 0 {
        return env
    }
    if len(names) == 1 {
        return append(env, CodegenBinding{
            Name: names[0],
            TypeName: inferred,
        })
    }
    elems := ParseTupleTypeNames(inferred)
    if len(elems) == len(names) {
        return ExtendCodegenTupleEnv(names, elems, env, 0)
    }
    return env
}

func ExtendCodegenTupleEnv(names []string, elems []string, env []CodegenBinding, idx int) []CodegenBinding {
    if idx >= len(names) {
        return env
    }
    next := append(env, CodegenBinding{
        Name: names[idx],
        TypeName: elems[idx],
    })
    return ExtendCodegenTupleEnv(names, elems, next, idx + 1)
}

func GenerateExprs(exprs []ast.Expr, enums []EnumInfo) string {
    if len(exprs) == 0 {
        return ""
    }
    if len(exprs) == 1 {
        return GenerateExpr(exprs[0], enums)
    }
    return GenerateExpr(exprs[0], enums) + ", " + GenerateExprs(exprs[1:], enums)
}

func JoinNameList(items []string, idx int) string {
    if idx >= len(items) {
        return ""
    }
    if idx + 1 >= len(items) {
        return GenerateGoName(items[idx])
    }
    return GenerateGoName(items[idx]) + ", " + JoinNameList(items, idx + 1)
}

func GenerateBindCopyUpdate(name string, expr ast.Expr, tail []ast.Stmt, indent string, enums []EnumInfo) string {
    source := ast.ExprCopyUpdateSource(expr)
    sourceName := CopyUpdateSourceName(source)
    if HasText(sourceName) {
        if !StringsEqual(sourceName, name) {
            if !StatementsMentionName(tail, sourceName, 0) {
                tempPrefix := "_copyUpdate"
                return GenerateCopyUpdateTempValues(tempPrefix, ast.ExprCopyUpdateUpdates(expr), indent, enums, 0) +
                    GenerateCopyUpdateTempAssignments(sourceName, ast.ExprCopyUpdateUpdates(expr), tempPrefix, indent, 0) +
                    indent + GenerateGoName(name) + " := " + GenerateGoName(sourceName) + "\n"
            }
        }
    }
    return indent + GenerateGoName(name) + " := " + GenerateExpr(source, enums) + "\n" +
        GenerateCopyUpdateAssignments(GenerateGoName(name), ast.ExprCopyUpdateUpdates(expr), indent, enums)
}

func GenerateReturnCopyUpdate(expr ast.Expr, indent string, enums []EnumInfo) string {
    source := ast.ExprCopyUpdateSource(expr)
    sourceName := CopyUpdateSourceName(source)
    if HasText(sourceName) {
        tempPrefix := "_copyUpdate"
        return GenerateCopyUpdateTempValues(tempPrefix, ast.ExprCopyUpdateUpdates(expr), indent, enums, 0) +
            GenerateCopyUpdateTempAssignments(sourceName, ast.ExprCopyUpdateUpdates(expr), tempPrefix, indent, 0) +
            indent + "return " + GenerateGoName(sourceName) + "\n"
    }
    tmp := "_updated"
    return indent + tmp + " := " + GenerateExpr(source, enums) + "\n" +
        GenerateCopyUpdateAssignments(tmp, ast.ExprCopyUpdateUpdates(expr), indent, enums) +
        indent + "return " + tmp + "\n"
}

func GenerateCopyUpdateAssignments(target string, updates []ast.FieldUpdate, indent string, enums []EnumInfo) string {
    if len(updates) == 0 {
        return ""
    }
    head := indent + GenerateFieldPath(target, ast.FieldUpdatePathValue(updates[0])) +
        " = " + GenerateExpr(ast.FieldUpdateExprValue(updates[0]), enums) + "\n"
    return head + GenerateCopyUpdateAssignments(target, updates[1:], indent, enums)
}

func GenerateCopyUpdateTempValues(prefix string, updates []ast.FieldUpdate, indent string, enums []EnumInfo, idx int) string {
    if idx >= len(updates) {
        return ""
    }
    head := indent + prefix + IntString(idx) + " := " + GenerateExpr(ast.FieldUpdateExprValue(updates[idx]), enums) + "\n"
    return head + GenerateCopyUpdateTempValues(prefix, updates, indent, enums, idx + 1)
}

func GenerateCopyUpdateTempAssignments(target string, updates []ast.FieldUpdate, prefix string, indent string, idx int) string {
    if idx >= len(updates) {
        return ""
    }
    head := indent + GenerateFieldPath(GenerateGoName(target), ast.FieldUpdatePathValue(updates[idx])) + " = " + prefix + IntString(idx) + "\n"
    return head + GenerateCopyUpdateTempAssignments(target, updates, prefix, indent, idx + 1)
}

func CopyUpdateSourceName(expr ast.Expr) string {
    if ast.ExprIsIdent(expr) {
        return ast.ExprIdentName(expr)
    }
    return ""
}

func StatementsMentionName(stmts []ast.Stmt, name string, idx int) bool {
    if idx >= len(stmts) {
        return false
    }
    if StmtMentionsName(stmts[idx], name) {
        return true
    }
    return StatementsMentionName(stmts, name, idx + 1)
}

func StmtMentionsName(stmt ast.Stmt, name string) bool {
    if ast.StmtIsBind(stmt) {
        return ExprMentionsName(ast.StmtBindValue(stmt), name)
    }
    if ast.StmtIsIf(stmt) {
        if ExprMentionsName(ast.StmtIfCond(stmt), name) {
            return true
        }
        return StatementsMentionName(ast.BlockStatements(ast.StmtIfBody(stmt)), name, 0)
    }
    if ast.StmtIsSwitch(stmt) {
        if !ast.ExprOptionIsNone(ast.StmtSwitchTag(stmt)) {
            if ExprMentionsName(ast.ExprOptionValue(ast.StmtSwitchTag(stmt)), name) {
                return true
            }
        }
        return SwitchCasesMentionName(ast.StmtSwitchCases(stmt), name, 0)
    }
    if ast.StmtIsMatch(stmt) {
        if ExprMentionsName(ast.StmtMatchTag(stmt), name) {
            return true
        }
        return MatchCasesMentionName(ast.StmtMatchCases(stmt), name, 0)
    }
    if ast.StmtIsReturn(stmt) {
        return ExprListMentionsName(ast.StmtReturnResults(stmt), name, 0)
    }
    if ast.StmtIsExpr(stmt) {
        return ExprMentionsName(ast.StmtExprValue(stmt), name)
    }
    return false
}

func SwitchCasesMentionName(cases []ast.CaseClause, name string, idx int) bool {
    if idx >= len(cases) {
        return false
    }
    if ExprListMentionsName(ast.SwitchCaseExprs(cases[idx]), name, 0) {
        return true
    }
    if StatementsMentionName(ast.SwitchCaseBody(cases[idx]), name, 0) {
        return true
    }
    return SwitchCasesMentionName(cases, name, idx + 1)
}

func MatchCasesMentionName(cases []ast.MatchCase, name string, idx int) bool {
    if idx >= len(cases) {
        return false
    }
    if StatementsMentionName(ast.MatchCaseBody(cases[idx]), name, 0) {
        return true
    }
    return MatchCasesMentionName(cases, name, idx + 1)
}

func ExprListMentionsName(exprs []ast.Expr, name string, idx int) bool {
    if idx >= len(exprs) {
        return false
    }
    if ExprMentionsName(exprs[idx], name) {
        return true
    }
    return ExprListMentionsName(exprs, name, idx + 1)
}

func ExprMentionsName(expr ast.Expr, name string) bool {
    if ast.ExprIsIdent(expr) {
        return ast.ExprIdentName(expr) == name
    }
    if ast.ExprIsTuple(expr) {
        return ExprListMentionsName(ast.ExprTupleElems(expr), name, 0)
    }
    if ast.ExprIsPipeline(expr) {
        if ExprMentionsName(ast.ExprPipelineLeft(expr), name) {
            return true
        }
        return ExprMentionsName(ast.ExprPipelineRight(expr), name)
    }
    if ast.ExprIsUnary(expr) {
        return ExprMentionsName(ast.ExprUnaryOperand(expr), name)
    }
    if ast.ExprIsBinary(expr) {
        if ExprMentionsName(ast.ExprBinaryLeft(expr), name) {
            return true
        }
        return ExprMentionsName(ast.ExprBinaryRight(expr), name)
    }
    if ast.ExprIsCall(expr) {
        if ExprMentionsName(ast.ExprCallFunc(expr), name) {
            return true
        }
        return ExprListMentionsName(ast.ExprCallArgs(expr), name, 0)
    }
    if ast.ExprIsSelector(expr) {
        return ExprMentionsName(ast.ExprSelectorTarget(expr), name)
    }
    if ast.ExprIsIndex(expr) {
        if ExprMentionsName(ast.ExprIndexTarget(expr), name) {
            return true
        }
        return ExprMentionsName(ast.ExprIndexValue(expr), name)
    }
    if ast.ExprIsSlice(expr) {
        if ExprMentionsName(ast.ExprSliceTarget(expr), name) {
            return true
        }
        if !ast.ExprOptionIsNone(ast.ExprSliceLow(expr)) {
            if ExprMentionsName(ast.ExprOptionValue(ast.ExprSliceLow(expr)), name) {
                return true
            }
        }
        if !ast.ExprOptionIsNone(ast.ExprSliceHigh(expr)) {
            return ExprMentionsName(ast.ExprOptionValue(ast.ExprSliceHigh(expr)), name)
        }
        return false
    }
    if ast.ExprIsStructLit(expr) {
        return FieldInitExprsMentionName(ast.ExprStructLitFields(expr), name, 0)
    }
    if ast.ExprIsSliceLit(expr) {
        return ExprListMentionsName(ast.ExprSliceLitElems(expr), name, 0)
    }
    if ast.ExprIsFuncLit(expr) {
        return StatementsMentionName(ast.BlockStatements(ast.ExprFuncLitBody(expr)), name, 0)
    }
    if ast.ExprIsCopyUpdate(expr) {
        if ExprMentionsName(ast.ExprCopyUpdateSource(expr), name) {
            return true
        }
        return FieldUpdateExprsMentionName(ast.ExprCopyUpdateUpdates(expr), name, 0)
    }
    return false
}

func FieldInitExprsMentionName(fields []ast.FieldInit, name string, idx int) bool {
    if idx >= len(fields) {
        return false
    }
    if ExprMentionsName(ast.FieldInitExprValue(fields[idx]), name) {
        return true
    }
    return FieldInitExprsMentionName(fields, name, idx + 1)
}

func FieldUpdateExprsMentionName(fields []ast.FieldUpdate, name string, idx int) bool {
    if idx >= len(fields) {
        return false
    }
    if ExprMentionsName(ast.FieldUpdateExprValue(fields[idx]), name) {
        return true
    }
    return FieldUpdateExprsMentionName(fields, name, idx + 1)
}

func GenerateFieldPath(target string, path []string) string {
    if len(path) == 0 {
        return target
    }
    return target + "." + GenerateFieldPathTail(path)
}

func GenerateFieldPathTail(path []string) string {
    if len(path) == 0 {
        return ""
    }
    if len(path) == 1 {
        return GenerateGoName(path[0])
    }
    return GenerateGoName(path[0]) + "." + GenerateFieldPathTail(path[1:])
}

func GenerateExpr(expr ast.Expr, enums []EnumInfo) string {
    if ast.ExprIsTuple(expr) {
        return GenerateTupleExpr(ast.ExprTupleElems(expr), enums)
    }
    if ast.ExprIsPipeline(expr) {
        return GeneratePipelineExpr(ast.ExprPipelineLeft(expr), ast.ExprPipelineRight(expr), enums)
    }
    if ast.ExprIsUnary(expr) {
        return token.TypeString(ast.ExprUnaryOp(expr)) + GenerateExpr(ast.ExprUnaryOperand(expr), enums)
    }
    if ast.ExprIsBinary(expr) {
        return "(" + GenerateExpr(ast.ExprBinaryLeft(expr), enums) + " " +
            token.TypeString(ast.ExprBinaryOp(expr)) + " " +
            GenerateExpr(ast.ExprBinaryRight(expr), enums) + ")"
    }
    if ast.ExprIsCall(expr) {
        return GenerateCallExpr(expr, enums)
    }
    if ast.ExprIsSelector(expr) {
        return GenerateExpr(ast.ExprSelectorTarget(expr), enums) + "." + GenerateGoName(ast.ExprSelectorField(expr))
    }
    if ast.ExprIsIndex(expr) {
        return GenerateExpr(ast.ExprIndexTarget(expr), enums) + "[" + GenerateExpr(ast.ExprIndexValue(expr), enums) + "]"
    }
    if ast.ExprIsSlice(expr) {
        return GenerateExpr(ast.ExprSliceTarget(expr), enums) + "[" +
            GenerateOptionalExpr(ast.ExprSliceLow(expr), enums) + ":" +
            GenerateOptionalExpr(ast.ExprSliceHigh(expr), enums) + "]"
    }
    if ast.ExprIsStructLit(expr) {
        return GenerateStructLit(ast.ExprStructLitType(expr), ast.ExprStructLitFields(expr), enums)
    }
    if ast.ExprIsSliceLit(expr) {
        return GenerateSliceLit(ast.ExprSliceLitType(expr), ast.ExprSliceLitElems(expr), enums)
    }
    if ast.ExprIsFuncLit(expr) {
        return GenerateFuncLitExpr(ast.ExprFuncLitParams(expr), ast.ExprFuncLitResults(expr), ast.ExprFuncLitBody(expr), enums)
    }
    if ast.ExprIsIdent(expr) {
        name := ast.ExprIdentName(expr)
        info := FindVariantInfo(name, enums)
        if !isNone[EnumVariantInfo](info) {
            item := unwrapOr[EnumVariantInfo](info, EmptyEnumVariantInfo())
            if len(item.FieldTypes) == 0 {
                return GenerateGoName(item.Name) + GenerateTypeParamValueSuffix(item.TypeParams, 0) + "()"
            }
        }
        mappedFunc := PreludeFuncName(name)
        if mappedFunc == "" {
            mappedType := PreludeTypeName(name)
            if mappedType == "" {
                return GenerateGoName(name)
            }
            return mappedType
        }
        return mappedFunc
    }
    if ast.ExprIsBasicLit(expr) {
        return ast.ExprBasicLitValue(expr)
    }
    return "nil /* unsupported expr */"
}

func GenerateFuncLitExpr(params []ast.FieldDef, results []ast.TypeExpr, body ast.BlockStmt, enums []EnumInfo) string {
    suffix := GenerateResultSuffix(results)
    env := GenerateFieldBindings(params, 0, []CodegenBinding{})
    resultTypes := TypeExprNames(results, 0, []string{})
    if suffix == "" {
        return "func(" + GenerateParams(params) + ") " + GenerateBlock(body, "    ", resultTypes, env, enums)
    }
    return "func(" + GenerateParams(params) + ") " + suffix + " " + GenerateBlock(body, "    ", resultTypes, env, enums)
}

func GenerateCallExpr(expr ast.Expr, enums []EnumInfo) string {
    fn := ast.ExprCallFunc(expr)
    info := FindVariantInfoByExpr(fn, enums)
    if !isNone[EnumVariantInfo](info) {
        item := unwrapOr[EnumVariantInfo](info, EmptyEnumVariantInfo())
        return GenerateConstructorExpr(item, ast.ExprCallTypeArgs(expr), ast.ExprCallArgs(expr), enums)
    }
    if ast.ExprIsIdent(fn) {
        preludeCtor := GeneratePreludeConstructorExpr(ast.ExprIdentName(fn), ast.ExprCallTypeArgs(expr), ast.ExprCallArgs(expr), enums)
        if HasText(preludeCtor) {
            return preludeCtor
        }
    }
    return GenerateExpr(fn, enums) +
        GenerateTypeArgSuffix(ast.ExprCallTypeArgs(expr)) +
        "(" + GenerateExprs(ast.ExprCallArgs(expr), enums) + ")"
}

func GeneratePreludeConstructorExpr(name string, typeArgs []ast.TypeExpr, args []ast.Expr, enums []EnumInfo) string {
    if name == "None" {
        return "base.None" + GenerateTypeArgSuffix(typeArgs) + "()"
    }
    if name == "Some" {
        return "base.Some" + GenerateTypeArgSuffix(typeArgs) + "(" + GenerateExprs(args, enums) + ")"
    }
    if name == "Ok" {
        return "base.Ok" + GenerateTypeArgSuffix(typeArgs) + "(" + GenerateExprs(args, enums) + ")"
    }
    if name == "Err" {
        return "base.Err" + GenerateTypeArgSuffix(typeArgs) + "(" + GenerateExprs(args, enums) + ")"
    }
    return ""
}

func GenerateConstructorExpr(info EnumVariantInfo, typeArgs []ast.TypeExpr, args []ast.Expr, enums []EnumInfo) string {
    return GenerateVariantTypeRef(info, typeArgs) + "(" + GenerateExprs(args, enums) + ")"
}

func GenerateVariantTypeRef(info EnumVariantInfo, typeArgs []ast.TypeExpr) string {
    name := GenerateGoName(info.Name)
    if len(info.TypeParams) == 0 {
        return name
    }
    if len(typeArgs) > 0 {
        return name + GenerateTypeArgSuffix(typeArgs)
    }
    return name + "[" + JoinStrings(info.TypeParams, 0) + "]"
}

func GenerateTypeParamValueSuffix(params []string, idx int) string {
    if len(params) == 0 {
        return ""
    }
    return "[" + JoinStrings(params, 0) + "]"
}

func GenerateConstructorFields(args []ast.Expr, idx int, enums []EnumInfo) string {
    if idx >= len(args) {
        return ""
    }
    head := "Value" + IntString(idx) + ": " + GenerateExpr(args[idx], enums)
    if idx + 1 >= len(args) {
        return head
    }
    return head + ", " + GenerateConstructorFields(args, idx + 1, enums)
}

func GenerateTupleExpr(elems []ast.Expr, enums []EnumInfo) string {
    if len(elems) == 0 {
        return "struct{}{}"
    }
    return "struct{ " + GenerateTupleFieldTypes(elems, 0) + " }{ " + GenerateTupleFieldValues(elems, 0, enums) + " }"
}

func GenerateTupleFieldTypes(elems []ast.Expr, idx int) string {
    if idx >= len(elems) {
        return ""
    }
    head := "V" + IntString(idx) + " any;"
    return head + GenerateTupleFieldTypes(elems, idx + 1)
}

func GenerateTupleFieldValues(elems []ast.Expr, idx int, enums []EnumInfo) string {
    if idx >= len(elems) {
        return ""
    }
    head := "V" + IntString(idx) + ": " + GenerateExpr(elems[idx], enums)
    if idx + 1 >= len(elems) {
        return head
    }
    return head + ", " + GenerateTupleFieldValues(elems, idx + 1, enums)
}

func GeneratePipelineExpr(left ast.Expr, right ast.Expr, enums []EnumInfo) string {
    if ast.ExprIsCall(right) {
        return GenerateExpr(ast.ExprCallFunc(right), enums) + "(" +
            GeneratePipelineArgs(left, ast.ExprCallArgs(right), enums) + ")"
    }
    return GenerateExpr(right, enums) + "(" + GenerateExpr(left, enums) + ")"
}

func GeneratePipelineArgs(first ast.Expr, rest []ast.Expr, enums []EnumInfo) string {
    if len(rest) == 0 {
        return GenerateExpr(first, enums)
    }
    return GenerateExpr(first, enums) + ", " + GenerateExprs(rest, enums)
}

func GenerateReturnPipelineFusion(expr ast.Expr, indent string, resultTypes []string, enums []EnumInfo) string {
    if !(len(resultTypes) == 1) {
        return ""
    }
    fusion := ExtractPipelineFusion(expr)
    if len(fusion.Stages) == 0 {
        return ""
    }
    if !PipelineStagesAreFusible(fusion.Stages, 0) {
        return ""
    }
    sourceVar := "_pipeSourceRet"
    accVar := "_pipeAccRet"
    itemVar := "_pipeItemRet"
    accInit := GeneratePipelineAccumulatorBinding(accVar, sourceVar, resultTypes[0], fusion.Stages, indent, enums)
    if accInit == "" {
        return ""
    }
    return indent + sourceVar + " := " + GenerateExpr(fusion.Source, enums) + "\n" +
        accInit +
        indent + "for _, " + itemVar + " := range " + sourceVar + " {\n" +
        GeneratePipelineLoopBody(fusion.Stages, 0, itemVar, accVar, indent + "    ", enums) +
        indent + "}\n" +
        indent + "return " + accVar + "\n"
}

func GenerateBindPipelineFusion(name string, expr ast.Expr, indent string, env []CodegenBinding, enums []EnumInfo) string {
    fusion := ExtractPipelineFusion(expr)
    if len(fusion.Stages) == 0 {
        return ""
    }
    if !PipelineStagesAreFusible(fusion.Stages, 0) {
        return ""
    }
    resultType := InferPipelineFusionResultType(fusion, env, enums)
    if !HasText(resultType) {
        return ""
    }
    sourceVar := "_pipeSource" + TitleName(name)
    itemVar := "_pipeItem" + TitleName(name)
    init := GeneratePipelineAccumulatorBinding(GenerateGoName(name), sourceVar, resultType, fusion.Stages, indent, enums)
    if !HasText(init) {
        return ""
    }
    return indent + sourceVar + " := " + GenerateExpr(fusion.Source, enums) + "\n" +
        init +
        indent + "for _, " + itemVar + " := range " + sourceVar + " {\n" +
        GeneratePipelineLoopBody(fusion.Stages, 0, itemVar, GenerateGoName(name), indent + "    ", enums) +
        indent + "}\n"
}

func GenerateBindReturnPipelineFusion(stmts []ast.Stmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(stmts) < 2 {
        return ""
    }
    bindStmt := stmts[0]
    retStmt := stmts[1]
    if !ast.StmtIsBind(bindStmt) {
        return ""
    }
    if !ast.StmtIsReturn(retStmt) {
        return ""
    }
    names := ast.StmtBindNames(bindStmt)
    if !(len(names) == 1) {
        return ""
    }
    results := ast.StmtReturnResults(retStmt)
    if !(len(results) == 1) {
        return ""
    }
    bindFusion := ExtractPipelineFusion(ast.StmtBindValue(bindStmt))
    if len(bindFusion.Stages) == 0 {
        return ""
    }
    retFusion := ExtractPipelineFusion(results[0])
    if len(retFusion.Stages) == 0 {
        return ""
    }
    if !ast.ExprIsIdent(retFusion.Source) {
        return ""
    }
    if !StringsEqual(ast.ExprIdentName(retFusion.Source), names[0]) {
        return ""
    }
    combined := ConcatPipelineStages(bindFusion.Stages, retFusion.Stages, 0)
    if !PipelineStagesAreFusible(combined, 0) {
        return ""
    }
    if !(len(resultTypes) == 1) {
        return ""
    }
    sourceVar := "_pipeSourceRet"
    accVar := "_pipeAccRet"
    itemVar := "_pipeItemRet"
    init := GeneratePipelineAccumulatorBinding(accVar, sourceVar, resultTypes[0], combined, indent, enums)
    if !HasText(init) {
        return ""
    }
    return indent + sourceVar + " := " + GenerateExpr(bindFusion.Source, enums) + "\n" +
        init +
        indent + "for _, " + itemVar + " := range " + sourceVar + " {\n" +
        GeneratePipelineLoopBody(combined, 0, itemVar, accVar, indent + "    ", enums) +
        indent + "}\n" +
        indent + "return " + accVar + "\n"
}

func ConcatPipelineStages(left []PipelineStage, right []PipelineStage, idx int) []PipelineStage {
    if idx >= len(right) {
        return left
    }
    return ConcatPipelineStages(append(left, right[idx]), right, idx + 1)
}

func TitleName(name string) string {
    if !HasText(name) {
        return ""
    }
    return strings.ToUpper(string(name[0])) + SubstringFrom(name, 1, "")
}

func ExtractPipelineFusion(expr ast.Expr) PipelineFusion {
    if !ast.ExprIsPipeline(expr) {
        return EmptyPipelineFusion()
    }
    stage := ParsePipelineStage(ast.ExprPipelineRight(expr))
    if stage.Kind == "" {
        return EmptyPipelineFusion()
    }
    left := ast.ExprPipelineLeft(expr)
    if ast.ExprIsPipeline(left) {
        prior := ExtractPipelineFusion(left)
        if len(prior.Stages) == 0 {
            return EmptyPipelineFusion()
        }
        return PipelineFusion{
            Source: prior.Source,
            Stages: append(prior.Stages, stage),
        }
    }
    return PipelineFusion{
        Source: left,
        Stages: []PipelineStage{stage},
    }
}

func ParsePipelineStage(expr ast.Expr) PipelineStage {
    if !ast.ExprIsCall(expr) {
        return EmptyPipelineStage()
    }
    name := PipelineStageName(ast.ExprCallFunc(expr))
    args := ast.ExprCallArgs(expr)
    if name == "Map" {
        if len(args) == 1 {
            return PipelineStage{
                Kind: "map",
                Func: args[0],
                Init: None[ast.Expr](),
            }
        }
        return EmptyPipelineStage()
    }
    if name == "Filter" {
        if len(args) == 1 {
            return PipelineStage{
                Kind: "filter",
                Func: args[0],
                Init: None[ast.Expr](),
            }
        }
        return EmptyPipelineStage()
    }
    if name == "Fold" || name == "Reduce" {
        if len(args) == 2 {
            return PipelineStage{
                Kind: "fold",
                Func: args[1],
                Init: Some[ast.Expr](args[0]),
            }
        }
        return EmptyPipelineStage()
    }
    return EmptyPipelineStage()
}

func PipelineStageName(fn ast.Expr) string {
    if ast.ExprIsIdent(fn) {
        return ast.ExprIdentName(fn)
    }
    if ast.ExprIsSelector(fn) {
        return ast.ExprSelectorField(fn)
    }
    return ""
}

func PipelineStagesAreFusible(stages []PipelineStage, idx int) bool {
    if idx >= len(stages) {
        return true
    }
    if stages[idx].Kind == "fold" {
        return idx + 1 == len(stages)
    }
    return PipelineStagesAreFusible(stages, idx + 1)
}

func InferPipelineFusionResultType(fusion PipelineFusion, env []CodegenBinding, enums []EnumInfo) string {
    sourceType := InferExprTypeName(fusion.Source, env, enums)
    current := SliceElemTypeName(sourceType)
    if len(fusion.Stages) == 0 {
        return ""
    }
    return InferPipelineFusionResultTypeLoop(fusion.Stages, 0, current, env, enums)
}

func InferPipelineFusionResultTypeLoop(stages []PipelineStage, idx int, current string, env []CodegenBinding, enums []EnumInfo) string {
    if idx >= len(stages) {
        if !HasText(current) {
            return ""
        }
        return "[]" + current
    }
    stage := stages[idx]
    if stage.Kind == "map" {
        next := InferPipelineStageFuncResultType(stage.Func, env, enums)
        if !HasText(next) {
            return ""
        }
        return InferPipelineFusionResultTypeLoop(stages, idx + 1, next, env, enums)
    }
    if stage.Kind == "filter" {
        if !HasText(current) {
            return ""
        }
        return InferPipelineFusionResultTypeLoop(stages, idx + 1, current, env, enums)
    }
    if isNone[ast.Expr](stage.Init) {
        return ""
    }
    return InferExprTypeName(unwrapOr[ast.Expr](stage.Init, ast.MakeIdent(ast.ZeroPos(), "")), env, enums)
}

func InferPipelineStageFuncResultType(fn ast.Expr, env []CodegenBinding, enums []EnumInfo) string {
    if ast.ExprIsIdent(fn) {
        return FuncTypeResultName(LookupBindingType(ast.ExprIdentName(fn), env))
    }
    if ast.ExprIsFuncLit(fn) {
        if len(ast.ExprFuncLitResults(fn)) == 1 {
            return GenerateTypeExpr(ast.ExprFuncLitResults(fn)[0])
        }
    }
    return InferExprTypeName(fn, env, enums)
}

func GeneratePipelineAccumulatorBinding(target string, sourceVar string, resultType string, stages []PipelineStage, indent string, enums []EnumInfo) string {
    terminal := stages[len(stages)-1]
    if terminal.Kind == "fold" {
        if isNone[ast.Expr](terminal.Init) {
            return ""
        }
        return indent + target + " := " + GenerateExpr(unwrapOr[ast.Expr](terminal.Init, ast.MakeIdent(ast.ZeroPos(), "")), enums) + "\n"
    }
    if !HasSlicePrefix(resultType) {
        return ""
    }
    return indent + target + " := make(" + resultType + ", 0, len(" + sourceVar + "))\n"
}

func GeneratePipelineLoopBody(stages []PipelineStage, idx int, current string, acc string, indent string, enums []EnumInfo) string {
    if idx >= len(stages) {
        return indent + acc + " = append(" + acc + ", " + current + ")\n"
    }
    stage := stages[idx]
    if stage.Kind == "map" {
        next := "_pipeValue" + IntString(idx)
        return indent + next + " := " + GenerateExpr(stage.Func, enums) + "(" + current + ")\n" +
            GeneratePipelineLoopBody(stages, idx + 1, next, acc, indent, enums)
    }
    if stage.Kind == "filter" {
        return indent + "if !" + GenerateExpr(stage.Func, enums) + "(" + current + ") {\n" +
            indent + "    continue\n" +
            indent + "}\n" +
            GeneratePipelineLoopBody(stages, idx + 1, current, acc, indent, enums)
    }
    return indent + acc + " = " + GenerateExpr(stage.Func, enums) + "(" + acc + ", " + current + ")\n"
}

func GenerateOptionalExpr(expr Option[ast.Expr], enums []EnumInfo) string {
    if ast.ExprOptionIsNone(expr) {
        return ""
    }
    return GenerateExpr(ast.ExprOptionValue(expr), enums)
}

func GenerateStructLit(name string, fields []ast.FieldInit, enums []EnumInfo) string {
    if len(fields) == 0 {
        return GenerateGoName(name) + "{}"
    }
    return GenerateGoName(name) + "{ " + GenerateFieldInits(fields, enums) + " }"
}

func GenerateFieldInits(fields []ast.FieldInit, enums []EnumInfo) string {
    if len(fields) == 0 {
        return ""
    }
    head := GenerateGoName(ast.FieldInitNameValue(fields[0])) + ": " + GenerateExpr(ast.FieldInitExprValue(fields[0]), enums)
    if len(fields) == 1 {
        return head
    }
    return head + ", " + GenerateFieldInits(fields[1:], enums)
}

func GenerateSliceLit(elemType Option[ast.TypeExpr], elems []ast.Expr, enums []EnumInfo) string {
    typ := SliceElemTypeString(elemType)
    return "[]" + typ + "{ " + GenerateExprs(elems, enums) + " }"
}

func SliceElemTypeString(elemType Option[ast.TypeExpr]) string {
    if isNone[ast.TypeExpr](elemType) {
        return "any"
    }
    return GenerateTypeExpr(unwrapOr[ast.TypeExpr](elemType, ast.MakeNamedType(ast.ZeroPos(), "any")))
}

func GenerateSwitchStmt(stmt ast.Stmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    head := GenerateSwitchHead(ast.StmtSwitchTag(stmt), indent)
    return head + " {\n" + GenerateSwitchCases(ast.StmtSwitchCases(stmt), indent + "    ", resultTypes, env, enums) + indent + "}\n"
}

func GenerateSwitchHead(tag Option[ast.Expr], indent string) string {
    if ast.ExprOptionIsNone(tag) {
        return indent + "switch"
    }
    return indent + "switch " + GenerateExpr(ast.ExprOptionValue(tag), []EnumInfo{})
}

func GenerateSwitchCases(cases []ast.CaseClause, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(cases) == 0 {
        return ""
    }
    return GenerateSwitchCase(cases[0], indent, resultTypes, env, enums) + GenerateSwitchCases(cases[1:], indent, resultTypes, env, enums)
}

func GenerateSwitchCase(c ast.CaseClause, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if ast.SwitchCaseIsDefault(c) {
        return indent + "default:\n" + GenerateStatements(ast.SwitchCaseBody(c), indent + "    ", resultTypes, env, enums)
    }
        return indent + "case " + GenerateExprs(ast.SwitchCaseExprs(c), enums) + ":\n" +
        GenerateStatements(ast.SwitchCaseBody(c), indent + "    ", resultTypes, env, enums)
}

func GenerateMatchStmt(stmt ast.Stmt, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    temp := "_match"
    tagType := InferExprTypeName(ast.StmtMatchTag(stmt), env, enums)
    matchType := ResolveEnumMatchType(ast.StmtMatchCases(stmt), tagType, enums)
    if HasText(matchType) {
        if MatchCasesAreEnumLike(ast.StmtMatchCases(stmt), 0) {
            return indent + "{\n" +
                indent + "    " + temp + " := " + GenerateExpr(ast.StmtMatchTag(stmt), enums) + "\n" +
                indent + "    switch " + temp + ".Tag {\n" +
                GenerateEnumTagMatchCases(ast.StmtMatchCases(stmt), temp, matchType, indent + "    ", resultTypes, env, enums, 0) +
                indent + "    }\n" +
                indent + "}\n"
        }
    }
    return indent + "switch " + temp + " := any(" + GenerateExpr(ast.StmtMatchTag(stmt), enums) + ").(type) {\n" +
        GenerateMatchCases(ast.StmtMatchCases(stmt), temp, tagType, indent + "    ", resultTypes, env, enums) +
        indent + "}\n" +
        indent + "panic(`non-exhaustive match`)\n"
}

func GenerateTailMatchStmt(stmt ast.Stmt, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    temp := "_match"
    tagType := InferExprTypeName(ast.StmtMatchTag(stmt), env, enums)
    matchType := ResolveEnumMatchType(ast.StmtMatchCases(stmt), tagType, enums)
    if HasText(matchType) {
        if MatchCasesAreEnumLike(ast.StmtMatchCases(stmt), 0) {
            return indent + "{\n" +
                indent + "    " + temp + " := " + GenerateExpr(ast.StmtMatchTag(stmt), enums) + "\n" +
                indent + "    switch " + temp + ".Tag {\n" +
                GenerateTailEnumTagMatchCases(ast.StmtMatchCases(stmt), temp, matchType, fnName, params, indent + "    ", resultTypes, env, enums, 0) +
                indent + "    }\n" +
                indent + "}\n"
        }
    }
    return indent + "switch " + temp + " := any(" + GenerateExpr(ast.StmtMatchTag(stmt), enums) + ").(type) {\n" +
        GenerateTailMatchCases(ast.StmtMatchCases(stmt), temp, tagType, fnName, params, indent + "    ", resultTypes, env, enums) +
        indent + "}\n" +
        indent + "panic(`non-exhaustive match`)\n"
}

func ResolveEnumMatchType(cases []ast.MatchCase, tagType string, enums []EnumInfo) string {
    if HasText(tagType) {
        if MatchCasesAreEnumLike(cases, 0) {
            return tagType
        }
    }
    if len(cases) == 0 {
        return ""
    }
    return MatchCasesEnumType(cases, enums, 0, "")
}

func IsKnownFlatEnumType(tagType string, enums []EnumInfo) bool {
    if tagType == "" {
        return false
    }
    baseType := BaseTypeName(tagType)
    if IsPreludeOptionType(baseType) || IsPreludeResultType(baseType) {
        return true
    }
    return !isNone[EnumInfo](FindEnumInfo(ShortBaseTypeName(tagType), enums))
}

func MatchCasesEnumType(cases []ast.MatchCase, enums []EnumInfo, idx int, seen string) string {
    if idx >= len(cases) {
        return seen
    }
    pat := ast.MatchCasePattern(cases[idx])
    if ast.PatternIsWildcard(pat) {
        return MatchCasesEnumType(cases, enums, idx + 1, seen)
    }
    if !ast.PatternIsEnum(pat) {
        return ""
    }
    owner := VariantOwnerType(ast.PatternEnumName(pat), enums)
    if owner == "" {
        return ""
    }
    if seen == "" {
        return MatchCasesEnumType(cases, enums, idx + 1, owner)
    }
    if !StringsEqual(owner, seen) {
        return ""
    }
    return MatchCasesEnumType(cases, enums, idx + 1, seen)
}

func VariantOwnerType(variantName string, enums []EnumInfo) string {
    if IsPreludeOptionVariant(variantName) {
        return "Option"
    }
    if IsPreludeResultVariant(variantName) {
        return "Result"
    }
    info := FindVariantInfo(variantName, enums)
    if isNone[EnumVariantInfo](info) {
        return ""
    }
    return unwrapOr[EnumVariantInfo](info, EmptyEnumVariantInfo()).ParentName
}

func GenerateEnumTagMatchCases(cases []ast.MatchCase, temp string, tagType string, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo, depth int) string {
    if len(cases) == 0 {
        return indent + "default:\n" + indent + "    panic(`unreachable: non-exhaustive match`)\n"
    }
    pat := ast.MatchCasePattern(cases[0])
    if ast.PatternIsWildcard(pat) {
        return indent + "default:\n" +
            GenerateStatements(ast.MatchCaseBody(cases[0]), indent + "    ", resultTypes, env, enums)
    }
    body := GenerateStatements(ast.MatchCaseBody(cases[0]), indent + "    ", resultTypes, env, enums)
    wrappedBody := MaybeWrapEnumCaseBody(ast.PatternEnumSubPats(pat), indent + "    ", body)
    fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pat), tagType, enums)
    bindings := GenerateStage0EnumPatternBindings(ast.PatternEnumSubPats(pat), temp, ast.PatternEnumName(pat), tagType, 0, fieldTypes, indent + "    ", wrappedBody)
    return indent + "case " + EnumTagConstRef(ast.PatternEnumName(pat), tagType) + ":\n" +
        bindings +
        GenerateEnumTagMatchCases(cases[1:], temp, tagType, indent, resultTypes, env, enums, depth + 1)
}

func GenerateTailEnumTagMatchCases(cases []ast.MatchCase, temp string, tagType string, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo, depth int) string {
    if len(cases) == 0 {
        return indent + "default:\n" + indent + "    panic(`unreachable: non-exhaustive match`)\n"
    }
    pat := ast.MatchCasePattern(cases[0])
    if ast.PatternIsWildcard(pat) {
        return indent + "default:\n" +
            GenerateTailLoopStatements(ast.MatchCaseBody(cases[0]), fnName, params, indent + "    ", resultTypes, env, enums)
    }
    body := GenerateTailLoopStatements(ast.MatchCaseBody(cases[0]), fnName, params, indent + "    ", resultTypes, env, enums)
    wrappedBody := MaybeWrapEnumCaseBody(ast.PatternEnumSubPats(pat), indent + "    ", body)
    fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pat), tagType, enums)
    bindings := GenerateStage0EnumPatternBindings(ast.PatternEnumSubPats(pat), temp, ast.PatternEnumName(pat), tagType, 0, fieldTypes, indent + "    ", wrappedBody)
    return indent + "case " + EnumTagConstRef(ast.PatternEnumName(pat), tagType) + ":\n" +
        bindings +
        GenerateTailEnumTagMatchCases(cases[1:], temp, tagType, fnName, params, indent, resultTypes, env, enums, depth + 1)
}

func CanGenerateEnumIfMatch(cases []ast.MatchCase, tagType string, enums []EnumInfo) bool {
    if tagType == "" {
        return false
    }
    return MatchCasesAreEnumLike(cases, 0)
}

func StringsEqual(left string, right string) bool {
    if left == right {
        return true
    }
    return false
}

func MatchCasesAreEnumLike(cases []ast.MatchCase, idx int) bool {
    if idx >= len(cases) {
        return true
    }
    pat := ast.MatchCasePattern(cases[idx])
    if ast.PatternIsEnum(pat) || ast.PatternIsWildcard(pat) {
        return MatchCasesAreEnumLike(cases, idx + 1)
    }
    return false
}

func GenerateEnumIfMatchCases(cases []ast.MatchCase, temp string, tagType string, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo, depth int) string {
    if len(cases) == 0 {
        return indent + "panic(`unreachable: non-exhaustive match`)\n"
    }
    pat := ast.MatchCasePattern(cases[0])
    body := GenerateStatements(ast.MatchCaseBody(cases[0]), indent + "    ", resultTypes, env, enums)
    wrappedBody := MaybeWrapEnumCaseBody(ast.PatternEnumSubPats(pat), indent + "    ", body)
    if ast.PatternIsWildcard(pat) {
        return indent + "{\n" + body + indent + "}\n"
    }
    caseName := "_case" + IntString(depth)
    fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pat), tagType, enums)
    bindings := GenerateStage0EnumPatternBindings(ast.PatternEnumSubPats(pat), caseName, ast.PatternEnumName(pat), tagType, 0, fieldTypes, indent + "    ", wrappedBody)
    tail := GenerateEnumIfMatchCases(cases[1:], temp, tagType, indent, resultTypes, env, enums, depth + 1)
    binder := EnumCaseBinder(caseName, ast.PatternEnumSubPats(pat))
    return indent + "if " + binder + ", ok := any(" + temp + ").(" + GenerateEnumAssertionType(ast.PatternEnumName(pat), tagType, enums) + "); ok {\n" +
        bindings +
        indent + "} else {\n" +
        tail +
        indent + "}\n"
}

func EnumCaseBinder(caseName string, patterns []ast.Pattern) string {
    if !PatternsBindNames(patterns, 0) {
        return "_"
    }
    return caseName
}

func MaybeWrapEnumCaseBody(patterns []ast.Pattern, indent string, body string) string {
    if len(patterns) == 0 {
        return body
    }
    if PatternsBindNames(patterns, 0) {
        return body
    }
    return indent + "{\n" + body + indent + "}\n"
}

func PatternsBindNames(patterns []ast.Pattern, idx int) bool {
    if idx >= len(patterns) {
        return false
    }
    if PatternBindsName(patterns[idx]) {
        return true
    }
    return PatternsBindNames(patterns, idx + 1)
}

func PatternBindsName(pattern ast.Pattern) bool {
    if ast.PatternIsIdent(pattern) {
        return true
    }
    if ast.PatternIsEnum(pattern) {
        return PatternsBindNames(ast.PatternEnumSubPats(pattern), 0)
    }
    if ast.PatternIsStruct(pattern) {
        return FieldPatternsBindNames(ast.PatternStructFields(pattern), 0)
    }
    if ast.PatternIsTuple(pattern) {
        return PatternsBindNames(ast.PatternTupleElems(pattern), 0)
    }
    return false
}

func FieldPatternsBindNames(fields []ast.FieldPattern, idx int) bool {
    if idx >= len(fields) {
        return false
    }
    if PatternBindsName(ast.FieldPatternPatternValue(fields[idx])) {
        return true
    }
    return FieldPatternsBindNames(fields, idx + 1)
}

func GenerateEnumAssertionType(name string, tagType string, infos []EnumInfo) string {
    info := ResolveEnumVariantInfo(name, tagType, infos)
    if !isNone[EnumVariantInfo](info) {
        item := unwrapOr[EnumVariantInfo](info, EmptyEnumVariantInfo())
        if len(item.TypeParams) == 0 {
            return GenerateGoName(name)
        }
        actual := ParseNamedTypeArgs(tagType)
        if len(actual) == 0 {
            return GenerateGoName(name)
        }
        return GenerateGoName(name) + "[" + JoinStrings(actual, 0) + "]"
    }
    prelude := GeneratePreludeEnumAssertionType(name, tagType)
    if HasText(prelude) {
        return prelude
    }
    return GenerateGoName(name)
}

func GeneratePreludeEnumAssertionType(name string, tagType string) string {
    baseType := BaseTypeName(tagType)
    actual := ParseNamedTypeArgs(tagType)
    if IsPreludeOptionType(baseType) {
        if IsPreludeOptionVariant(name) {
            if len(actual) == 0 {
                return PreludeTypeName(name)
            }
            return PreludeTypeName(name) + "[" + JoinStrings(actual, 0) + "]"
        }
    }
    if IsPreludeResultType(baseType) {
        if IsPreludeResultVariant(name) {
            if len(actual) == 0 {
                return PreludeTypeName(name)
            }
            return PreludeTypeName(name) + "[" + JoinStrings(actual, 0) + "]"
        }
    }
    return ""
}

func GenerateStage0EnumPatternBindings(patterns []ast.Pattern, temp string, variantName string, tagType string, idx int, fieldTypes []string, indent string, body string) string {
    if idx >= len(patterns) {
        return body
    }
    value := temp + "." + EnumFieldAccess(variantName, tagType, idx)
    expected := StringAt(fieldTypes, idx)
    nextBody := GenerateStage0EnumPatternBindings(patterns, temp, variantName, tagType, idx + 1, fieldTypes, indent, body)
    return GenerateStage0PatternBinding(patterns[idx], value, expected, indent, nextBody)
}

func GenerateStage0PatternBinding(pattern ast.Pattern, value string, expectedType string, indent string, body string) string {
    if ast.PatternIsWildcard(pattern) {
        return body
    }
    if ast.PatternIsIdent(pattern) {
        return indent + "{\n" +
            indent + "    " + GenerateGoName(ast.PatternIdentName(pattern)) + " := " + value + "\n" +
            indent + "    _ = " + GenerateGoName(ast.PatternIdentName(pattern)) + "\n" +
            body +
            indent + "}\n"
    }
    return body
}

func GenerateMatchCases(cases []ast.MatchCase, temp string, tagType string, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(cases) == 0 {
        return ""
    }
    return GenerateMatchCase(cases[0], temp, tagType, indent, resultTypes, env, enums) +
        GenerateMatchCases(cases[1:], temp, tagType, indent, resultTypes, env, enums)
}

func GenerateTailMatchCases(cases []ast.MatchCase, temp string, tagType string, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    if len(cases) == 0 {
        return ""
    }
    return GenerateTailMatchCase(cases[0], temp, tagType, fnName, params, indent, resultTypes, env, enums) +
        GenerateTailMatchCases(cases[1:], temp, tagType, fnName, params, indent, resultTypes, env, enums)
}

func GenerateTailMatchCase(c ast.MatchCase, temp string, tagType string, fnName string, params []ast.FieldDef, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    pat := ast.MatchCasePattern(c)
    body := indent + "    _ = " + temp + "\n" + GenerateTailLoopStatements(ast.MatchCaseBody(c), fnName, params, indent + "    ", resultTypes, env, enums)
    if ast.PatternIsWildcard(pat) {
        return indent + "default:\n" + body
    }
    if ast.PatternIsEnum(pat) {
        fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pat), tagType, enums)
        bindings := GenerateEnumPatternBindings(ast.PatternEnumSubPats(pat), temp, ast.PatternEnumName(pat), tagType, 0, fieldTypes, EnumPayloadIsErased(ast.PatternEnumName(pat), tagType, enums), indent + "    ", body, 0, enums)
        return indent + "case " + GenerateEnumAssertionType(ast.PatternEnumName(pat), tagType, enums) + ":\n" + bindings
    }
    if ast.PatternIsStruct(pat) {
        bindings := GenerateStructPatternBindings(ast.PatternStructFields(pat), temp, indent + "    ", body, 0, enums)
        return indent + "case " + GenerateGoName(ast.PatternStructType(pat)) + ":\n" + bindings
    }
    if ast.PatternIsIdent(pat) {
        return indent + "default:\n" +
            indent + "    " + GenerateGoName(ast.PatternIdentName(pat)) + " := " + temp + "\n" +
            body
    }
    return indent + "default:\n" + body
}

func GenerateMatchCase(c ast.MatchCase, temp string, tagType string, indent string, resultTypes []string, env []CodegenBinding, enums []EnumInfo) string {
    pat := ast.MatchCasePattern(c)
    body := indent + "    _ = " + temp + "\n" + GenerateStatements(ast.MatchCaseBody(c), indent + "    ", resultTypes, env, enums)
    if ast.PatternIsWildcard(pat) {
        return indent + "default:\n" + body
    }
    if ast.PatternIsEnum(pat) {
        fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pat), tagType, enums)
        bindings := GenerateEnumPatternBindings(ast.PatternEnumSubPats(pat), temp, ast.PatternEnumName(pat), tagType, 0, fieldTypes, EnumPayloadIsErased(ast.PatternEnumName(pat), tagType, enums), indent + "    ", body, 0, enums)
        return indent + "case " + GenerateEnumAssertionType(ast.PatternEnumName(pat), tagType, enums) + ":\n" + bindings
    }
    if ast.PatternIsStruct(pat) {
        bindings := GenerateStructPatternBindings(ast.PatternStructFields(pat), temp, indent + "    ", body, 0, enums)
        return indent + "case " + GenerateGoName(ast.PatternStructType(pat)) + ":\n" + bindings
    }
    if ast.PatternIsIdent(pat) {
        return indent + "default:\n" +
            indent + "    " + GenerateGoName(ast.PatternIdentName(pat)) + " := " + temp + "\n" +
            body
    }
    return indent + "default:\n" + body
}

func GenerateEnumPatternBindings(patterns []ast.Pattern, temp string, variantName string, tagType string, idx int, fieldTypes []string, erased bool, indent string, body string, depth int, enums []EnumInfo) string {
    if idx >= len(patterns) {
        return body
    }
    value := temp + "." + EnumFieldAccess(variantName, tagType, idx)
    expected := StringAt(fieldTypes, idx)
    nextBody := GenerateEnumPatternBindings(patterns, temp, variantName, tagType, idx + 1, fieldTypes, erased, indent, body, depth + 1, enums)
    return GeneratePatternBinding(patterns[idx], value, expected, erased, indent, nextBody, depth, enums)
}

func GenerateStructPatternBindings(fields []ast.FieldPattern, temp string, indent string, body string, depth int, enums []EnumInfo) string {
    if len(fields) == 0 {
        return body
    }
    value := temp + "." + GenerateGoName(ast.FieldPatternNameValue(fields[0]))
    nextBody := GenerateStructPatternBindings(fields[1:], temp, indent, body, depth + 1, enums)
    return GeneratePatternBinding(ast.FieldPatternPatternValue(fields[0]), value, "", false, indent, nextBody, depth, enums)
}

func GeneratePatternBinding(pattern ast.Pattern, value string, expectedType string, fromAny bool, indent string, body string, depth int, enums []EnumInfo) string {
    if ast.PatternIsWildcard(pattern) {
        return body
    }
    if ast.PatternIsIdent(pattern) {
        return indent + GenerateGoName(ast.PatternIdentName(pattern)) + " := " + MaybeCastValue(value, expectedType, fromAny) + "\n" + body
    }
    if ast.PatternIsEnum(pattern) {
        temp := "_pat" + IntString(depth)
        fieldTypes := ResolveEnumPatternFieldTypes(ast.PatternEnumName(pattern), expectedType, enums)
        inner := GenerateEnumPatternBindings(ast.PatternEnumSubPats(pattern), temp, ast.PatternEnumName(pattern), expectedType, 0, fieldTypes, EnumPayloadIsErased(ast.PatternEnumName(pattern), expectedType, enums), indent + "    ", body, depth + 1, enums)
        if HasText(expectedType) {
            return indent + "{\n" +
                indent + "    " + temp + " := " + MaybeCastValue(value, expectedType, fromAny) + "\n" +
                indent + "    if " + temp + ".Tag == " + EnumTagConstRef(ast.PatternEnumName(pattern), expectedType) + " {\n" +
                inner +
                indent + "    }\n" +
                indent + "}\n"
        }
        return indent + "switch " + temp + " := any(" + value + ").(type) {\n" +
            indent + "case " + GenerateEnumAssertionType(ast.PatternEnumName(pattern), expectedType, enums) + ":\n" +
            inner +
            indent + "}\n"
    }
    if ast.PatternIsStruct(pattern) {
        temp := "_pat" + IntString(depth)
        inner := GenerateStructPatternBindings(ast.PatternStructFields(pattern), temp, indent + "    ", body, depth + 1, enums)
        return indent + "{\n" +
            indent + "    " + temp + " := " + MaybeCastValue(value, EffectiveStructPatternType(pattern, expectedType), fromAny) + "\n" +
            inner +
            indent + "}\n"
    }
    return body
}

func EffectiveStructPatternType(pattern ast.Pattern, expectedType string) string {
    if expectedType == "" {
        return ast.PatternStructType(pattern)
    }
    return expectedType
}

func MaybeCastValue(value string, expectedType string, fromAny bool) string {
    if !fromAny {
        return value
    }
    if expectedType == "" {
        return value
    }
    return value + ".(" + expectedType + ")"
}

func CollectEnumInfos(decls []ast.Decl, idx int, acc []EnumInfo) []EnumInfo {
    if idx >= len(decls) {
        return acc
    }
    decl := decls[idx]
    if ast.DeclIsEnumType(decl) {
        typeParams := TypeParamNames(ast.DeclTypeParams(decl), 0, []string{})
        next := append(acc, EnumInfo{
            Name: ast.DeclName(decl),
            TypeParams: typeParams,
            Variants: CollectVariantInfos(ast.DeclName(decl), ast.DeclEnumVariants(decl), 0, typeParams, []EnumVariantInfo{}),
        })
        return CollectEnumInfos(decls, idx + 1, next)
    }
    return CollectEnumInfos(decls, idx + 1, acc)
}

func CollectVariantInfos(parent string, variants []ast.Variant, idx int, typeParams []string, acc []EnumVariantInfo) []EnumVariantInfo {
    if idx >= len(variants) {
        return acc
    }
    next := append(acc, EnumVariantInfo{
        Name: ast.VariantName(variants[idx]),
        ParentName: parent,
        FieldTypes: TypeExprNames(ast.VariantFields(variants[idx]), 0, []string{}),
        TypeParams: typeParams,
        Erased: false,
    })
    return CollectVariantInfos(parent, variants, idx + 1, typeParams, next)
}

func TypeParamNames(params []ast.TypeParam, idx int, acc []string) []string {
    if idx >= len(params) {
        return acc
    }
    return TypeParamNames(params, idx + 1, append(acc, ast.TypeParamName(params[idx])))
}

func TypeExprNames(items []ast.TypeExpr, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    return TypeExprNames(items, idx + 1, append(acc, GenerateTypeExpr(items[idx])))
}

func FindVariantInfoByExpr(expr ast.Expr, enums []EnumInfo) Option[EnumVariantInfo] {
    if ast.ExprIsIdent(expr) {
        return FindVariantInfo(ast.ExprIdentName(expr), enums)
    }
    return None[EnumVariantInfo]()
}

func FindVariantInfo(name string, infos []EnumInfo) Option[EnumVariantInfo] {
    if len(infos) == 0 {
        return None[EnumVariantInfo]()
    }
    info := FindVariantInfoInEnum(name, infos[0].Variants)
    if isNone[EnumVariantInfo](info) {
        return FindVariantInfo(name, infos[1:])
    }
    return info
}

func FindVariantInfoInEnum(name string, variants []EnumVariantInfo) Option[EnumVariantInfo] {
    if len(variants) == 0 {
        return None[EnumVariantInfo]()
    }
    if variants[0].Name == name {
        return Some[EnumVariantInfo](variants[0])
    }
    return FindVariantInfoInEnum(name, variants[1:])
}

func ResolveEnumPatternFieldTypes(variantName string, tagType string, infos []EnumInfo) []string {
    prelude := ResolvePreludeEnumPatternFieldTypes(variantName, tagType)
    if len(prelude) > 0 {
        return prelude
    }
    if tagType == "" {
        return []string{}
    }
    info := FindEnumInfo(BaseTypeName(tagType), infos)
    if isNone[EnumInfo](info) {
        return []string{}
    }
    item := unwrapOr[EnumInfo](info, EmptyEnumInfo())
    variant := FindVariantInfoInEnum(variantName, item.Variants)
    if isNone[EnumVariantInfo](variant) {
        return []string{}
    }
    actual := ParseNamedTypeArgs(tagType)
    found := unwrapOr[EnumVariantInfo](variant, EmptyEnumVariantInfo())
    return SubstituteTypeNames(found.FieldTypes, item.TypeParams, actual, 0, []string{})
}

func ResolvePreludeEnumPatternFieldTypes(variantName string, tagType string) []string {
    baseType := BaseTypeName(tagType)
    actual := ParseNamedTypeArgs(tagType)
    if IsPreludeOptionType(baseType) {
        if variantName == "Some" {
            if len(actual) >= 1 {
                return []string{ actual[0] }
            }
        }
    }
    if IsPreludeResultType(baseType) {
        if variantName == "Ok" {
            if len(actual) >= 1 {
                return []string{ actual[0] }
            }
        }
        if variantName == "Err" {
            if len(actual) >= 2 {
                return []string{ actual[1] }
            }
        }
    }
    return []string{}
}

func EnumPayloadIsErased(variantName string, tagType string, infos []EnumInfo) bool {
    if tagType == "" {
        return false
    }
    info := FindEnumInfo(BaseTypeName(tagType), infos)
    if isNone[EnumInfo](info) {
        return false
    }
    item := unwrapOr[EnumInfo](info, EmptyEnumInfo())
    variant := FindVariantInfoInEnum(variantName, item.Variants)
    if isNone[EnumVariantInfo](variant) {
        return false
    }
    return unwrapOr[EnumVariantInfo](variant, EmptyEnumVariantInfo()).Erased
}

func EnumFieldAccess(variantName string, tagType string, idx int) string {
    return EnumStorageFieldName(variantName, idx)
}

func EnumPayloadIsGenericByType(tagType string, infos []EnumInfo) bool {
    if tagType == "" {
        return false
    }
    info := FindEnumInfo(BaseTypeName(tagType), infos)
    if isNone[EnumInfo](info) {
        return false
    }
    return len(unwrapOr[EnumInfo](info, EmptyEnumInfo()).TypeParams) > 0
}

func ResolveEnumVariantInfo(variantName string, tagType string, infos []EnumInfo) Option[EnumVariantInfo] {
    if tagType == "" {
        return None[EnumVariantInfo]()
    }
    info := FindEnumInfo(BaseTypeName(tagType), infos)
    if isNone[EnumInfo](info) {
        return None[EnumVariantInfo]()
    }
    item := unwrapOr[EnumInfo](info, EmptyEnumInfo())
    return FindVariantInfoInEnum(variantName, item.Variants)
}

func FindEnumInfo(name string, infos []EnumInfo) Option[EnumInfo] {
    if len(infos) == 0 {
        return None[EnumInfo]()
    }
    if infos[0].Name == name {
        return Some[EnumInfo](infos[0])
    }
    return FindEnumInfo(name, infos[1:])
}

func SubstituteTypeNames(items []string, params []string, actual []string, idx int, acc []string) []string {
    if idx >= len(items) {
        return acc
    }
    next := append(acc, SubstituteTypeName(items[idx], params, actual))
    return SubstituteTypeNames(items, params, actual, idx + 1, next)
}

func SubstituteTypeName(typeName string, params []string, actual []string) string {
    if HasSlicePrefix(typeName) {
        return "[]" + SubstituteTypeName(TrimSlicePrefix(typeName), params, actual)
    }
    if HasMapPrefix(typeName) {
        return "map[" + SubstituteTypeName(MapKeyTypeName(typeName), params, actual) + "]" + SubstituteTypeName(MapValueTypeName(typeName), params, actual)
    }
    if HasTupleEnvelope(typeName) {
        return "(" + SubstituteTypeNames(ParseTupleTypeNames(typeName), params, actual, 0, []string{})[0]
    }
    if strings.Contains(typeName, "[") {
        baseName := BaseTypeName(typeName)
        args := ParseNamedTypeArgs(typeName)
        replaced := SubstituteTypeNames(args, params, actual, 0, []string{})
        return baseName + "[" + JoinStrings(replaced, 0) + "]"
    }
    return SubstituteSimpleTypeName(typeName, params, actual, 0)
}

func SubstituteSimpleTypeName(typeName string, params []string, actual []string, idx int) string {
    if idx >= len(params) {
        return typeName
    }
    if idx < len(actual) {
        if typeName == params[idx] {
            return actual[idx]
        }
    }
    return SubstituteSimpleTypeName(typeName, params, actual, idx + 1)
}

func InferExprTypeName(expr ast.Expr, env []CodegenBinding, enums []EnumInfo) string {
    if ast.ExprIsBasicLit(expr) {
        return BasicLitTypeName(ast.ExprBasicLitKind(expr), ast.ExprBasicLitValue(expr))
    }
    if ast.ExprIsTuple(expr) {
        return TupleExprTypeName(ast.ExprTupleElems(expr), 0, []string{}, env, enums)
    }
    if ast.ExprIsSliceLit(expr) {
        if !isNone[ast.TypeExpr](ast.ExprSliceLitType(expr)) {
            return "[]" + GenerateTypeExpr(unwrapOr[ast.TypeExpr](ast.ExprSliceLitType(expr), ast.MakeNamedType(ast.ZeroPos(), "any")))
        }
    }
    if ast.ExprIsIdent(expr) {
        return LookupBindingType(ast.ExprIdentName(expr), env)
    }
    if ast.ExprIsUnary(expr) {
        if ast.ExprUnaryOp(expr) == token.NotType() {
            return "bool"
        }
        if ast.ExprUnaryOp(expr) == token.MinusType() {
            return InferExprTypeName(ast.ExprUnaryOperand(expr), env, enums)
        }
    }
    if ast.ExprIsBinary(expr) {
        op := ast.ExprBinaryOp(expr)
        if BinaryOpReturnsBool(op) {
            return "bool"
        }
        left := InferExprTypeName(ast.ExprBinaryLeft(expr), env, enums)
        right := InferExprTypeName(ast.ExprBinaryRight(expr), env, enums)
        if StringsEqual(left, right) {
            return left
        }
        return ""
    }
    if ast.ExprIsCall(expr) {
        return InferCallExprTypeName(expr, env, enums)
    }
    if ast.ExprIsStructLit(expr) {
        return ast.ExprStructLitType(expr)
    }
    if ast.ExprIsCopyUpdate(expr) {
        return InferExprTypeName(ast.ExprCopyUpdateSource(expr), env, enums)
    }
    if ast.ExprIsPipeline(expr) {
        fused := InferPipelineFusionResultType(ExtractPipelineFusion(expr), env, enums)
        if HasText(fused) {
            return fused
        }
        if ast.ExprIsCall(ast.ExprPipelineRight(expr)) {
            return InferAppliedCallResultType(ast.ExprCallFunc(ast.ExprPipelineRight(expr)), ast.ExprPipelineLeft(expr), ast.ExprCallArgs(ast.ExprPipelineRight(expr)), env, enums)
        }
        return InferAppliedCallResultType(ast.ExprPipelineRight(expr), ast.ExprPipelineLeft(expr), []ast.Expr{}, env, enums)
    }
    if ast.ExprIsIndex(expr) {
        return SliceElemTypeName(InferExprTypeName(ast.ExprIndexTarget(expr), env, enums))
    }
    if ast.ExprIsSlice(expr) {
        return InferExprTypeName(ast.ExprSliceTarget(expr), env, enums)
    }
    return ""
}

func InferCallExprTypeName(expr ast.Expr, env []CodegenBinding, enums []EnumInfo) string {
    fn := ast.ExprCallFunc(expr)
    if ast.ExprIsIdent(fn) {
        name := ast.ExprIdentName(fn)
        info := FindVariantInfo(name, enums)
        if !isNone[EnumVariantInfo](info) {
            return VariantParentTypeName(unwrapOr[EnumVariantInfo](info, EmptyEnumVariantInfo()), ast.ExprCallTypeArgs(expr))
        }
        if IsPreludeOptionVariant(name) {
            return "Option" + GenerateTypeArgSuffix(ast.ExprCallTypeArgs(expr))
        }
        if IsPreludeResultVariant(name) {
            return "Result" + GenerateTypeArgSuffix(ast.ExprCallTypeArgs(expr))
        }
        if name == "Lookup" || name == "lookupMap" {
            args := ast.ExprCallArgs(expr)
            if len(args) >= 1 {
                return LookupReturnTypeName(InferExprTypeName(args[0], env, enums))
            }
        }
        return FuncTypeResultName(LookupBindingType(name, env))
    }
    return ""
}

func InferAppliedCallResultType(fn ast.Expr, first ast.Expr, rest []ast.Expr, env []CodegenBinding, enums []EnumInfo) string {
    if ast.ExprIsIdent(fn) {
        name := ast.ExprIdentName(fn)
        if name == "Fold" || name == "Reduce" {
            if len(rest) >= 2 {
                return InferExprTypeName(rest[0], env, enums)
            }
        }
        if name == "Filter" {
            return InferExprTypeName(first, env, enums)
        }
        if name == "Map" {
            return InferAppliedMapResultType(first, rest, env, enums)
        }
        return FuncTypeResultName(LookupBindingType(name, env))
    }
    return ""
}

func InferAppliedMapResultType(first ast.Expr, rest []ast.Expr, env []CodegenBinding, enums []EnumInfo) string {
    if len(rest) >= 1 {
        mapped := InferPipelineStageFuncResultType(rest[0], env, enums)
        if HasText(mapped) {
            return "[]" + mapped
        }
    }
    return InferExprTypeName(first, env, enums)
}

func BinaryOpReturnsBool(op token.Type) bool {
    if op == token.EqType() || op == token.LtType() || op == token.GtType() || op == token.LteType() || op == token.GteType() {
        return true
    }
    return false
}

func BasicLitTypeName(kind token.Type, value string) string {
    if kind == token.StringLitType() {
        return "string"
    }
    if kind == token.IntLitType() {
        return "int"
    }
    if kind == token.TrueType() || kind == token.FalseType() {
        return "bool"
    }
    if value == "true" || value == "false" {
        return "bool"
    }
    return ""
}

func TupleExprTypeName(items []ast.Expr, idx int, acc []string, env []CodegenBinding, enums []EnumInfo) string {
    if idx >= len(items) {
        return "(" + JoinStrings(acc, 0) + ")"
    }
    got := InferExprTypeName(items[idx], env, enums)
    if !HasText(got) {
        return ""
    }
    return TupleExprTypeName(items, idx + 1, append(acc, got), env, enums)
}

func FuncTypeResultName(typeName string) string {
    if !strings.HasPrefix(typeName, "func(") {
        return ""
    }
    close := LastParenIndex(typeName, len(typeName) - 1)
    if close < 0 {
        return ""
    }
    if close + 1 >= len(typeName) {
        return ""
    }
    return strings.TrimSpace(SubstringFrom(typeName, close + 1, ""))
}

func LastParenIndex(value string, idx int) int {
    if idx < 0 {
        return -1
    }
    if value[idx] == ")"[0] {
        return idx
    }
    return LastParenIndex(value, idx - 1)
}

func VariantParentTypeName(info EnumVariantInfo, typeArgs []ast.TypeExpr) string {
    if info.ParentName == "" {
        return ""
    }
    if len(info.TypeParams) == 0 {
        return info.ParentName
    }
    if len(typeArgs) > 0 {
        return info.ParentName + GenerateTypeArgSuffix(typeArgs)
    }
    return info.ParentName + GenerateTypeParamValueSuffix(info.TypeParams, 0)
}

func LookupReturnTypeName(mapType string) string {
    if HasMapPrefix(mapType) {
        return "Option[" + MapValueTypeName(mapType) + "]"
    }
    return ""
}

func SliceElemTypeName(typeName string) string {
    if HasSlicePrefix(typeName) {
        return TrimSlicePrefix(typeName)
    }
    return ""
}

func LookupBindingType(name string, env []CodegenBinding) string {
    if len(env) == 0 {
        return ""
    }
    if env[0].Name == name {
        return env[0].TypeName
    }
    return LookupBindingType(name, env[1:])
}

func BaseTypeName(typeName string) string {
    if typeName == "" {
        return ""
    }
    return BaseTypeNameLoop(typeName, 0, "")
}

func ShortBaseTypeName(typeName string) string {
    base := BaseTypeName(typeName)
    idx := strings.LastIndex(base, ".")
    if idx < 0 {
        return base
    }
    return SubstringFrom(base, idx + 1, "")
}

func TypeQualifierPrefix(typeName string) string {
    base := BaseTypeName(typeName)
    idx := strings.LastIndex(base, ".")
    if idx < 0 {
        return ""
    }
    return SubstringBefore(base, idx + 1, 0, "")
}

func SubstringFrom(value string, start int, acc string) string {
    if start >= len(value) {
        return acc
    }
    return SubstringFrom(value, start + 1, acc + string(value[start]))
}

func SubstringBefore(value string, limit int, idx int, acc string) string {
    if idx >= len(value) || idx >= limit {
        return acc
    }
    return SubstringBefore(value, limit, idx + 1, acc + string(value[idx]))
}

func BaseTypeNameLoop(typeName string, idx int, acc string) string {
    if idx >= len(typeName) {
        return acc
    }
    if typeName[idx] == "["[0] {
        return acc
    }
    return BaseTypeNameLoop(typeName, idx + 1, acc + string(typeName[idx]))
}

func ParseNamedTypeArgs(typeName string) []string {
    start := FirstBracketIndex(typeName, 0)
    if start < 0 {
        return []string{}
    }
    inner := TrimOuterBrackets(typeName, start)
    if strings.TrimSpace(inner) == "" {
        return []string{}
    }
    return SplitTopLevelComma(inner, 0, 0, "", []string{})
}

func FirstBracketIndex(value string, idx int) int {
    if idx >= len(value) {
        return -1
    }
    if value[idx] == "["[0] {
        return idx
    }
    return FirstBracketIndex(value, idx + 1)
}

func TrimOuterBrackets(value string, start int) string {
    return TrimOuterBracketsLoop(value, 0, start, "")
}

func TrimOuterBracketsLoop(value string, idx int, start int, acc string) string {
    if idx >= len(value) {
        return acc
    }
    if idx <= start {
        return TrimOuterBracketsLoop(value, idx + 1, start, acc)
    }
    if idx + 1 == len(value) {
        return acc
    }
    return TrimOuterBracketsLoop(value, idx + 1, start, acc + string(value[idx]))
}

func SplitTopLevelComma(value string, idx int, depth int, current string, acc []string) []string {
    if idx >= len(value) {
        if strings.TrimSpace(current) == "" {
            return acc
        }
        return append(acc, strings.TrimSpace(current))
    }
    ch := value[idx]
    if ch == "["[0] || ch == "("[0] {
        return SplitTopLevelComma(value, idx + 1, depth + 1, current + string(ch), acc)
    }
    if ch == "]"[0] || ch == ")"[0] {
        return SplitTopLevelComma(value, idx + 1, depth - 1, current + string(ch), acc)
    }
    if ch == ","[0] {
        if depth == 0 {
            return SplitTopLevelComma(value, idx + 1, depth, "", append(acc, strings.TrimSpace(current)))
        }
    }
    return SplitTopLevelComma(value, idx + 1, depth, current + string(ch), acc)
}

func HasSlicePrefix(typeName string) bool {
    if len(typeName) < 2 {
        return false
    }
    if typeName[0] == "["[0] {
        if typeName[1] == "]"[0] {
            return true
        }
    }
    return false
}

func TrimSlicePrefix(typeName string) string {
    return TrimSlicePrefixLoop(typeName, 0, "")
}

func TrimSlicePrefixLoop(typeName string, idx int, acc string) string {
    if idx >= len(typeName) {
        return acc
    }
    if idx < 2 {
        return TrimSlicePrefixLoop(typeName, idx + 1, acc)
    }
    return TrimSlicePrefixLoop(typeName, idx + 1, acc + string(typeName[idx]))
}

func HasMapPrefix(typeName string) bool {
    return strings.HasPrefix(typeName, "map[")
}

func MapKeyTypeName(typeName string) string {
    return ParseMapTypeName(typeName, true)
}

func MapValueTypeName(typeName string) string {
    return ParseMapTypeName(typeName, false)
}

func ParseMapTypeName(typeName string, wantKey bool) string {
    return ParseMapTypeNameLoop(typeName, 4, 0, wantKey, "")
}

func ParseMapTypeNameLoop(typeName string, idx int, depth int, wantKey bool, acc string) string {
    if idx >= len(typeName) {
        return strings.TrimSpace(acc)
    }
    ch := typeName[idx]
    if wantKey {
        if ch == "["[0] {
            return ParseMapTypeNameLoop(typeName, idx + 1, depth + 1, wantKey, acc + string(ch))
        }
        if ch == "]"[0] {
            if depth == 0 {
                return strings.TrimSpace(acc)
            }
            return ParseMapTypeNameLoop(typeName, idx + 1, depth - 1, wantKey, acc + string(ch))
        }
        return ParseMapTypeNameLoop(typeName, idx + 1, depth, wantKey, acc + string(ch))
    }
    if ch == "]"[0] {
        if depth == 0 {
            return strings.TrimSpace(MapValueTail(typeName, idx + 1, ""))
        }
    }
    if ch == "["[0] {
        return ParseMapTypeNameLoop(typeName, idx + 1, depth + 1, wantKey, acc)
    }
    if ch == "]"[0] {
        return ParseMapTypeNameLoop(typeName, idx + 1, depth - 1, wantKey, acc)
    }
    return ParseMapTypeNameLoop(typeName, idx + 1, depth, wantKey, acc)
}

func MapValueTail(typeName string, idx int, acc string) string {
    if idx >= len(typeName) {
        return acc
    }
    return MapValueTail(typeName, idx + 1, acc + string(typeName[idx]))
}

func HasTupleEnvelope(typeName string) bool {
    if len(typeName) < 2 {
        return false
    }
    if typeName[0] == "("[0] {
        if typeName[len(typeName)-1] == ")"[0] {
            return true
        }
    }
    return false
}

func ParseTupleTypeNames(typeName string) []string {
    if !HasTupleEnvelope(typeName) {
        return []string{}
    }
    inner := TrimTupleEnvelope(typeName)
    if strings.TrimSpace(inner) == "" {
        return []string{}
    }
    return SplitTopLevelComma(inner, 0, 0, "", []string{})
}

func TrimTupleEnvelope(typeName string) string {
    return TrimTupleEnvelopeLoop(typeName, 0, "")
}

func TrimTupleEnvelopeLoop(typeName string, idx int, acc string) string {
    if idx >= len(typeName) {
        return acc
    }
    if idx == 0 {
        return TrimTupleEnvelopeLoop(typeName, idx + 1, acc)
    }
    if idx + 1 == len(typeName) {
        return acc
    }
    return TrimTupleEnvelopeLoop(typeName, idx + 1, acc + string(typeName[idx]))
}

func StringAt(items []string, idx int) string {
    if idx >= len(items) {
        return ""
    }
    return items[idx]
}

func JoinStrings(items []string, idx int) string {
    if idx >= len(items) {
        return ""
    }
    if idx + 1 >= len(items) {
        return items[idx]
    }
    return items[idx] + ", " + JoinStrings(items, idx + 1)
}

func GenerateGoName(name string) string {
    if IsGoKeyword(name) {
        return "fo_" + name
    }
    return name
}

func PreludeTypeName(name string) string {
    if name == "Cmd" || name == "Task" || name == "Option" || name == "Result" || name == "Unit" {
        return "base." + name
    }
    return ""
}

func PreludeFuncName(name string) string {
    if name == "unwrapOr" {
        return "base.UnwrapOr"
    }
    if name == "isSome" {
        return "base.IsSome"
    }
    if name == "isNone" {
        return "base.IsNone"
    }
    if name == "mapOption" {
        return "base.MapOption"
    }
    if name == "flatMapOption" {
        return "base.FlatMapOption"
    }
    if name == "mapResult" {
        return "base.MapResult"
    }
    if name == "flatMapResult" {
        return "base.FlatMapResult"
    }
    return ""
}

func HasText(value string) bool {
    if value == "" {
        return false
    }
    return true
}

func IsPreludeOptionType(baseType string) bool {
    if strings.HasSuffix(baseType, ".Option") {
        return true
    }
    return baseType == "Option"
}

func IsPreludeResultType(baseType string) bool {
    if strings.HasSuffix(baseType, ".Result") {
        return true
    }
    return baseType == "Result"
}

func IsPreludeOptionVariant(name string) bool {
    if name == "Some" {
        return true
    }
    return name == "None"
}

func IsPreludeResultVariant(name string) bool {
    if name == "Ok" {
        return true
    }
    return name == "Err"
}

func IsGoKeyword(name string) bool {
    return IsGoKeywordAt(name, 0)
}

func IsGoKeywordAt(name string, idx int) bool {
    keywords := []string{
        "break",
        "default",
        "func",
        "interface",
        "select",
        "case",
        "defer",
        "go",
        "map",
        "struct",
        "chan",
        "else",
        "goto",
        "package",
        "switch",
        "const",
        "fallthrough",
        "if",
        "range",
        "type",
        "continue",
        "for",
        "import",
        "return",
        "var",
    }
    if idx >= len(keywords) {
        return false
    }
    if keywords[idx] == name {
        return true
    }
    return IsGoKeywordAt(name, idx + 1)
}

func IntString(n int) string {
    if n == 0 {
        return "0"
    }
    if n == 1 {
        return "1"
    }
    if n == 2 {
        return "2"
    }
    if n == 3 {
        return "3"
    }
    if n == 4 {
        return "4"
    }
    if n == 5 {
        return "5"
    }
    if n == 6 {
        return "6"
    }
    if n == 7 {
        return "7"
    }
    if n == 8 {
        return "8"
    }
    if n == 9 {
        return "9"
    }
    return "0"
}
