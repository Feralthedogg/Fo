package main

type Point struct {
	X int
	Y int
}

func (p Point) Translate(dx int, dy int) Point {
	return Point{X: p.X + dx, Y: p.Y + dy}
}

func (p Point) Scale(factor int) Point {
	return Point{X: p.X * factor, Y: p.Y * factor}
}

func Distance(a Point, b Point) int {
	dx := a.X - b.X
	dy := a.Y - b.Y
	return dx*dx + dy*dy
}
