package main

import "github.com/Feralthedogg/Fo/stdlib/fo"

func Double(x int) int {
    return x * 2
}

func Positive(x int) bool {
    return x > 0
}

func Add(acc int, x int) int {
    return acc + x
}

func DoublePositives(xs []int) []int {
    return xs |> base.Map(Double) |> base.Filter(Positive)
}

func SumDoublePositives(xs []int) int {
    return xs |> base.Map(Double) |> base.Filter(Positive) |> base.Fold(0, Add)
}
